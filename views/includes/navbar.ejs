<style>
  /* ========== VALL THEME NAVBAR - REFINED ========== */
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  :root {
    --vall-cyan: #00d8ff;
    --vall-cyan-dark: #00b8e6;
    --vall-cyan-glow: 0 0 10px rgba(0, 216, 255, 0.3);
    --vall-bg-dark: #0a0a1a;
    --vall-bg-darker: #050510;
    --vall-text: #e2e8f0;
    --vall-text-muted: #94a3b8;
    --vall-card-bg: rgba(15, 23, 42, 0.95);
  }

  /* Navbar Container */
  .vall-navbar {
    background: linear-gradient(135deg, #0a0a1a 0%, #050510 100%);
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: 70px;
    z-index: 1000;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.4);
    border-bottom: 1px solid rgba(0, 216, 255, 0.2);
  }

  .vall-navbar-container {
    max-width: 1400px;
    margin: 0 auto;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 24px;
    gap: 20px;
  }

  /* Logo */
  .vall-logo {
    font-size: 28px;
    font-weight: 800;
    background: linear-gradient(135deg, #00d8ff, #008cff);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    text-decoration: none;
    letter-spacing: -0.5px;
    transition: all 0.3s ease;
    white-space: nowrap;
  }

  .vall-logo:hover {
    transform: scale(1.02);
    text-shadow: 0 0 15px rgba(0, 216, 255, 0.4);
  }

  /* Desktop Navigation */
  .vall-nav-links {
    display: flex;
    align-items: center;
    gap: 8px;
    flex: 1;
  }

  /* Dropdown */
  .vall-dropdown {
    position: relative;
  }

  .vall-dropdown-btn {
    background: transparent;
    border: none;
    color: var(--vall-text-muted);
    font-size: 14px;
    font-weight: 500;
    padding: 8px 16px;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 6px;
    transition: all 0.3s ease;
    border-radius: 8px;
  }

  .vall-dropdown-btn:hover {
    color: var(--vall-cyan);
    background: rgba(0, 216, 255, 0.05);
  }

  .vall-dropdown-arrow {
    font-size: 10px;
    transition: transform 0.2s ease;
  }

  .vall-dropdown.active .vall-dropdown-arrow {
    transform: rotate(180deg);
  }

  .vall-dropdown-menu {
    position: absolute;
    top: calc(100% + 8px);
    left: 0;
    min-width: 220px;
    background: var(--vall-card-bg);
    border: 1px solid rgba(0, 216, 255, 0.2);
    border-radius: 12px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(10px);
    opacity: 0;
    visibility: hidden;
    transform: translateY(-10px);
    transition: all 0.2s ease;
    z-index: 1001;
  }

  .vall-dropdown.active .vall-dropdown-menu {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .vall-dropdown-item {
    display: block;
    padding: 10px 18px;
    color: var(--vall-text);
    text-decoration: none;
    font-size: 13px;
    transition: all 0.2s ease;
    white-space: nowrap;
  }

  .vall-dropdown-item:hover {
    background: rgba(0, 216, 255, 0.1);
    color: var(--vall-cyan);
    padding-left: 24px;
  }

  .vall-dropdown-divider {
    height: 1px;
    background: rgba(0, 216, 255, 0.1);
    margin: 8px 0;
  }

  /* Nav Link */
  .vall-nav-link {
    color: var(--vall-text-muted);
    text-decoration: none;
    font-size: 14px;
    font-weight: 500;
    padding: 8px 16px;
    transition: all 0.3s ease;
    border-radius: 8px;
  }

  .vall-nav-link:hover {
    color: var(--vall-cyan);
    background: rgba(0, 216, 255, 0.05);
  }

  /* Search Container */
  .vall-search {
    flex: 1;
    max-width: 450px;
    position: relative;
  }

  @media (max-width: 992px) {
    .vall-search {
      max-width: 100%;
      margin: 15px 0;
    }
  }

  .vall-search-form {
    display: flex;
    width: 100%;
  }

  .vall-search-input {
    flex: 1;
    padding: 8px 16px;
    background: rgba(20, 20, 30, 0.8);
    border: 1px solid rgba(0, 216, 255, 0.2);
    border-radius: 40px 0 0 40px;
    color: var(--vall-text);
    font-size: 14px;
    outline: none;
    transition: all 0.3s ease;
  }

  .vall-search-input:focus {
    border-color: var(--vall-cyan);
    background: rgba(0, 216, 255, 0.05);
  }

  .vall-search-input::placeholder {
    color: var(--vall-text-muted);
  }

  .vall-search-btn {
    padding: 0 20px;
    background: linear-gradient(135deg, var(--vall-cyan), #008cff);
    border: none;
    border-radius: 0 40px 40px 0;
    color: white;
    cursor: pointer;
    transition: all 0.3s ease;
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .vall-search-btn:hover {
    transform: scale(1.02);
    box-shadow: 0 0 10px rgba(0, 216, 255, 0.3);
  }

  /* Search Results - Dark Theme */
  .vall-search-results {
    position: absolute;
    top: calc(100% + 8px);
    left: 0;
    right: 0;
    background: var(--vall-card-bg);
    border: 1px solid rgba(0, 216, 255, 0.2);
    border-radius: 12px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
    max-height: 350px;
    overflow-y: auto;
    display: none;
    z-index: 1002;
    backdrop-filter: blur(10px);
  }

  .vall-search-result {
    padding: 12px 16px;
    display: flex;
    align-items: center;
    gap: 12px;
    cursor: pointer;
    transition: all 0.2s ease;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }

  .vall-search-result:hover {
    background: rgba(0, 216, 255, 0.1);
    padding-left: 20px;
  }

  /* Letter Avatar */
  .vall-search-avatar {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--vall-cyan), #008cff);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 14px;
    font-weight: 600;
    color: white;
    text-transform: uppercase;
  }

  .vall-search-result img {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    object-fit: cover;
  }

  .vall-search-result span {
    color: var(--vall-text);
    font-size: 14px;
  }

  .vall-search-no-results {
    padding: 16px;
    color: var(--vall-text-muted);
    text-align: center;
    font-size: 13px;
  }

  /* Right Section */
  .vall-nav-right {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  /* Notification */
  .vall-notification {
    position: relative;
    padding: 8px;
    color: var(--vall-text-muted);
    text-decoration: none;
    display: flex;
    align-items: center;
    transition: all 0.3s ease;
    border-radius: 8px;
  }

  .vall-notification:hover {
    color: var(--vall-cyan);
    background: rgba(0, 216, 255, 0.05);
  }

  .vall-badge {
    position: absolute;
    top: 0;
    right: 0;
    background: #ef4444;
    color: white;
    font-size: 10px;
    font-weight: 600;
    padding: 2px 6px;
    border-radius: 50%;
    min-width: 18px;
    text-align: center;
  }

  /* Profile */
  .vall-profile {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 4px 8px 4px 4px;
    text-decoration: none;
    border-radius: 40px;
    transition: all 0.3s ease;
    cursor: pointer;
    background: transparent;
    border: none;
  }

  .vall-profile:hover {
    background: rgba(0, 216, 255, 0.05);
  }

  .vall-profile-img {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid rgba(0, 216, 255, 0.3);
  }

  .vall-profile-letter {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--vall-cyan), #008cff);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 16px;
    font-weight: 600;
    color: white;
    text-transform: uppercase;
  }

  .vall-profile-name {
    color: var(--vall-text);
    font-size: 13px;
    font-weight: 500;
  }

  /* Mobile Toggle */
  .vall-mobile-toggle {
    display: none;
    background: transparent;
    border: 1px solid rgba(0, 216, 255, 0.3);
    padding: 8px 10px;
    border-radius: 8px;
    cursor: pointer;
  }

  .vall-mobile-toggle span {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--vall-cyan);
    margin: 4px 0;
    transition: all 0.3s ease;
  }

  /* Mobile Menu */
  .vall-mobile-menu {
    position: fixed;
    top: 70px;
    left: 0;
    right: 0;
    background: linear-gradient(135deg, #0f0f1a, #0a0a1a);
    border-bottom: 1px solid rgba(0, 216, 255, 0.2);
    padding: 20px;
    transform: translateY(-100%);
    opacity: 0;
    visibility: hidden;
    transition: all 0.3s ease;
    z-index: 999;
    max-height: calc(100vh - 70px);
    overflow-y: auto;
  }

  .vall-mobile-menu.active {
    transform: translateY(0);
    opacity: 1;
    visibility: visible;
  }

  .vall-mobile-link {
    display: block;
    padding: 12px 0;
    color: var(--vall-text);
    text-decoration: none;
    font-size: 15px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }

  .vall-mobile-dropdown {
    margin: 8px 0;
  }

  .vall-mobile-dropdown-btn {
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
    background: transparent;
    border: none;
    color: var(--vall-text);
    font-size: 15px;
    padding: 12px 0;
    cursor: pointer;
  }

  .vall-mobile-dropdown-menu {
    padding-left: 16px;
    display: none;
  }

  .vall-mobile-dropdown-menu.active {
    display: block;
  }

  .vall-mobile-dropdown-item {
    display: block;
    padding: 10px 0;
    color: var(--vall-text-muted);
    text-decoration: none;
    font-size: 13px;
  }

  /* Responsive */
  @media (max-width: 992px) {
    .vall-nav-links {
      display: none;
    }
    
    .vall-search {
      display: none;
    }
    
    .vall-mobile-toggle {
      display: block;
    }
    
    .vall-nav-right {
      gap: 12px;
    }
    
    .vall-profile-name {
      display: none;
    }
    
    .vall-mobile-menu .vall-search {
      display: block;
      margin: 15px 0;
    }
  }

  @media (max-width: 576px) {
    .vall-navbar-container {
      padding: 0 16px;
    }
    
    .vall-logo {
      font-size: 24px;
    }
    
    .vall-profile-img,
    .vall-profile-letter {
      width: 32px;
      height: 32px;
      font-size: 14px;
    }
  }

  /* Body Padding */
  body {
    padding-top: 70px;
  }

  /* Mobile Dropdown Fix - Make them scrollable */
  @media (max-width: 992px) {
    .vall-dropdown .vall-dropdown-menu {
      position: fixed;
      top: auto;
      bottom: auto;
      left: 10px;
      right: 10px;
      width: calc(100% - 20px);
      max-width: none;
      max-height: 60vh;
      overflow-y: auto;
      z-index: 2000;
    }
    
    #profileDropdown .vall-dropdown-menu {
      top: auto;
      bottom: 80px;
      left: 10px;
      right: 10px;
    }
    
    .vall-notification-dropdown {
      position: fixed;
      top: 70px;
      left: 10px;
      right: 10px;
      max-height: 70vh;
      overflow-y: auto;
      background: linear-gradient(135deg, #0f0f1a, #0a0a1a);
      border: 1px solid rgba(0, 216, 255, 0.2);
      border-radius: 12px;
      padding: 10px 0;
      z-index: 2000;
    }
    
    .vall-dropdown-item {
      padding: 14px 18px;
      font-size: 15px;
    }
    
    .vall-dropdown-menu {
      z-index: 2000;
    }
    
    .vall-notification {
      position: relative;
      cursor: pointer;
    }
  }
  
  @media (max-width: 576px) {
    #profileDropdown .vall-dropdown-menu {
      bottom: 70px;
    }
    
    .vall-dropdown-item {
      padding: 12px 16px;
      font-size: 14px;
    }
  }
  
  .vall-dropdown-menu {
    scroll-behavior: smooth;
  }
  
  .vall-dropdown-menu::-webkit-scrollbar {
    width: 4px;
  }
  
  .vall-dropdown-menu::-webkit-scrollbar-track {
    background: rgba(255, 255, 255, 0.05);
    border-radius: 4px;
  }
  
  .vall-dropdown-menu::-webkit-scrollbar-thumb {
    background: var(--vall-cyan);
    border-radius: 4px;
  }
  @media (max-width: 992px) {
  #profileDropdown .vall-dropdown-menu {
    position: fixed;
    top: 70px;   /* below navbar */
    bottom: auto;
    left: 10px;
    right: 10px;
    margin-right: 10px;
  }
}
html, body {
  height: 100%;
  overflow-x: hidden;  /* only block horizontal scroll */
  overflow-y: auto;    /* allow vertical scroll */
}
@media (max-width: 992px) {
  .vall-dropdown-menu {
    position: absolute; /* instead of fixed */
  }
}
