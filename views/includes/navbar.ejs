<script>
function getUserInitial(user) {
  return user.username ? user.username.charAt(0).toUpperCase() : '?';
}

function toggleDropdown(id) {
  const dropdown = document.getElementById(id);
  dropdown.classList.toggle('active');
  
  document.querySelectorAll('.vall-dropdown').forEach(d => {
    if (d.id !== id) d.classList.remove('active');
  });
}

document.addEventListener('click', function(e) {
  if (!e.target.closest('.vall-dropdown')) {
    document.querySelectorAll('.vall-dropdown').forEach(d => {
      d.classList.remove('active');
    });
  }
});

const mobileToggle = document.getElementById('mobileToggle');
const mobileMenu = document.getElementById('mobileMenu');

if (mobileToggle && mobileMenu) {
  mobileToggle.addEventListener('click', function() {
    mobileMenu.classList.toggle('active');
  });
}

function toggleMobileDropdown(btn) {
  const menu = btn.nextElementSibling;
  menu.classList.toggle('active');
  const arrow = btn.querySelector('span:last-child');
  if (menu.classList.contains('active')) {
    arrow.style.transform = 'rotate(180deg)';
  } else {
    arrow.style.transform = 'rotate(0deg)';
  }
}

const isMainPage = window.location.pathname === '/' || 
                  window.location.pathname === '/home' ||
                  document.body.classList.contains('main-page');

if (!isMainPage) {
  const searchContainers = document.querySelectorAll('.vall-search');
  searchContainers.forEach(container => {
    container.style.display = 'none';
  });
}

function setupSearch(searchInputId, resultsId, searchBtnId) {
  const searchInput = document.getElementById(searchInputId);
  const searchResults = document.getElementById(resultsId);
  const searchBtn = document.getElementById(searchBtnId);
  
  if (!searchInput || !searchResults) return;
  
  let timeoutId;
  
  const performSearch = async (query) => {
    if (query.length < 2) {
      searchResults.style.display = 'none';
      return;
    }
    
    try {
      searchResults.innerHTML = '<div class="vall-search-no-results">Searching...</div>';
      searchResults.style.display = 'block';
      
      const response = await fetch(`/users/search?q=${encodeURIComponent(query)}`);
      const users = await response.json();
      
      if (users.length === 0) {
        searchResults.innerHTML = `<div class="vall-search-no-results">No users found for "${query}"</div>`;
      } else {
        searchResults.innerHTML = '';
        users.forEach(user => {
          const div = document.createElement('div');
          div.className = 'vall-search-result';
          
          if (user.profilePhoto && user.profilePhoto !== '/default-profile.png') {
            div.innerHTML = `
              <img src="${user.profilePhoto}" onerror="this.onerror=null; this.style.display='none'; this.parentElement.querySelector('.search-avatar-fallback').style.display='flex';">
              <div class="vall-search-avatar search-avatar-fallback" style="display: none;">${getUserInitial(user)}</div>
              <span>${user.username}</span>
            `;
          } else {
            div.innerHTML = `
              <div class="vall-search-avatar">${getUserInitial(user)}</div>
              <span>${user.username}</span>
            `;
          }
          
          div.onclick = () => window.location.href = `/users/${user.username}`;
          searchResults.appendChild(div);
        });
      }
    } catch (error) {
      console.error('Search failed:', error);
      searchResults.innerHTML = '<div class="vall-search-no-results">Search failed. Please try again.</div>';
    }
  };
  
  const debouncedSearch = (query) => {
    clearTimeout(timeoutId);
    timeoutId = setTimeout(() => performSearch(query), 300);
  };
  
  searchInput.addEventListener('input', (e) => {
    debouncedSearch(e.target.value.trim());
  });
  
  searchInput.addEventListener('keypress', (e) => {
    if (e.key === 'Enter') {
      e.preventDefault();
      performSearch(searchInput.value.trim());
    }
  });
  
  if (searchBtn) {
    searchBtn.addEventListener('click', () => {
      performSearch(searchInput.value.trim());
    });
  }
  
  document.addEventListener('click', (e) => {
    if (!e.target.closest('.vall-search')) {
      searchResults.style.display = 'none';
    }
  });
}

setupSearch('searchInput', 'searchResults', 'searchBtn');
setupSearch('mobileSearchInput', 'mobileSearchResults', 'mobileSearchBtn');
</script>