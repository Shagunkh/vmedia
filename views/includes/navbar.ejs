<nav class="vall-navbar">
  <div class="vall-navbar-container">
    <a href="/home" class="vall-logo">VALL</a>

    <div class="vall-nav-links">
      <div class="vall-dropdown" id="featuresDropdown">
        <button class="vall-dropdown-btn" onclick="toggleDropdown('featuresDropdown')">
          Features
          <span class="vall-dropdown-arrow">▼</span>
        </button>
        <div class="vall-dropdown-menu">
          <a href="/cgpa" class="vall-dropdown-item">CGPA/GPA Calculator</a>
          <a href="/vride" class="vall-dropdown-item">V-Ride</a>
          <a href="/tasks" class="vall-dropdown-item">Smart Study Planner</a>
          <a href="/quiz" class="vall-dropdown-item">Flashcards & Quizlets</a>
          <a href="/add-drop/page" class="vall-dropdown-item">Add & Drop</a>
          <a href="/api/rooms" class="vall-dropdown-item">Roommate Finder</a>
          <a href="/confessions" class="vall-dropdown-item">Confessions Wall</a>
          <a href="/lost-and-found" class="vall-dropdown-item">Lost & Found Board</a>
          <a href="/ffcs" class="vall-dropdown-item">FFCS Planner</a>
          <a href="/faculty" class="vall-dropdown-item">Faculty Review</a>
          <a href="/api/pyq" class="vall-dropdown-item">Previous Year Papers</a>
          <a href="/collab" class="vall-dropdown-item">Collab Requests</a>
        </div>
      </div>
      
      <a href="/" class="vall-nav-link">Home</a>
      <a href="/aboutus" class="vall-nav-link">About</a>
    </div>

    <div class="vall-search">
      <div class="vall-search-form">
        <input type="text" class="vall-search-input" placeholder="Search users..." id="searchInput">
        <button class="vall-search-btn" id="searchBtn">
          <svg width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
            <path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001c.03.04.062.078.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1.007 1.007 0 0 0-.115-.1zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0z"/>
          </svg>
        </button>
      </div>
      <div class="vall-search-results" id="searchResults"></div>
    </div>

    <div class="vall-nav-right">
      <a href="/notifications" class="vall-notification">
        <svg width="18" height="18" fill="currentColor" viewBox="0 0 16 16">
          <path d="M8 16a2 2 0 0 0 2-2H6a2 2 0 0 0 2 2zM8 1.918l-.797.161A4.002 4.002 0 0 0 4 6c0 .628-.134 2.197-.459 3.742-.16.767-.376 1.566-.663 2.258h10.244c-.287-.692-.503-1.491-.663-2.258C12.134 8.197 12 6.628 12 6a4.002 4.002 0 0 0-3.203-3.92L8 1.917z"/>
        </svg>
        <% if (typeof notifications !== 'undefined' && notifications && notifications.length > 0) { %>
          <span class="vall-badge"><%= notifications.length %></span>
        <% } %>
      </a>

      <% if (typeof currUser !== 'undefined' && currUser) { %>
        <div class="vall-dropdown" id="profileDropdown">
          <button class="vall-profile" onclick="toggleDropdown('profileDropdown')">
            <% if (currUser.profilePhoto) { %>
              <img src="<%= currUser.profilePhoto %>" alt="Profile" class="vall-profile-img">
            <% } else { %>
              <div class="vall-profile-letter"><%= currUser.username.charAt(0).toUpperCase() %></div>
            <% } %>
            <span class="vall-profile-name"><%= currUser.username %></span>
          </button>
          <div class="vall-dropdown-menu" style="right: 0; left: auto;">
            <a href="/profile" class="vall-dropdown-item">My Profile</a>
            <a href="/marketplace/my-products" class="vall-dropdown-item">My Products</a>
            <a href="/marketplace/orders" class="vall-dropdown-item">My Orders</a>
            <div class="vall-dropdown-divider"></div>
            <a href="/users/logout" class="vall-dropdown-item">Logout</a>
          </div>
        </div>
      <% } else { %>
        <a href="/users/login" class="vall-nav-link">Login</a>
        <a href="/users/signup" class="vall-nav-link">Sign Up</a>
      <% } %>
    </div>

    <button class="vall-mobile-toggle" id="mobileToggle">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>

  <div class="vall-mobile-menu" id="mobileMenu">
    <div class="vall-search" style="display: block;">
      <div class="vall-search-form">
