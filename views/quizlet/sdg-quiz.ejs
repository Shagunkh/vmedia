<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Education for Sustainable Development (NPTEL)</title>
    <meta name="description" content="Test your knowledge on Sustainable Development Goals, Education for Sustainable Development, Global Citizenship, and more!">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <style>
        /* ===== COSMIC DESIGN SYSTEM ===== */
        :root {
            --cosmic-primary: linear-gradient(90deg, #00d8ff, #008cff);
            --cosmic-primary-reverse: linear-gradient(90deg, #008cff, #00d8ff);
            --cosmic-light: #00d8ff;
            --cosmic-dark: #008cff;
            --cosmic-black: #0a0a12;
            --cosmic-dark-bg: #12121a;
            --cosmic-card: #0d0d18;
            --cosmic-text: #f0f4ff;
            --cosmic-text-dim: #b0b8cc;
            --cosmic-success: #4cffb0;
            --cosmic-error: #ff4c6a;
            --transition-snap: cubic-bezier(0.8, 0, 0.2, 1);
            --transition-smooth: cubic-bezier(0.4, 0, 0.2, 1);
            --transition-bounce: cubic-bezier(0.7, -0.4, 0.4, 1.4);
        }

        /* ===== ANIMATIONS ===== */
        @keyframes cosmicPulse {
            0%, 100% { transform: scale(1); opacity: 1; }
            50% { transform: scale(1.05); opacity: 0.8; }
        }
        @keyframes cosmicFloat {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-12px); }
        }
        @keyframes cosmicGradient {
            0% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
            100% { background-position: 0% 50%; }
        }
        @keyframes cosmicFadeIn {
            from { opacity: 0; transform: translateY(24px); }
            to { opacity: 1; transform: translateY(0); }
        }
        @keyframes cosmicRipple {
            to { transform: scale(4); opacity: 0; }
        }
        @keyframes cosmicSpin {
            to { transform: rotate(360deg); }
        }
        @keyframes cosmicConfetti {
            0% { transform: translateY(-100px) rotate(0deg); opacity: 1; }
            100% { transform: translateY(100vh) rotate(720deg); opacity: 0; }
        }
        @keyframes subtleGlow {
            0%, 100% { text-shadow: 0 0 8px rgba(0,216,255,0.3); }
            50% { text-shadow: 0 0 18px rgba(0,216,255,0.6); }
        }
        @keyframes starDrift {
            to { transform: translate(var(--tx), var(--ty)); opacity: 0; }
        }

        /* ===== BASE ===== */
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: 'Poppins', -apple-system, BlinkMacSystemFont, sans-serif;
            background-color: var(--cosmic-black);
            background-image:
                radial-gradient(circle at 15% 25%, rgba(0,140,255,0.13) 0%, transparent 30%),
                radial-gradient(circle at 85% 75%, rgba(0,216,255,0.13) 0%, transparent 30%);
            color: var(--cosmic-text);
            min-height: 100vh;
            overflow-x: hidden;
        }

        /* ===== STARS ===== */
        #stars-canvas {
            position: fixed;
            top: 0; left: 0;
            width: 100%; height: 100%;
            pointer-events: none;
            z-index: 0;
            opacity: 0.4;
        }

        /* ===== HEADER ===== */
        .cosmic-header {
            position: relative;
            text-align: center;
            padding: 6rem 2rem 4rem;
            overflow: hidden;
            z-index: 1;
        }
        .cosmic-header::before {
            content: '';
            position: absolute;
            inset: 0;
            background: radial-gradient(ellipse at center top, rgba(0,216,255,0.12) 0%, transparent 65%);
            pointer-events: none;
        }
        .header-badge {
            display: inline-block;
            background: rgba(0,216,255,0.1);
            border: 1px solid rgba(0,216,255,0.3);
            color: var(--cosmic-light);
            font-size: 0.8rem;
            font-weight: 600;
            letter-spacing: 0.15em;
            text-transform: uppercase;
            padding: 0.4rem 1.2rem;
            border-radius: 50px;
            margin-bottom: 1.5rem;
            animation: cosmicFadeIn 0.8s var(--transition-smooth) both;
        }
        .cosmic-title {
            font-size: clamp(2.8rem, 8vw, 6rem);
            font-weight: 900;
            background: var(--cosmic-primary);
            background-size: 200% 200%;
            animation:
                cosmicGradient 6s ease infinite,
                cosmicFloat 7s ease-in-out infinite,
                cosmicFadeIn 1s var(--transition-smooth) 0.1s both;
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
            line-height: 1.1;
            letter-spacing: -0.03em;
            margin-bottom: 1rem;
        }
        .cosmic-tagline {
            font-size: clamp(1rem, 2.5vw, 1.4rem);
            font-weight: 300;
            color: var(--cosmic-text-dim);
            max-width: 600px;
            margin: 0 auto 2.5rem;
            animation: cosmicFadeIn 1s var(--transition-smooth) 0.3s both, subtleGlow 4s ease-in-out infinite;
        }
        .header-stats {
            display: flex;
            justify-content: center;
            gap: 2rem;
            flex-wrap: wrap;
            animation: cosmicFadeIn 1s var(--transition-smooth) 0.5s both;
        }
        .stat-item {
            text-align: center;
        }
        .stat-value {
            font-size: 1.8rem;
            font-weight: 800;
            background: var(--cosmic-primary);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
        }
        .stat-label {
            font-size: 0.75rem;
            color: var(--cosmic-text-dim);
            text-transform: uppercase;
            letter-spacing: 0.1em;
        }

        /* ===== SUBJECT GRID ===== */
        .cosmic-subjects {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            gap: 1.8rem;
            padding: 2rem 3rem 4rem;
            max-width: 1400px;
            margin: 0 auto;
            position: relative;
            z-index: 1;
        }

        /* ===== SUBJECT CARD ===== */
        .cosmic-card {
            background: var(--cosmic-card);
            border: 1px solid rgba(0,216,255,0.08);
            border-radius: 18px;
            padding: 2rem;
            cursor: pointer;
            position: relative;
            overflow: hidden;
            transform-style: preserve-3d;
            transition: all 0.5s var(--transition-snap);
            animation: cosmicFadeIn 0.7s var(--transition-smooth) both;
        }
        .cosmic-card:nth-child(1)  { animation-delay: 0.05s; }
        .cosmic-card:nth-child(2)  { animation-delay: 0.10s; }
        .cosmic-card:nth-child(3)  { animation-delay: 0.15s; }
        .cosmic-card:nth-child(4)  { animation-delay: 0.20s; }
        .cosmic-card:nth-child(5)  { animation-delay: 0.25s; }
        .cosmic-card:nth-child(6)  { animation-delay: 0.30s; }
        .cosmic-card:nth-child(7)  { animation-delay: 0.35s; }
        .cosmic-card:nth-child(8)  { animation-delay: 0.40s; }
        .cosmic-card:nth-child(9)  { animation-delay: 0.45s; }
        .cosmic-card:nth-child(10) { animation-delay: 0.50s; }
        .cosmic-card:nth-child(11) { animation-delay: 0.55s; }
        .cosmic-card:nth-child(12) { animation-delay: 0.60s; }

        .cosmic-card::before {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0;
            height: 3px;
            background: var(--cosmic-primary);
            transform: scaleX(0);
            transform-origin: left;
            transition: transform 0.5s var(--transition-snap);
        }
        .cosmic-card::after {
            content: '';
            position: absolute;
            inset: 0;
            background: radial-gradient(circle at 70% 20%, rgba(0,216,255,0.06) 0%, transparent 60%);
            opacity: 0;
            transition: opacity 0.4s ease;
            pointer-events: none;
        }
        .cosmic-card:hover {
            transform: translateY(-10px) rotateX(4deg) rotateY(1deg);
            box-shadow: 0 24px 50px rgba(0,140,255,0.25), 0 0 0 1px rgba(0,216,255,0.2);
            border-color: rgba(0,216,255,0.25);
        }
        .cosmic-card:hover::before { transform: scaleX(1); }
        .cosmic-card:hover::after  { opacity: 1; }

        .card-icon {
            font-size: 2.2rem;
            margin-bottom: 0.8rem;
            display: block;
        }
        .card-week {
            font-size: 0.72rem;
            font-weight: 600;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            color: var(--cosmic-light);
            opacity: 0.7;
            margin-bottom: 0.4rem;
        }
        .cosmic-card-title {
            font-size: 1.3rem;
            font-weight: 700;
            background: var(--cosmic-primary);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
            margin-bottom: 0.8rem;
            line-height: 1.3;
        }
        .cosmic-card-desc {
            font-size: 0.88rem;
            color: var(--cosmic-text-dim);
            line-height: 1.6;
            transition: color 0.3s ease;
        }
        .cosmic-card:hover .cosmic-card-desc { color: var(--cosmic-text); }
        .card-questions {
            margin-top: 1.2rem;
            font-size: 0.78rem;
            color: rgba(0,216,255,0.6);
            font-weight: 600;
        }

        /* ===== MODAL ===== */
        .cosmic-modal {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,0.85);
            backdrop-filter: blur(12px);
            z-index: 1000;
            justify-content: center;
            align-items: center;
            opacity: 0;
            transition: opacity 0.4s var(--transition-smooth);
        }
        .cosmic-modal.show {
            display: flex;
            animation: cosmicFadeIn 0.4s var(--transition-smooth) forwards;
        }
        .cosmic-modal-content {
            background: rgba(13,13,24,0.95);
            border-radius: 20px;
            width: 90%;
            max-width: 860px;
            max-height: 88vh;
            overflow-y: auto;
            padding: 2.5rem;
            position: relative;
            border: 1px solid rgba(0,216,255,0.15);
            box-shadow: 0 30px 80px rgba(0,0,0,0.7), 0 0 40px rgba(0,140,255,0.1);
            transform: scale(0.96) translateY(16px);
            transition: all 0.4s var(--transition-smooth);
        }
        .cosmic-modal.show .cosmic-modal-content { transform: scale(1) translateY(0); }
        .cosmic-modal-title {
            font-size: 2rem;
            font-weight: 800;
            background: var(--cosmic-primary);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
            margin-bottom: 0.5rem;
        }
        .cosmic-modal-subtitle {
            color: var(--cosmic-text-dim);
            margin-bottom: 2rem;
            font-size: 0.92rem;
        }
        .cosmic-close-btn {
            position: absolute;
            top: 1.2rem; right: 1.2rem;
            width: 38px; height: 38px;
            display: flex; align-items: center; justify-content: center;
            border-radius: 50%;
            background: rgba(0,216,255,0.08);
            color: var(--cosmic-text);
            font-size: 1.4rem;
            cursor: pointer;
            transition: all 0.3s ease;
            border: 1px solid rgba(0,216,255,0.15);
        }
        .cosmic-close-btn:hover {
            background: rgba(0,216,255,0.18);
            transform: rotate(90deg);
            color: var(--cosmic-light);
        }

        /* ===== QUIZ START OPTIONS ===== */
        .cosmic-options-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
            gap: 1rem;
        }
        .cosmic-option {
            background: rgba(0,216,255,0.05);
            border: 1px solid rgba(0,216,255,0.15);
            border-radius: 12px;
            padding: 1.2rem 1rem;
            text-align: center;
            cursor: pointer;
            color: var(--cosmic-text);
            font-size: 0.9rem;
            transition: all 0.3s var(--transition-smooth);
            position: relative;
            overflow: hidden;
            min-height: 44px;
            -webkit-tap-highlight-color: transparent;
        }
        .cosmic-option:hover {
            background: rgba(0,216,255,0.12);
            border-color: rgba(0,216,255,0.4);
            transform: translateY(-4px);
            box-shadow: 0 8px 20px rgba(0,216,255,0.12);
        }
        .cosmic-full-option {
            grid-column: 1 / -1;
            background: var(--cosmic-primary);
            color: white;
            font-weight: 700;
            padding: 1.5rem;
            animation: cosmicPulse 3s infinite;
            border: none;
        }
        .cosmic-full-option:hover {
            animation: none;
            background: var(--cosmic-primary-reverse);
            transform: translateY(-4px);
            box-shadow: 0 12px 28px rgba(0,140,255,0.35);
        }

        /* ===== QUIZ SCREEN ===== */
        .cosmic-quiz-screen {
            display: none;
            position: fixed;
            inset: 0;
            background: var(--cosmic-dark-bg);
            z-index: 1001;
            overflow-y: auto;
        }
        .cosmic-quiz-screen.show {
            display: block;
            animation: cosmicFadeIn 0.5s var(--transition-smooth) forwards;
        }
        .cosmic-quiz-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 0.8rem;
            padding: 1.2rem 2rem;
            background: rgba(0,0,0,0.6);
            position: sticky;
            top: 0; z-index: 10;
            border-bottom: 1px solid rgba(0,216,255,0.1);
            backdrop-filter: blur(8px);
        }
        .cosmic-quiz-title {
            font-size: 1.2rem;
            font-weight: 700;
            background: var(--cosmic-primary);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
        }
        .cosmic-timer {
            font-size: 1.15rem;
            font-weight: 700;
            background: var(--cosmic-primary);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
            animation: cosmicPulse 2s infinite;
        }
        .cosmic-quiz-actions {
            display: flex;
            align-items: center;
            gap: 0.8rem;
        }
        .cosmic-question-container {
            padding: 3rem 2rem;
            max-width: 820px;
            margin: 0 auto;
            animation: cosmicFadeIn 0.6s var(--transition-smooth);
        }
        .question-progress {
            font-size: 0.82rem;
            color: var(--cosmic-text-dim);
            margin-bottom: 1rem;
            font-weight: 600;
        }
        .cosmic-question {
            font-size: 1.35rem;
            margin-bottom: 2rem;
            line-height: 1.7;
            color: var(--cosmic-text);
            background: rgba(0,216,255,0.04);
            padding: 1.4rem 1.6rem;
            border-radius: 14px;
            border-left: 4px solid var(--cosmic-light);
        }
        .cosmic-options { display: flex; flex-direction: column; gap: 0.85rem; }
        .cosmic-option-item {
            padding: 1.2rem 1.5rem;
            border: 1px solid rgba(0,216,255,0.1);
            border-radius: 12px;
            cursor: pointer;
            background: rgba(0,216,255,0.03);
            position: relative;
            overflow: hidden;
            transition: all 0.3s var(--transition-smooth);
            animation: cosmicFadeIn 0.5s var(--transition-smooth) both;
            min-height: 44px;
            -webkit-tap-highlight-color: transparent;
        }
        .cosmic-option-item:nth-child(1) { animation-delay: 0.05s; }
        .cosmic-option-item:nth-child(2) { animation-delay: 0.12s; }
        .cosmic-option-item:nth-child(3) { animation-delay: 0.19s; }
        .cosmic-option-item:nth-child(4) { animation-delay: 0.26s; }
        .cosmic-option-item::before {
            content: '';
            position: absolute;
            top: 0; left: 0;
            width: 4px; height: 100%;
            background: var(--cosmic-light);
            transform: scaleY(0);
            transform-origin: top;
            transition: transform 0.3s ease;
        }
        .cosmic-option-item:hover {
            background: rgba(0,216,255,0.08);
            border-color: rgba(0,216,255,0.3);
            transform: translateX(8px);
        }
        .cosmic-option-item.selected {
            background: rgba(0,216,255,0.13);
            border-color: var(--cosmic-light);
            transform: translateX(8px);
        }
        .cosmic-option-item.selected::before { transform: scaleY(1); }
        .cosmic-option-item.correct {
            background: rgba(76,255,176,0.1);
            border-color: var(--cosmic-success);
        }
        .cosmic-option-item.correct::before { background: var(--cosmic-success); transform: scaleY(1); }
        .cosmic-option-item.incorrect {
            background: rgba(255,76,106,0.1);
            border-color: var(--cosmic-error);
        }
        .cosmic-option-item.incorrect::before { background: var(--cosmic-error); transform: scaleY(1); }

        .cosmic-navigation {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-top: 2.5rem;
            padding-top: 1.5rem;
            border-top: 1px solid rgba(0,216,255,0.08);
        }

        /* ===== BUTTONS ===== */
        .cosmic-btn {
            padding: 0.9rem 1.8rem;
            border: none;
            border-radius: 10px;
            cursor: pointer;
            font-weight: 600;
            font-family: 'Poppins', sans-serif;
            font-size: 0.95rem;
            transition: all 0.3s var(--transition-smooth);
            display: flex; align-items: center; justify-content: center;
            gap: 0.4rem;
            min-width: 130px;
            min-height: 44px;
            -webkit-tap-highlight-color: transparent;
        }
        .cosmic-btn-primary {
            background: var(--cosmic-primary);
            color: white;
            box-shadow: 0 4px 14px rgba(0,140,255,0.3);
        }
        .cosmic-btn-primary:hover {
            background: var(--cosmic-primary-reverse);
            transform: translateY(-2px);
            box-shadow: 0 8px 22px rgba(0,140,255,0.4);
        }
        .cosmic-btn-secondary {
            background: rgba(0,216,255,0.08);
            color: var(--cosmic-light);
            border: 1px solid rgba(0,216,255,0.25);
        }
        .cosmic-btn-secondary:hover {
            background: rgba(0,216,255,0.16);
            transform: translateY(-2px);
        }
        .cosmic-btn-danger {
            background: rgba(255,76,106,0.1);
            color: var(--cosmic-error);
            border: 1px solid rgba(255,76,106,0.3);
            min-width: auto;
            padding: 0.7rem 1.2rem;
            font-size: 0.85rem;
        }
        .cosmic-btn-danger:hover { background: rgba(255,76,106,0.2); }
        .cosmic-btn:disabled {
            opacity: 0.45;
            cursor: not-allowed;
            transform: none !important;
            box-shadow: none !important;
        }

        /* ===== RESULTS SCREEN ===== */
        .cosmic-results-screen {
            display: none;
            position: fixed;
            inset: 0;
            background: var(--cosmic-dark-bg);
            z-index: 1002;
            overflow-y: auto;
            padding: 2rem;
            text-align: center;
        }
        .cosmic-results-screen.show {
            display: block;
            animation: cosmicFadeIn 0.5s var(--transition-smooth) forwards;
        }
        .cosmic-results-container {
            max-width: 820px;
            margin: 2rem auto;
            background: var(--cosmic-card);
            border-radius: 22px;
            padding: 3rem;
            border: 1px solid rgba(0,216,255,0.12);
            box-shadow: 0 20px 60px rgba(0,0,0,0.6);
            position: relative;
            overflow: hidden;
            animation: cosmicFloat 6s ease-in-out infinite;
        }
        .cosmic-results-container::before {
            content: '';
            position: absolute;
            top: -60%; left: -60%;
            width: 220%; height: 220%;
            background: radial-gradient(circle, rgba(0,216,255,0.04) 0%, transparent 65%);
            pointer-events: none;
        }
        .result-emoji {
            font-size: 4rem;
            margin-bottom: 1rem;
            display: block;
        }
        .cosmic-results-title {
            font-size: 2.2rem;
            font-weight: 800;
            background: var(--cosmic-primary);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
            margin-bottom: 1rem;
        }
        .cosmic-score {
            font-size: 2.8rem;
            font-weight: 900;
            background: var(--cosmic-primary);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
            display: inline-block;
            position: relative;
            margin: 1rem 0 0.5rem;
        }
        .cosmic-score::after {
            content: '';
            position: absolute;
            bottom: -8px; left: 50%;
            transform: translateX(-50%);
            width: 80px; height: 3px;
            background: var(--cosmic-primary);
            border-radius: 2px;
        }
        .score-message {
            color: var(--cosmic-text-dim);
            font-size: 1rem;
            margin-top: 1.2rem;
        }
        .cosmic-review {
            margin-top: 3rem;
            text-align: left;
        }
        .cosmic-review-title {
            font-size: 1.4rem;
            font-weight: 700;
            margin-bottom: 1.5rem;
            color: var(--cosmic-text);
            border-bottom: 1px solid rgba(0,216,255,0.1);
            padding-bottom: 0.8rem;
        }
        .cosmic-answer-item {
            margin-bottom: 1.8rem;
            padding: 1.2rem 1.5rem;
            border-radius: 12px;
            background: rgba(0,216,255,0.03);
            border: 1px solid rgba(0,216,255,0.06);
            animation: cosmicFadeIn 0.5s var(--transition-smooth) both;
        }
        .cosmic-answer-item.cosmic-correct {
            background: rgba(76,255,176,0.06);
            border-color: rgba(76,255,176,0.15);
        }
        .cosmic-answer-item.cosmic-incorrect {
            background: rgba(255,76,106,0.06);
            border-color: rgba(255,76,106,0.15);
        }
        .cosmic-answer-item p { margin-bottom: 0.4rem; color: var(--cosmic-text); font-size: 0.92rem; }
        .cosmic-answer-item p strong { font-weight: 700; }
        .cosmic-correct-text { color: var(--cosmic-success); }
        .cosmic-incorrect-text { color: var(--cosmic-error); }
        .results-actions {
            display: flex;
            gap: 1rem;
            justify-content: center;
            flex-wrap: wrap;
            margin-top: 2rem;
        }

        /* ===== SPINNER ===== */
        .cosmic-spinner {
            display: none;
            position: fixed;
            top: 50%; left: 50%;
            transform: translate(-50%, -50%);
            width: 56px; height: 56px;
            border: 4px solid rgba(0,216,255,0.1);
            border-radius: 50%;
            border-top-color: var(--cosmic-light);
            animation: cosmicSpin 0.8s linear infinite;
            z-index: 2000;
        }

        /* ===== CONFETTI ===== */
        .cosmic-confetti {
            position: absolute;
            width: 8px; height: 8px;
            opacity: 0;
            animation: cosmicConfetti 4s linear forwards;
            z-index: 1;
            border-radius: 2px;
