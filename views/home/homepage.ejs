<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>VMedia | The VITian Ecosystem</title>
    <link href="https://fonts.googleapis.com/css2?family=SF+Pro+Display:wght@300;400;500;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            --primary: #00d8ff;
            --primary-light: #008cff;
            --dark: #000;
            --dark-gray: #0a0a0a;
            --light-gray: #1a1a1a;
            --text: #fff;
            --text-secondary: #a1a1a6;
            --neon-glow: 0 0 15px rgba(0, 216, 255, 0.7);
            --gradient: linear-gradient(90deg, #00d8ff, #008cff, #00d8ff);
            --gradient-radial: radial-gradient(circle at center, #00d8ff, #008cff);
        }
        
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            background-color: var(--dark);
            color: var(--text);
            font-family: 'SF Pro Display', -apple-system, BlinkMacSystemFont, sans-serif;
            overflow-x: hidden;
            -webkit-font-smoothing: antialiased;
            line-height: 1.6;
        }
        
        /* Next-Level Animations */
        @keyframes float {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-20px); }
        }
        
        @keyframes gradientFlow {
            0% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
            100% { background-position: 0% 50%; }
        }
        
        @keyframes pulse {
            0%, 100% { transform: scale(1); }
            50% { transform: scale(1.05); }
        }
        
        @keyframes neonPulse {
            0%, 100% { text-shadow: 0 0 10px var(--primary), 0 0 20px var(--primary); }
            50% { text-shadow: 0 0 15px var(--primary), 0 0 30px var(--primary); }
        }
        
        @keyframes particleMove {
            0% { transform: translate(0, 0); opacity: 1; }
            100% { transform: translate(var(--tx), var(--ty)); opacity: 0; }
        }
        
        @keyframes slideIn {
            from {
                opacity: 0;
                transform: translateY(30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
        
        /* Navigation - Premium Glass Morphism */
        .nav-container {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            padding: 20px 50px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            z-index: 1000;
            backdrop-filter: blur(12px);
            background: rgba(0, 0, 0, 0.7);
            border-bottom: 1px solid rgba(0, 216, 255, 0.1);
            transition: all 0.5s cubic-bezier(0.165, 0.84, 0.44, 1);
        }
        
        .nav-container.scrolled {
            padding: 15px 50px;
            background: rgba(0, 0, 0, 0.9);
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
        }
        
        .logo-nav {
            font-size: 1.8rem;
            font-weight: 700;
            color: var(--text);
            text-decoration: none;
            background: var(--gradient);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
            position: relative;
        }
        
        .logo-nav::after {
            content: '';
            position: absolute;
            bottom: -5px;
            left: 0;
            width: 100%;
            height: 2px;
            background: var(--gradient);
            transform: scaleX(0);
            transform-origin: right;
            transition: transform 0.6s cubic-bezier(0.19, 1, 0.22, 1);
        }
        
        .logo-nav:hover::after {
            transform: scaleX(1);
            transform-origin: left;
        }
        
        .nav-links {
            display: flex;
            gap: 40px;
        }
        
        .nav-link {
            color: var(--text-secondary);
            text-decoration: none;
            font-size: 1rem;
            font-weight: 400;
            position: relative;
            transition: all 0.5s cubic-bezier(0.165, 0.84, 0.44, 1);
            text-transform: uppercase;
            letter-spacing: 1px;
        }
        
        .nav-link:hover {
            color: var(--text);
        }
        
        .nav-link::before {
            content: '';
            position: absolute;
            bottom: -5px;
            left: 0;
            width: 0;
            height: 2px;
            background: var(--gradient);
            transition: width 0.6s cubic-bezier(0.165, 0.84, 0.44, 1);
        }
        
        .nav-link:hover::before {
            width: 100%;
        }
        
        .auth-buttons {
            display: flex;
            gap: 15px;
        }
        
        .auth-btn {
            padding: 10px 25px;
            border-radius: 50px;
            font-size: 0.9rem;
            text-decoration: none;
            transition: all 0.5s cubic-bezier(0.165, 0.84, 0.44, 1);
            position: relative;
            overflow: hidden;
            z-index: 1;
        }
        
        .auth-btn::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: var(--gradient);
            z-index: -1;
            opacity: 0;
            transition: opacity 0.5s ease;
        }
        
        .login-btn {
            color: var(--text);
            background: transparent;
            border: 1px solid rgba(0, 216, 255, 0.3);
        }
        
        .login-btn:hover {
            color: var(--text);
            border-color: var(--primary);
            box-shadow: var(--neon-glow);
        }
        
        .login-btn:hover::before {
            opacity: 0.2;
        }
        
        .signup-btn {
            color: var(--dark);
            background: var(--gradient);
            font-weight: 500;
            background-size: 200% auto;
            animation: gradientFlow 3s infinite linear;
        }
        
        .signup-btn:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 20px rgba(0, 140, 255, 0.3);
        }
        
        /* Hero Section - Cosmic Effect */
        .hero {
            height: 100vh;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            text-align: center;
            padding: 0 2rem;
            position: relative;
            overflow: hidden;
            background: radial-gradient(ellipse at bottom, #0d0d1a 0%, #000000 100%);
        }
        
        .particles {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
        }
        
        .particle {
            position: absolute;
            width: 2px;
            height: 2px;
            background: var(--primary);
            border-radius: 50%;
            animation: particleMove linear infinite;
        }
        
        .hero-content {
            position: relative;
            z-index: 1;
            max-width: 1000px;
            margin: 0 auto;
        }
        
        .logo {
            font-size: 6rem;
            font-weight: 700;
            margin-bottom: 1rem;
            background: var(--gradient);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
            letter-spacing: -2px;
            text-align: center;
        }
        
        .tagline {
            font-size: 2.5rem;
            font-weight: 400;
            margin-bottom: 2rem;
            color: var(--text);
            line-height: 1.2;
            text-shadow: 0 0 10px rgba(255, 255, 255, 0.1);
            text-align: center;
        }
        
        .subtagline {
            font-size: 1.3rem;
            color: var(--text-secondary);
            margin-bottom: 3rem;
            max-width: 600px;
            margin-left: auto;
            margin-right: auto;
            opacity: 0.9;
            text-align: center;
        }
        
        .cta-container {
            display: flex;
            justify-content: center;
            gap: 20px;
            margin-top: 2rem;
        }
        
        .cta {
            padding: 15px 30px;
            border-radius: 50px;
            font-size: 1.1rem;
            text-decoration: none;
            transition: all 0.5s cubic-bezier(0.165, 0.84, 0.44, 1);
            position: relative;
            overflow: hidden;
            z-index: 1;
            font-weight: 500;
            letter-spacing: 1px;
        }
        
        .cta::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: var(--gradient);
            z-index: -1;
            transition: all 0.5s ease;
        }
        
        .cta-primary {
            color: var(--text);
            border: 1px solid transparent;
        }
        
        .cta-primary::before {
            opacity: 1;
            background-size: 200% auto;
            animation: gradientFlow 3s infinite linear;
        }
        
        .cta-primary:hover {
            transform: translateY(-5px);
            box-shadow: 0 15px 30px rgba(0, 140, 255, 0.4);
        }
        
        .cta-secondary {
            color: var(--primary);
            border: 1px solid var(--primary);
            background: transparent;
        }
        
        .cta-secondary::before {
            opacity: 0;
            background: var(--gradient);
        }
        
        .cta-secondary:hover {
            color: var(--text);
            border-color: transparent;
            transform: translateY(-5px);
            box-shadow: 0 10px 20px rgba(0, 140, 255, 0.3);
        }
        
        .cta-secondary:hover::before {
            opacity: 1;
        }
        
        .scroll-down {
            position: absolute;
            bottom: 30px;
            left: 50%;
            transform: translateX(-50%);
            color: var(--text-secondary);
            font-size: 1.5rem;
            cursor: pointer;
            animation: float 2s ease-in-out infinite;
            transition: all 0.3s ease;
        }
        
        .scroll-down:hover {
            color: var(--primary);
            animation: float 1.5s ease-in-out infinite;
        }
        
        /* VMALL Promo Banner */
        .vmall-promo {
            margin: 80px 20px;
            background: linear-gradient(135deg, #0a0a1a, #050510);
            border-radius: 30px;
            overflow: hidden;
            position: relative;
            border: 1px solid rgba(0, 216, 255, 0.2);
            transition: all 0.5s ease;
            cursor: pointer;
        }
        
        .vmall-promo:hover {
            transform: translateY(-10px);
            border-color: rgba(0, 216, 255, 0.5);
            box-shadow: 0 20px 40px rgba(0, 140, 255, 0.2);
        }
        
        .vmall-promo-content {
            display: flex;
            flex-wrap: wrap;
            align-items: center;
            justify-content: space-between;
            padding: 50px;
            gap: 40px;
            position: relative;
            z-index: 2;
        }
        
        .vmall-promo-left {
            flex: 1;
            min-width: 280px;
        }
        
        .vmall-promo-badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: rgba(0, 216, 255, 0.1);
            padding: 8px 20px;
            border-radius: 40px;
            margin-bottom: 20px;
            border: 1px solid rgba(0, 216, 255, 0.3);
        }
        
        .vmall-promo-badge i {
            color: var(--primary);
            font-size: 12px;
        }
        
        .vmall-promo-badge span {
            color: var(--primary);
            font-size: 12px;
            font-weight: 500;
            letter-spacing: 1px;
        }
        
        .vmall-promo-title {
            font-size: 48px;
            font-weight: 800;
            margin-bottom: 20px;
            color: white;
        }
        
        .vmall-promo-title span {
            background: var(--gradient);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
        }
        
        .vmall-promo-desc {
            font-size: 16px;
            color: var(--text-secondary);
            margin-bottom: 30px;
            max-width: 500px;
        }
        
        .vmall-promo-features {
            display: flex;
            flex-wrap: wrap;
            gap: 15px;
            margin-bottom: 30px;
        }
        
        .vmall-feature {
            display: flex;
            align-items: center;
            gap: 8px;
            background: rgba(255, 255, 255, 0.05);
            padding: 8px 16px;
            border-radius: 40px;
            font-size: 13px;
            color: var(--text-secondary);
        }
        
        .vmall-feature i {
            color: var(--primary);
        }
        
        .vmall-cta {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            background: var(--gradient);
            padding: 14px 32px;
            border-radius: 50px;
            color: var(--dark);
            text-decoration: none;
            font-weight: 600;
            transition: all 0.3s ease;
        }
        
        .vmall-cta:hover {
            transform: translateX(5px);
            box-shadow: 0 0 20px rgba(0, 216, 255, 0.5);
        }
        
        .vmall-promo-right {
            background: rgba(10, 10, 26, 0.6);
            backdrop-filter: blur(10px);
            border-radius: 24px;
            padding: 30px;
            min-width: 280px;
            border: 1px solid rgba(0, 216, 255, 0.2);
        }
        
        .vmall-stats {
            text-align: center;
        }
        
        .vmall-stat {
            padding: 20px;
            margin-bottom: 15px;
            background: rgba(0, 0, 0, 0.3);
            border-radius: 16px;
            transition: all 0.3s ease;
        }
        
        .vmall-stat:hover {
            background: rgba(0, 216, 255, 0.1);
            transform: scale(1.02);
        }
        
        .vmall-stat-number {
            font-size: 36px;
            font-weight: 800;
            background: var(--gradient);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
            display: block;
        }
        
        .vmall-stat-label {
            font-size: 12px;
            color: var(--text-secondary);
        }
        
        .vmall-divider {
            height: 1px;
            background: linear-gradient(90deg, transparent, rgba(0, 216, 255, 0.3), transparent);
            margin: 20px 0;
        }
        
        /* Features Section */
        .features {
            padding: 10rem 0;
            position: relative;
            background: var(--dark);
            overflow: hidden;
        }
        
        .features::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: radial-gradient(circle at center, rgba(0, 216, 255, 0.05) 0%, transparent 70%);
            pointer-events: none;
        }
        
        .section-title {
            font-size: 4rem;
            font-weight: 700;
            text-align: center;
            margin-bottom: 6rem;
            padding: 0 2rem;
            background: var(--gradient);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
            position: relative;
            display: inline-block;
            width: 100%;
        }
        
        .section-title::after {
            content: '';
            position: absolute;
            bottom: -15px;
            left: 50%;
            transform: translateX(-50%);
            width: 100px;
            height: 3px;
            background: var(--gradient);
            border-radius: 3px;
        }
        
        /* Horizontal Scroll Container */
        .horizontal-scroll-container {
            display: flex;
            overflow-x: auto;
            gap: 2rem;
            padding: 2rem;
            scrollbar-width: none;
            -ms-overflow-style: none;
            max-width: 1200px;
            margin: 0 auto;
        }
        
        .horizontal-scroll-container::-webkit-scrollbar {
            display: none;
        }
        
        .feature-card {
            flex: 0 0 300px;
            background: rgba(10, 10, 10, 0.7);
            border-radius: 20px;
            padding: 2.5rem;
            transition: all 0.6s cubic-bezier(0.165, 0.84, 0.44, 1);
            position: relative;
            overflow: hidden;
            backdrop-filter: blur(10px);
            border: 1px solid rgba(0, 216, 255, 0.1);
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
        }
        
        .feature-card::before {
            content: '';
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: var(--gradient-radial);
            opacity: 0.1;
            transform: rotate(45deg);
            transition: all 0.8s cubic-bezier(0.165, 0.84, 0.44, 1);
            z-index: -1;
        }
        
        .feature-card:hover {
            transform: translateY(-15px) scale(1.02);
            box-shadow: 0 20px 40px rgba(0, 140, 255, 0.2);
            border-color: rgba(0, 216, 255, 0.3);
        }
        
        .feature-card:hover::before {
            transform: rotate(90deg);
            opacity: 0.2;
        }
        
        .feature-icon {
            font-size: 3rem;
            margin-bottom: 1.5rem;
            color: var(--primary);
            text-shadow: 0 0 10px rgba(0, 216, 255, 0.3);
            text-align: center;
        }
        
        .feature-card h3 {
            font-size: 1.7rem;
            margin-bottom: 1rem;
            font-weight: 600;
            background: var(--gradient);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
            text-align: center;
        }
        
        .feature-card p {
            color: var(--text-secondary);
            line-height: 1.6;
            font-size: 1.1rem;
            text-align: center;
        }
        
        /* Stats Section */
        .stats {
            padding: 10rem 2rem;
            background: linear-gradient(to bottom, var(--dark), var(--dark-gray));
            position: relative;
            overflow: hidden;
        }
        
        .stats-grid {
            display: flex;
            justify-content: space-around;
            flex-wrap: wrap;
            max-width: 1200px;
            margin: 0 auto;
            gap: 4rem;
        }
        
        .stat-item {
            text-align: center;
            min-width: 200px;
            position: relative;
        }
        
        .stat-item::after {
            content: '';
            position: absolute;
            bottom: -20px;
            left: 50%;
            transform: translateX(-50%);
            width: 50px;
            height: 3px;
            background: var(--gradient);
            border-radius: 3px;
            opacity: 0.7;
        }
        
        .stat-number {
            font-size: 4.5rem;
            font-weight: 700;
            margin-bottom: 0.5rem;
            background: var(--gradient);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
            font-family: 'SF Pro Display', sans-serif;
        }
        
        .stat-label {
            font-size: 1.2rem;
            color: var(--text-secondary);
            text-transform: uppercase;
            letter-spacing: 2px;
        }
        
        /* Testimonials */
        .testimonials {
            padding: 10rem 2rem;
            background: var(--dark);
            position: relative;
            perspective: 1000px;
        }
        
        .testimonial-card {
            max-width: 800px;
            margin: 0 auto;
            background: rgba(10, 10, 10, 0.7);
            border-radius: 20px;
            padding: 4rem;
            text-align: center;
            position: relative;
            backdrop-filter: blur(10px);
            border: 1px solid rgba(0, 216, 255, 0.1);
            box-shadow: 0 20px 50px rgba(0, 0, 0, 0.3);
            transform-style: preserve-3d;
            transition: all 0.5s ease;
        }
        
        .testimonial-card:hover {
            transform: rotateY(5deg) rotateX(5deg) translateY(-10px);
            box-shadow: 0 30px 60px rgba(0, 140, 255, 0.2);
        }
        
        .testimonial-text {
            font-size: 1.6rem;
            font-weight: 300;
            margin-bottom: 3rem;
            line-height: 1.6;
            position: relative;
            font-style: italic;
        }
        
        .testimonial-text::before,
        .testimonial-text::after {
            content: '"';
            font-size: 4rem;
            color: var(--primary);
            opacity: 0.3;
            position: absolute;
            font-family: serif;
        }
        
        .testimonial-text::before {
            top: -2rem;
            left: -1.5rem;
        }
        
        .testimonial-text::after {
            bottom: -3.5rem;
            right: -1.5rem;
        }
        
        .testimonial-author {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 1.5rem;
        }
        
        .author-avatar {
            width: 70px;
            height: 70px;
            border-radius: 50%;
            object-fit: cover;
            border: 3px solid var(--primary);
            box-shadow: 0 0 20px rgba(0, 216, 255, 0.3);
        }
        
        .author-info h4 {
            font-size: 1.4rem;
            margin-bottom: 0.3rem;
            text-align: left;
            color: var(--text);
        }
        
        .author-info p {
            color: var(--text-secondary);
            text-align: left;
            font-size: 1rem;
        }
        
        /* Footer */
        footer {
            padding: 8rem 2rem 3rem;
            background: linear-gradient(to bottom, var(--dark-gray), #000);
            position: relative;
            overflow: hidden;
        }
        
        footer::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 1px;
            background: var(--gradient);
            box-shadow: 0 0 20px rgba(0, 216, 255, 0.5);
        }
        
        .footer-content {
            max-width: 1200px;
            margin: 0 auto;
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 4rem;
        }
        
        .footer-logo {
            font-size: 2rem;
            font-weight: 700;
            margin-bottom: 1.5rem;
            background: var(--gradient);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
            text-align: center;
        }
        
        .footer-about p {
            color: var(--text-secondary);
            margin-bottom: 1.5rem;
            line-height: 1.6;
            font-size: 1.1rem;
            text-align: center;
        }
        
        .social-links {
            display: flex;
            gap: 1rem;
            justify-content: center;
        }
        
        .social-link {
            width: 45px;
            height: 45px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            background: rgba(255, 255, 255, 0.05);
            color: var(--text);
            transition: all 0.5s cubic-bezier(0.165, 0.84, 0.44, 1);
            text-decoration: none;
            position: relative;
            overflow: hidden;
        }
        
        .social-link::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: var(--gradient);
            z-index: -1;
            opacity: 0;
            transition: opacity 0.5s ease;
        }
        
        .social-link:hover {
            transform: translateY(-5px);
            color: var(--text);
        }
        
        .social-link:hover::before {
            opacity: 1;
        }
        
        .footer-links h3 {
            font-size: 1.4rem;
            margin-bottom: 1.5rem;
            font-weight: 600;
            color: var(--text);
            position: relative;
            display: inline-block;
            text-align: center;
            width: 100%;
        }
        
        .footer-links h3::after {
            content: '';
            position: absolute;
            bottom: -5px;
            left: 50%;
            transform: translateX(-50%);
            width: 50%;
            height: 2px;
            background: var(--gradient);
        }
        
        .footer-links ul {
            list-style: none;
            text-align: center;
        }
        
        .footer-links li {
            margin-bottom: 1rem;
        }
        
        .footer-links a {
            color: var(--text-secondary);
            text-decoration: none;
            transition: all 0.3s ease;
            display: inline-block;
            position: relative;
        }
        
        .footer-links a::after {
            content: '';
            position: absolute;
            bottom: -2px;
            left: 0;
            width: 0;
            height: 1px;
            background: var(--gradient);
            transition: width 0.3s ease;
        }
        
        .footer-links a:hover {
            color: var(--primary);
            transform: translateX(5px);
        }
        
        .footer-links a:hover::after {
            width: 100%;
        }
        
        .copyright {
            text-align: center;
            margin-top: 6rem;
            padding-top: 2rem;
            border-top: 1px solid rgba(255, 255, 255, 0.1);
            color: var(--text-secondary);
            font-size: 0.9rem;
            position: relative;
        }
        
        .copyright::before {
            content: '';
            position: absolute;
            top: 0;
            left: 50%;
            transform: translateX(-50%);
            width: 100px;
            height: 2px;
            background: var(--gradient);
        }
        
        /* Responsive */
        @media (max-width: 992px) {
            .nav-links {
                display: none;
            }
            
            .logo {
                font-size: 4.5rem;
            }
            
            .tagline {
                font-size: 2rem;
            }
            
            .vmall-promo-title {
                font-size: 36px;
            }
            
            .vmall-promo-content {
                padding: 40px;
                flex-direction: column;
                text-align: center;
            }
            
            .vmall-promo-desc {
                margin-left: auto;
                margin-right: auto;
            }
            
            .vmall-promo-features {
                justify-content: center;
            }
        }
        
        @media (max-width: 768px) {
            .nav-container {
                padding: 15px 20px;
            }
            
