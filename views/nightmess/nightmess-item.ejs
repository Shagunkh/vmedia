
<style>
.food-detail-container {
    max-width: 1200px;
    margin: 40px auto;
    padding: 0 20px;
}

.food-image {
    border-radius: 24px;
    overflow: hidden;
    background: #f3f4f6;
}

.food-image img {
    width: 100%;
    height: 500px;
    object-fit: contain;
}

.info-card {
    background: white;
    border-radius: 24px;
    padding: 32px;
    box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.1);
}

.price {
    font-size: 36px;
    font-weight: 800;
    color: #f97316;
}

.block-badge {
    display: inline-block;
    background: linear-gradient(135deg, #f97316, #ea580c);
    color: white;
    padding: 8px 16px;
    border-radius: 40px;
    font-weight: 600;
}

.btn-orange {
    background: linear-gradient(135deg, #f97316, #ea580c);
    color: white;
    border: none;
    padding: 14px 24px;
    border-radius: 60px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
}

.btn-orange:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 25px rgba(249,115,22,0.3);
}
</style>

<div class="food-detail-container">
    <a href="/marketplace" class="back-button" onclick="switchToNightMessTab()">
        <i class="fas fa-arrow-left"></i> Back to Night Mess
    </a>
    
    <div class="row mt-4">
        <div class="col-md-6">
            <div class="food-image">
                <img src="<%= item.images[0] %>" alt="<%= item.title %>">
            </div>
            <div class="thumbnail-container mt-3 d-flex gap-2">
                <% item.images.forEach((image, index) => { %>
                    <img src="<%= image %>" class="thumbnail" style="width: 80px; height: 80px; object-fit: cover; border-radius: 12px; cursor: pointer;" onclick="changeImage(this)">
                <% }) %>
            </div>
        </div>
        
        <div class="col-md-6">
            <div class="info-card">
                <h1 class="mb-3"><%= item.title %></h1>
                
                <div class="mb-3">
                    <span class="block-badge">Block <%= item.hostelBlock %></span>
                    <span class="badge bg-info ms-2"><%= item.category %></span>
                </div>
                
                <div class="price mb-3">₹<%= item.price %></div>
                
                <div class="mb-4">
                    <div class="d-flex align-items-center mb-2">
                        <i class="fas fa-user-circle fa-2x me-2 text-muted"></i>
                        <div>
                            <strong><%= item.vendor.username %></strong>
                            <div class="text-muted small">Vendor</div>
                        </div>
                    </div>
                </div>
                
                <div class="mb-4">
                    <h6>Description</h6>
                    <p class="text-muted"><%= item.description %></p>
                </div>
                
                <% if (currUser && item.vendor._id.toString() !== currUser._id.toString()) { %>
                    <div class="action-buttons">
                        <% if (!hasInterested) { %>
                            <form action="/api/nightmess/item/<%= item._id %>/interest" method="POST" style="flex: 1;">
                                <button type="submit" class="btn-orange w-100">
                                    <i class="fas fa-heart"></i> I'm Interested
                                </button>
                            </form>
                        <% } else { %>
                            <button class="btn-orange w-100" disabled>
                                <i class="fas fa-check"></i> Interest Shown!
                            </button>
                        <% } %>
                        
                        <% if (existingChatRoom) { %>
                            <button class="btn-outline open-chat-btn w-100"
                                    data-room-id="<%= existingChatRoom %>"
                                    data-item-id="<%= item._id %>"
                                    data-item-title="<%= item.title %>"
                                    data-other-user-id="<%= item.vendor._id %>"
                                    data-other-user-name="<%= item.vendor.username %>">
                                <i class="fas fa-comments"></i> Chat with Vendor
                            </button>
                        <% } %>
                    </div>
                <% } else if (currUser && item.vendor._id.toString() === currUser._id.toString()) { %>
                    <a href="/marketplace/edit-nightmess-item/<%= item._id %>" class="btn-orange w-100 text-center">
                        <i class="fas fa-edit"></i> Edit Item
                    </a>
                <% } else { %>
                    <div class="alert alert-warning text-center">
                        <a href="/users/login?returnTo=<%= encodeURIComponent('/marketplace/nightmess-item/' + item._id) %>">Login</a> to show interest
                    </div>
                <% } %>
            </div>
        </div>
    </div>
</div>

<script>
function changeImage(element) {
    const mainImage = document.querySelector('.food-image img');
    mainImage.src = element.src;
}

function switchToNightMessTab() {
    sessionStorage.setItem('activeTab', 'nightmess');
}

document.addEventListener('DOMContentLoaded', function() {
    if (sessionStorage.getItem('activeTab') === 'nightmess') {
        sessionStorage.removeItem('activeTab');
        // The parent page will handle tab switching
    }
});
</script>

<%- include('../partials/vall-promo-banner') %>