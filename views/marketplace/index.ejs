<%- include('../partials/header') %>

<style>
/* ========== MODERN VARIABLES ========== */
:root {
    --primary: #2563eb;
    --primary-dark: #1e40af;
    --accent: #f97316;
    --dark: #0f172a;
    --light: #f8fafc;
    --gray-50: #f9fafb;
    --gray-100: #f3f4f6;
    --gray-200: #e5e7eb;
    --gray-600: #4b5563;
    --gray-800: #1f2937;
    --shadow-sm: 0 1px 2px 0 rgb(0 0 0 / 0.05);
    --shadow-md: 0 4px 6px -1px rgb(0 0 0 / 0.1);
    --shadow-lg: 0 10px 15px -3px rgb(0 0 0 / 0.1);
    --shadow-xl: 0 20px 25px -5px rgb(0 0 0 / 0.1);
    --shadow-2xl: 0 25px 50px -12px rgb(0 0 0 / 0.25);
}

/* ========== HERO BANNER - PREMIUM ========== */
.vmall-hero {
    position: relative;
    background: linear-gradient(135deg, #0f172a 0%, #1e1b4b 50%, #0f172a 100%);
    margin: 20px 20px 40px 20px;
    border-radius: 32px;
    overflow: hidden;
    box-shadow: var(--shadow-2xl);
}

.vmall-hero::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: radial-gradient(circle at 20% 50%, rgba(37,99,235,0.15) 0%, transparent 50%);
    pointer-events: none;
}

.vmall-hero::after {
    content: '';
    position: absolute;
    top: -50%;
    right: -20%;
    width: 80%;
    height: 200%;
    background: radial-gradient(circle, rgba(249,115,22,0.1) 0%, transparent 70%);
    pointer-events: none;
}

.vmall-banner {
    padding: 60px 50px;
    position: relative;
    z-index: 2;
}

.banner-title {
    font-size: 56px;
    font-weight: 800;
    line-height: 1.2;
    margin-bottom: 20px;
    color: white;
}

.banner-title span {
    background: linear-gradient(135deg, #60a5fa, #f97316);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
}

.banner-subtitle {
    font-size: 18px;
    color: #94a3b8;
    margin-bottom: 32px;
    max-width: 500px;
    line-height: 1.6;
}

/* ========== SEARCH BAR - FIXED ========== */
.banner-search {
    display: flex;
    gap: 12px;
    max-width: 600px;
    width: 100%;
    box-sizing: border-box;
}

.banner-search-input {
    flex: 1;
    min-width: 0;
    padding: 16px 24px;
    border-radius: 60px;
    border: none;
    font-size: 16px;
    background: rgba(255, 255, 255, 0.1);
    color: white;
    backdrop-filter: blur(10px);
    transition: all 0.3s ease;
}

.banner-search-input::placeholder {
    color: rgba(255, 255, 255, 0.7);
    font-size: 15px;
}

.banner-search-input:focus {
    outline: none;
    background: rgba(255, 255, 255, 0.2);
    box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.3);
}

.banner-search-btn {
    flex-shrink: 0;
    padding: 0 28px;
    border-radius: 60px;
    background: linear-gradient(135deg, #3b82f6, #2563eb);
    border: none;
    color: white;
    font-size: 16px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
    display: flex;
    align-items: center;
    gap: 10px;
    white-space: nowrap;
}

.banner-search-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 25px rgba(37, 99, 235, 0.4);
}

.banner-buttons {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
    margin-top: 24px;
}

.btn-banner-primary {
    background: linear-gradient(135deg, #3b82f6, #2563eb);
    color: white;
    padding: 14px 32px;
    border-radius: 60px;
    text-decoration: none;
    font-weight: 600;
    transition: all 0.3s ease;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    border: none;
    cursor: pointer;
}

.btn-banner-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 25px rgba(37,99,235,0.4);
    color: white;
}

.btn-banner-secondary {
    background: rgba(255,255,255,0.1);
    backdrop-filter: blur(10px);
    color: white;
    padding: 14px 32px;
    border-radius: 60px;
    text-decoration: none;
    font-weight: 600;
    transition: all 0.3s ease;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    border: 1px solid rgba(255,255,255,0.2);
}

.btn-banner-secondary:hover {
    background: rgba(255,255,255,0.2);
    transform: translateY(-2px);
    color: white;
}

.banner-stats {
    display: flex;
    gap: 40px;
    margin-top: 48px;
}

.stat-item {
    text-align: left;
}

.stat-number {
    font-size: 28px;
    font-weight: 800;
    color: white;
    display: block;
}

.stat-label {
    font-size: 13px;
    color: #64748b;
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

.banner-image {
    position: absolute;
    right: 0;
    top: 50%;
    transform: translateY(-50%);
    width: 45%;
    max-width: 500px;
}

/* ========== MOBILE VIEW FIXES ========== */
@media (max-width: 992px) {
    .vmall-hero {
        margin: 10px;
        border-radius: 24px;
    }
    
    .vmall-banner {
        padding: 40px 30px;
        text-align: center;
    }
    
    .banner-title {
        font-size: 36px;
        text-align: center;
        line-height: 1.3;
    }
    
    .banner-subtitle {
        font-size: 14px;
        text-align: center;
        margin-left: auto;
        margin-right: auto;
        max-width: 90%;
    }
    
    .banner-image {
        display: none;
    }
    
    .banner-stats {
        flex-wrap: wrap;
        gap: 20px;
        justify-content: center;
    }
    
    .banner-search {
        max-width: 100%;
        margin: 0 auto;
    }
    
    .banner-search-input {
        padding: 14px 20px;
        font-size: 14px;
    }
    
    .banner-search-btn {
        padding: 0 24px;
        font-size: 14px;
    }
    
    .banner-buttons {
        justify-content: center;
    }
}

@media (max-width: 768px) {
    .vmall-banner {
        padding: 30px 20px;
    }
    
    .banner-title {
        font-size: 32px;
    }
    
    .banner-subtitle {
        font-size: 13px;
    }
    
    .banner-stats {
        gap: 15px;
    }
    
    .stat-number {
        font-size: 20px;
    }
    
    .stat-label {
        font-size: 10px;
    }
    
    .banner-search-btn {
        padding: 0 20px;
    }
}

@media (max-width: 550px) {
    .banner-search {
        display: flex;
        flex-direction: row;
        gap: 8px;
        width: 100%;
    }
    
    .banner-search-input {
        flex: 1;
        padding: 12px 16px;
        font-size: 13px;
    }
    
    .banner-search-input::placeholder {
        font-size: 12px;
    }
    
    .banner-search-btn {
        padding: 0 16px;
        font-size: 13px;
        gap: 6px;
    }
}

@media (max-width: 430px) {
    .banner-search {
        gap: 6px;
    }
    
    .banner-search-input {
        padding: 10px 12px;
        font-size: 12px;
    }
    
    .banner-search-btn {
        padding: 0 12px;
        font-size: 12px;
    }
    
    .banner-search-btn i {
        font-size: 12px;
    }
}

@media (max-width: 380px) {
    .banner-search-btn span {
        display: none;
    }
    
    .banner-search-btn {
        width: 44px;
        height: 44px;
        padding: 0;
        border-radius: 50%;
        justify-content: center;
    }
    
    .banner-search-btn i {
        margin: 0;
        font-size: 18px;
    }
}

/* ========== BROWSE SECTION ========== */
.browse-section {
    margin: 60px 20px 40px 20px;
}

/* ========== TAB STYLES ========== */
.tab-container {
    margin-bottom: 32px;
    border-bottom: 2px solid var(--gray-200);
}

.tab-buttons {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
}

.tab-btn {
    padding: 12px 28px;
    font-size: 16px;
    font-weight: 600;
    background: transparent;
    border: none;
    color: var(--gray-600);
    cursor: pointer;
    transition: all 0.3s ease;
    border-radius: 40px;
    position: relative;
}

.tab-btn:hover {
    color: var(--primary);
    background: rgba(37, 99, 235, 0.05);
}

.tab-btn.active {
    color: var(--primary);
    background: linear-gradient(135deg, rgba(37, 99, 235, 0.1), rgba(249, 115, 22, 0.05));
}

.tab-btn.active::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--primary), var(--accent));
    border-radius: 2px;
}

.tab-content {
    display: none;
    animation: fadeIn 0.3s ease;
}

.tab-content.active {
    display: block;
}

@keyframes fadeIn {
    from {
        opacity: 0;
        transform: translateY(10px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

/* ========== NIGHT MESS EMPTY STATE ========== */
.night-mess-empty {
    text-align: center;
    padding: 80px 40px;
    background: linear-gradient(135deg, #fef3c7 0%, #fffbeb 100%);
    border-radius: 32px;
    margin: 20px 0;
}

.night-mess-icon {
    width: 100px;
    height: 100px;
    background: linear-gradient(135deg, #f97316, #ea580c);
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 24px;
}

.night-mess-icon i {
    font-size: 48px;
    color: white;
}

.night-mess-title {
    font-size: 28px;
    font-weight: 700;
    margin-bottom: 12px;
    color: #7c2d12;
}

.night-mess-text {
    color: #9a3412;
    margin-bottom: 24px;
    max-width: 400px;
    margin-left: auto;
    margin-right: auto;
}

.night-mess-btn {
    background: #7c2d12;
    color: white;
    padding: 12px 28px;
    border-radius: 40px;
    text-decoration: none;
    font-weight: 600;
    display: inline-block;
    transition: all 0.3s ease;
}

.night-mess-btn:hover {
    background: #9a3412;
    transform: translateY(-2px);
    box-shadow: 0 5px 15px rgba(124, 45, 18, 0.3);
}

/* ========== FILTER BAR ========== */
.filter-bar {
    background: white;
    border-radius: 20px;
    padding: 20px 24px;
    margin-bottom: 32px;
    box-shadow: var(--shadow-sm);
    border: 1px solid var(--gray-200);
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 16px;
    justify-content: space-between;
}

.filter-group {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
}

.filter-label {
    font-weight: 600;
    color: var(--gray-800);
    font-size: 14px;
}

.filter-select {
    padding: 8px 16px;
    border: 1px solid var(--gray-200);
    border-radius: 12px;
    font-size: 14px;
    background: white;
    cursor: pointer;
    transition: all 0.2s;
}

.filter-select:focus {
    outline: none;
    border-color: var(--primary);
}

.price-input-group {
    display: flex;
    gap: 8px;
}

.price-input {
    width: 100px;
    padding: 8px 12px;
    border: 1px solid var(--gray-200);
    border-radius: 12px;
    font-size: 14px;
}

.filter-apply {
    background: var(--primary);
    color: white;
    border: none;
    padding: 8px 24px;
    border-radius: 12px;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s;
}

.filter-apply:hover {
    background: var(--primary-dark);
}

.sell-quick-btn {
    background: linear-gradient(135deg, #f97316, #ea580c);
    color: white;
    padding: 8px 24px;
    border-radius: 12px;
    text-decoration: none;
    font-weight: 500;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    transition: all 0.2s;
}

.sell-quick-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 5px 15px rgba(249,115,22,0.3);
    color: white;
}

@media (max-width: 768px) {
    .filter-bar {
        flex-direction: column;
        align-items: stretch;
    }
    .filter-group {
        justify-content: space-between;
    }
    
    .tab-btn {
        padding: 8px 20px;
        font-size: 14px;
    }
}

/* ========== PRODUCT GRID ========== */
.products-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 28px;
}

.product-card-vmall {
    background: white;
    border-radius: 24px;
    overflow: hidden;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    border: 1px solid var(--gray-200);
    position: relative;
    cursor: pointer;
    text-decoration: none;
    display: block;
}

.product-card-vmall:hover {
    transform: translateY(-8px);
    box-shadow: var(--shadow-2xl);
    border-color: transparent;
}

.product-card-vmall:hover .product-image-vmall img {
    transform: scale(1.08);
}

.product-image-vmall {
    position: relative;
    overflow: hidden;
    aspect-ratio: 1;
    background: linear-gradient(135deg, var(--gray-100) 0%, #fff 100%);
}

.product-image-vmall img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
}

.product-badge-vmall {
    position: absolute;
    top: 16px;
    left: 16px;
    background: rgba(0,0,0,0.75);
    backdrop-filter: blur(8px);
    padding: 6px 14px;
    border-radius: 30px;
    font-size: 12px;
    font-weight: 600;
    color: white;
    letter-spacing: 0.5px;
    z-index: 2;
}

.product-wishlist {
    position: absolute;
    top: 16px;
    right: 16px;
    width: 36px;
    height: 36px;
    background: rgba(255,255,255,0.9);
    backdrop-filter: blur(8px);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.3s ease;
    z-index: 2;
}

.product-wishlist:hover {
    background: white;
    transform: scale(1.1);
}

.product-wishlist i {
    color: #ef4444;
    font-size: 16px;
}

.product-info {
    padding: 20px;
}

.product-title-vmall {
    font-size: 18px;
    font-weight: 700;
    margin-bottom: 8px;
    color: var(--dark);
    line-height: 1.4;
    transition: color 0.2s;
}

.product-card-vmall:hover .product-title-vmall {
    color: var(--primary);
}

.product-meta-vmall {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 12px;
}

.seller-vmall {
    font-size: 12px;
    color: var(--gray-600);
    display: flex;
    align-items: center;
    gap: 6px;
}

.seller-vmall i {
    font-size: 12px;
    color: var(--primary);
}

.condition-vmall {
    font-size: 11px;
    padding: 4px 10px;
    border-radius: 20px;
    font-weight: 600;
}

.condition-new {
    background: linear-gradient(135deg, #10b981, #059669);
    color: white;
}

.condition-like-new {
    background: linear-gradient(135deg, #3b82f6, #2563eb);
    color: white;
}

.condition-good {
    background: linear-gradient(135deg, #f59e0b, #d97706);
    color: white;
}

.product-description {
    font-size: 13px;
    color: var(--gray-600);
    line-height: 1.5;
    margin-bottom: 16px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
}

.price-section {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    align-items: center;
    padding-top: 12px;
    border-top: 1px solid var(--gray-200);
}

.product-price-vmall {
    font-size: 24px;
    font-weight: 800;
    background: linear-gradient(135deg, var(--primary), var(--accent));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
}

.view-details-icon {
    width: 32px;
    height: 32px;
    background: var(--gray-100);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
    opacity: 0;
    transform: translateX(-10px);
}

.product-card-vmall:hover .view-details-icon {
    opacity: 1;
    transform: translateX(0);
}

.view-details-icon i {
    font-size: 14px;
    color: var(--primary);
}

/* ========== PRODUCT GRID - RESPONSIVE ========== */
@media (min-width: 769px) and (max-width: 1024px) {
    .products-grid {
        grid-template-columns: repeat(2, 1fr);
        gap: 20px;
    }
}

@media (max-width: 768px) {
    .products-grid {
        grid-template-columns: repeat(2, 1fr);
        gap: 12px;
        padding: 0 4px;
    }
    
    .product-card-vmall {
        border-radius: 12px;
    }
    
    .product-image-vmall {
        aspect-ratio: 1;
    }
    
    .product-info {
        padding: 10px;
    }
    
    .product-title-vmall {
        font-size: 13px;
        font-weight: 600;
        margin-bottom: 4px;
        line-height: 1.3;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        min-height: 34px;
    }
    
    .product-meta-vmall {
        margin-bottom: 6px;
        flex-wrap: wrap;
        gap: 4px;
    }
    
    .seller-vmall {
        font-size: 10px;
    }
    
    .seller-vmall i {
        font-size: 9px;
    }
    
    .condition-vmall {
        font-size: 8px;
        padding: 2px 6px;
        border-radius: 12px;
    }
    
    .product-description {
        display: none;
    }
    
    .price-section {
        padding-top: 6px;
        margin-top: 0;
        border-top: 1px solid var(--gray-200);
    }
    
    .product-price-vmall {
        font-size: 14px;
        font-weight: 700;
    }
    
    .view-details-icon {
        width: 24px;
        height: 24px;
    }
    
    .view-details-icon i {
        font-size: 10px;
    }
    
    .product-badge-vmall {
        top: 8px;
        left: 8px;
        padding: 3px 8px;
        font-size: 8px;
        font-weight: 500;
    }
    
    .product-wishlist {
        top: 8px;
        right: 8px;
        width: 28px;
        height: 28px;
    }
    
    .product-wishlist i {
        font-size: 12px;
    }
}

@media (max-width: 480px) {
    .products-grid {
        gap: 10px;
    }
    
    .product-info {
        padding: 8px;
    }
    
    .product-title-vmall {
        font-size: 12px;
        min-height: 30px;
    }
    
    .seller-vmall {
        font-size: 9px;
    }
    
    .condition-vmall {
        font-size: 7px;
        padding: 1px 4px;
    }
    
    .product-price-vmall {
        font-size: 13px;
    }
    
    .view-details-icon {
        width: 20px;
        height: 20px;
    }
    
    .view-details-icon i {
        font-size: 9px;
    }
}

@media (max-width: 360px) {
    .products-grid {
        gap: 8px;
    }
    
    .product-title-vmall {
        font-size: 11px;
        min-height: 28px;
    }
    
    .product-price-vmall {
        font-size: 12px;
    }
}

/* ========== ONGOING SECTION ========== */
.ongoing-section {
    margin: 40px 20px;
    background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%);
    border-radius: 28px;
    padding: 48px;
    position: relative;
    overflow: hidden;
}

.ongoing-section::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -20%;
    width: 300px;
    height: 300px;
    background: radial-gradient(circle, rgba(249,115,22,0.2) 0%, transparent 70%);
    border-radius: 50%;
}

.ongoing-content {
    position: relative;
    z-index: 2;
}

.ongoing-badge {
    display: inline-block;
    background: #f97316;
    color: white;
    padding: 6px 16px;
    border-radius: 30px;
    font-size: 13px;
    font-weight: 600;
    margin-bottom: 20px;
}

.ongoing-title {
    font-size: 36px;
    font-weight: 800;
    margin-bottom: 16px;
    color: #7c2d12;
}

.ongoing-text {
    font-size: 16px;
    color: #9a3412;
    margin-bottom: 28px;
    max-width: 500px;
}

.ongoing-btn {
    background: #7c2d12;
    color: white;
    padding: 14px 32px;
    border-radius: 50px;
    text-decoration: none;
    font-weight: 600;
    display: inline-flex;
    align-items: center;
    gap: 10px;
    transition: all 0.3s ease;
}

.ongoing-btn:hover {
    background: #9a3412;
    transform: translateX(5px);
    color: white;
}

@media (max-width: 768px) {
    .ongoing-section {
        padding: 30px 20px;
        margin: 30px 10px;
    }
    
    .ongoing-title {
        font-size: 28px;
    }
    
    .ongoing-text {
        font-size: 14px;
    }
    
    .ongoing-btn {
