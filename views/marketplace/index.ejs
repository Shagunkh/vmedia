<script>
function performSearch() {
    const searchQuery = document.getElementById('bannerSearchInput').value;
    if (searchQuery.trim()) {
        window.location.href = `/marketplace?search=${encodeURIComponent(searchQuery)}`;
    } else {
        window.location.href = '/marketplace';
    }
}

document.getElementById('bannerSearchInput')?.addEventListener('keypress', function(e) {
    if (e.key === 'Enter') {
        performSearch();
    }
});
</script>

