        animation: rotateBg 20s linear infinite;
    }
    
    @keyframes rotateBg {
        from { transform: rotate(0deg); }
        to { transform: rotate(360deg); }
    }
    
    /* Floating Particles */
    .hero-particles {
        position: absolute;
        width: 100%;
        height: 100%;
