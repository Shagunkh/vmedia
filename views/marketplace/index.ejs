<script>
function toggleWishlist(element, productId) {
    const icon = element.querySelector('i');
    if (icon.classList.contains('far')) {
        icon.classList.remove('far');
        icon.classList.add('fas');
        icon.style.color = '#ef4444';
    } else {
        icon.classList.remove('fas');
        icon.classList.add('far');
        icon.style.color = '';
    }
}

function switchTab(tabName) {
    const tabs = document.querySelectorAll('.tab-btn');
    const contents = document.querySelectorAll('.tab-content');
    
    tabs.forEach(tab => tab.classList.remove('active'));
    contents.forEach(content => content.classList.remove('active'));
    
    if (tabName === 'products') {
        document.getElementById('productsTab').classList.add('active');
        document.querySelector('.tab-buttons button:first-child').classList.add('active');
    } else if (tabName === 'nightmess') {
        document.getElementById('nightmessTab').classList.add('active');
        document.querySelector('.tab-buttons button:last-child').classList.add('active');
        loadNightMessItems();
    }
}

// ============ NIGHT MESS FUNCTIONS ============
// ============ NIGHT MESS FUNCTIONS ============
let nightMessItems = [];
let currentBlockFilter = '';
let currentSearchQuery = '';
let currentHostelType = 'both';

function loadNightMessItems() {
    const container = document.getElementById('nightmessItemsContainer');
    if (!container) return;
    
    container.innerHTML = '<div style="text-align: center; padding: 60px;"><div style="width: 60px; height: 60px; border: 3px solid var(--gray-200); border-top-color: #f97316; border-radius: 50%; margin: 0 auto 20px; animation: spin 1s linear infinite;"></div><p>Loading food stalls...</p></div>';
    
    // FIXED: Correct API endpoint with /nightmess prefix
    let url = '/nightmess/api/nightmess';
    const params = new URLSearchParams();
    if (currentBlockFilter && currentBlockFilter !== '') params.append('hostelBlock', currentBlockFilter);
    if (currentSearchQuery && currentSearchQuery !== '') params.append('search', currentSearchQuery);
    if (currentHostelType && currentHostelType !== 'both') params.append('hostelType', currentHostelType);
    if (params.toString()) url += '?' + params.toString();
    
    console.log('Fetching from URL:', url);
    
    fetch(url)
        .then(response => {
            if (!response.ok) {
                throw new Error(`HTTP ${response.status}`);
            }
            return response.json();
        })
        .then(data => {
            console.log('Night mess data received:', data);
            if (data.success !== false) {
                const items = data.items || [];
                renderNightMessItems(items, data.isOpen);
            } else {
                throw new Error(data.error || 'Failed to load');
            }
        })
        .catch(err => {
            console.error('Error loading night mess items:', err);
            container.innerHTML = `
                <div class="empty-state">
                    <div class="empty-icon"><i class="fas fa-utensils"></i></div>
                    <h3>Unable to load items</h3>
                    <p>Error: ${err.message}</p>
                    <button onclick="loadNightMessItems()" class="btn" style="background: linear-gradient(135deg, #f97316, #ea580c); color: white; padding: 12px 24px; border-radius: 40px; margin-top: 16px;">
                        <i class="fas fa-sync-alt"></i> Retry
                    </button>
                </div>
            `;
        });
}
function renderNightMessItems(items, isOpen) {
    const container = document.getElementById('nightmessItemsContainer');
    
    // Check if night mess is open
    if (isOpen === false) {
        container.innerHTML = `
            <div class="empty-state">
                <div class="empty-icon"><i class="fas fa-clock"></i></div>
                <h3>Night Mess is Closed</h3>
                <p>Open from 10:30 PM to 3:00 AM. Come back later for delicious food!</p>
            </div>
        `;
        return;
    }
    
    if (!items || items.length === 0) {
        container.innerHTML = `
            <div class="empty-state">
                <div class="empty-icon"><i class="fas fa-utensils"></i></div>
                <h3>No food stalls found</h3>
                <p>Be the first to add a food stall!</p>
                <% if (typeof currUser !== 'undefined' && currUser) { %>
                    <a href="/nightmess/add-item" class="btn" style="background: linear-gradient(135deg, #f97316, #ea580c); color: white; padding: 12px 28px; border-radius: 40px; text-decoration: none; display: inline-block; margin-top: 16px;">
                        <i class="fas fa-plus-circle"></i> Add Your Food Stall
                    </a>
                <% } else { %>
                    <a href="/users/login" class="btn" style="background: linear-gradient(135deg, #f97316, #ea580c); color: white; padding: 12px 28px; border-radius: 40px; text-decoration: none; display: inline-block; margin-top: 16px;">
                        Login to Add Food Stall
                    </a>
                <% } %>
            </div>
        `;
        return;
    }
    
    let html = '<div class="food-grid">';
    
    items.forEach(item => {
        const menuCount = item.menuItems ? item.menuItems.length : 0;
        const previewItems = item.menuItems ? item.menuItems.slice(0, 3) : [];
        const hostelTypeClass = item.hostelType === 'men' ? 'men' : 'women';
        const hostelTypeText = item.hostelType === 'men' ? '👨 Men\'s Only' : '👩 Women\'s Only';
        
        html += `
            <a href="/nightmess/item/${item._id}" class="food-card">
                <div class="food-image">
                    <img src="${escapeHtml(item.images && item.images[0] ? item.images[0] : '/images/default-food.jpg')}" alt="${escapeHtml(item.vendorName)}">
                    <div class="food-badge">${escapeHtml(item.category)}</div>
                    <div class="food-block-badge">Block ${escapeHtml(item.hostelBlock)}</div>
                    <div class="hostel-type-badge ${hostelTypeClass}">${hostelTypeText}</div>
                </div>
                <div class="food-info">
                    <div class="food-vendor-name">
                        <i class="fas fa-store"></i> ${escapeHtml(item.vendorName)}
                    </div>
                    <div class="food-category">
                        <i class="fas fa-tag"></i> ${escapeHtml(item.category)}
                    </div>
                    <div class="menu-count">
                        <i class="fas fa-utensils"></i> ${menuCount} menu items
                    </div>
                    ${previewItems.length > 0 ? `
                        <div class="menu-preview">
                            ${previewItems.map(menuItem => `
                                <span class="menu-preview-item">${escapeHtml(menuItem.itemName.substring(0, 15))}${menuItem.itemName.length > 15 ? '...' : ''}</span>
                            `).join('')}
                            ${menuCount > 3 ? `<span class="menu-preview-item">+${menuCount - 3} more</span>` : ''}
                        </div>
                    ` : '<div class="menu-preview"><span class="menu-preview-item">No items added yet</span></div>'}
                    <div class="food-meta">
                        <span class="food-vendor">
                            <i class="fas fa-user-circle"></i> ${escapeHtml(item.vendor?.username || 'Unknown')}
                        </span>
                        <span class="food-rating">
                            ${item.averageRating > 0 ? `<i class="fas fa-star"></i> ${item.averageRating.toFixed(1)}` : '<i class="far fa-star"></i> No ratings'}
                        </span>
                    </div>
                </div>
            </a>
        `;
    });
    
    html += '</div>';
    container.innerHTML = html;
}

function escapeHtml(text) {
    if (!text) return '';
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
}

function filterNightMessByType(type) {
    currentHostelType = type;
    loadNightMessItems();
    
    document.querySelectorAll('.hostel-type-btn').forEach(btn => {
        if (btn.getAttribute('data-type') === type) {
            btn.classList.add('active');
            btn.style.background = 'linear-gradient(135deg, #f97316, #ea580c)';
            btn.style.color = 'white';
        } else {
            btn.classList.remove('active');
            btn.style.background = 'rgba(10, 10, 26, 0.6)';
            btn.style.color = '#94a3b8';
        }
    });
}

function filterNightMessByBlock(block) {
    currentBlockFilter = block;
    loadNightMessItems();
    
    document.querySelectorAll('#nightmessTab .block-btn').forEach(btn => {
        if (btn.innerText === block || (block === '' && btn.innerText === 'All Blocks')) {
            btn.style.background = 'linear-gradient(135deg, #f97316, #ea580c)';
            btn.style.color = 'white';
        } else {
            btn.style.background = 'var(--gray-100)';
            btn.style.color = 'var(--gray-600)';
        }
    });
}

function searchNightMess() {
    const searchInput = document.getElementById('nightmessSearchInput');
    if (searchInput) {
        currentSearchQuery = searchInput.value.trim();
        loadNightMessItems();
    }
}

document.addEventListener('DOMContentLoaded', function() {
    // Always load night mess items when page loads
    loadNightMessItems();
    
    const searchInput = document.getElementById('nightmessSearchInput');
    const searchBtn = document.querySelector('#nightmessTab button[onclick="searchNightMess()"]');
    
    if (searchBtn) {
        searchBtn.addEventListener('click', function(e) {
            e.preventDefault();
            searchNightMess();
        });
    }
    
    if (searchInput) {
        searchInput.addEventListener('keypress', function(e) {
            if (e.key === 'Enter') {
                e.preventDefault();
                searchNightMess();
            }
        });
    }
});
</script>
<script>
// Add interactive counter animation when card comes into view
document.addEventListener('DOMContentLoaded', function() {
    const salesCard = document.querySelector('.total-sales-card');
    const amountElement = document.getElementById('totalSalesAmount');
    const targetAmount = <%= totalSales %>;
    
    const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                animateNumber(amountElement, 0, targetAmount, 2000);
                observer.unobserve(entry.target);
            }
        });
    }, { threshold: 0.3 });
    
    if (salesCard) {
        observer.observe(salesCard);
    }
    
    function animateNumber(element, start, end, duration) {
        let startTimestamp = null;
        const step = (timestamp) => {
            if (!startTimestamp) startTimestamp = timestamp;
            const progress = Math.min((timestamp - startTimestamp) / duration, 1);
            const current = Math.floor(progress * (end - start) + start);
            element.textContent = current.toLocaleString();
            if (progress < 1) {
                window.requestAnimationFrame(step);
            }
        };
        window.requestAnimationFrame(step);
    }
    
    // Add click interaction
    if (salesCard) {
        salesCard.addEventListener('click', function() {
            this.style.transform = 'scale(0.98)';
            setTimeout(() => {
                this.style.transform = '';
            }, 200);
            
            // Optional: Show a toast or redirect to sales page
            console.log('Total Sales: ₹<%= totalSales.toLocaleString() %>');
        });
    }
});
</script>