<script>
function toggleWishlist(element, productId) {
    const icon = element.querySelector('i');
    if (icon.classList.contains('far')) {
        icon.classList.remove('far');
        icon.classList.add('fas');
        icon.style.color = '#ef4444';
        console.log('Added to wishlist:', productId);
    } else {
        icon.classList.remove('fas');
        icon.classList.add('far');
        icon.style.color = '';
        console.log('Removed from wishlist:', productId);
    }
}

function switchTab(tabName) {
    // Update active button styles
    const tabs = document.querySelectorAll('.tab-btn');
    tabs.forEach(tab => tab.classList.remove('active'));
    
    // Update content visibility
    const contents = document.querySelectorAll('.tab-content');
    contents.forEach(content => content.classList.remove('active'));
    
    if (tabName === 'products') {
        document.getElementById('productsTab').classList.add('active');
        document.querySelector('.tab-buttons button:first-child').classList.add('active');
    } else if (tabName === 'nightmess') {
        document.getElementById('nightmessTab').classList.add('active');
        document.querySelector('.tab-buttons button:last-child').classList.add('active');
    }
}
</script>
<script>
// ============ NIGHT MESS FUNCTIONS ============
let nightMessItems = [];
let currentBlockFilter = '';
let currentSearchQuery = '';

function loadNightMessItems() {
    const container = document.getElementById('nightmessItemsContainer');
    if (!container) return;
    
    container.innerHTML = '<div style="text-align: center; padding: 60px;"><div style="width: 60px; height: 60px; border: 3px solid var(--gray-200); border-top-color: #f97316; border-radius: 50%; margin: 0 auto 20px; animation: spin 1s linear infinite;"></div><p>Loading night mess items...</p></div>';
    
    // FIXED: Correct API endpoint
    let url = 'nightmess/api/nightmess';
    const params = new URLSearchParams();
    if (currentBlockFilter) params.append('hostelBlock', currentBlockFilter);
    if (currentSearchQuery) params.append('search', currentSearchQuery);
    if (params.toString()) url += '?' + params.toString();
    
    console.log('Fetching from URL:', url);
    
    fetch(url)
        .then(response => {
            if (!response.ok) {
                throw new Error(`HTTP ${response.status}`);
            }
            return response.json();
        })
        .then(data => {
            console.log('Night mess data received:', data);
            if (data.success !== false) {
                nightMessItems = data.items || [];
                renderNightMessItems(data);
            } else {
                throw new Error(data.error || 'Failed to load');
            }
        })
        .catch(err => {
            console.error('Error loading night mess items:', err);
            container.innerHTML = `
                <div class="empty-state">
                    <div class="empty-icon"><i class="fas fa-utensils"></i></div>
                    <h3>Unable to load items</h3>
                    <p>Please try again later. Make sure the server is running.</p>
                    <button onclick="loadNightMessItems()" class="btn btn-primary mt-3">Retry</button>
                </div>
            `;
        });
}

function renderNightMessItems(data) {
    const container = document.getElementById('nightmessItemsContainer');
    
    // Check if night mess is open
    const isOpen = data.isOpen !== undefined ? data.isOpen : true;
    
    if (!isOpen) {
        container.innerHTML = `
            <div class="empty-state">
                <div class="empty-icon"><i class="fas fa-clock"></i></div>
                <h3>Night Mess is Closed</h3>
                <p>Open from 10:30 PM to 3:00 AM. Come back later for delicious food!</p>
            </div>
        `;
        return;
    }
    
    const items = data.items || [];
    
    if (items.length === 0) {
        container.innerHTML = `
            <div class="empty-state">
                <div class="empty-icon"><i class="fas fa-utensils"></i></div>
                <h3>No items found</h3>
                <p>Be the first to add a food item!</p>
                <% if (currUser) { %>
                    <a href="/nightmess/add-item" class="btn" style="background: linear-gradient(135deg, #f97316, #ea580c); color: white; padding: 12px 28px; border-radius: 40px; text-decoration: none; display: inline-block; margin-top: 16px;">
                        <i class="fas fa-plus-circle"></i> Add Your First Item
                    </a>
                <% } else { %>
                    <a href="/users/login" class="btn" style="background: linear-gradient(135deg, #f97316, #ea580c); color: white; padding: 12px 28px; border-radius: 40px; text-decoration: none; display: inline-block; margin-top: 16px;">
                        Login to Add Items
                    </a>
                <% } %>
            </div>
        `;
        return;
    }
    
    let html = '<div class="food-grid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 24px;">';
    
    items.forEach(item => {
        const priceText = item.price > 0 ? '₹' + item.price : 'Price Varies';
        const ratingHtml = item.averageRating > 0 
            ? `<i class="fas fa-star"></i> ${item.averageRating.toFixed(1)}` 
            : '<i class="far fa-star"></i> No ratings';
        
        html += `
            <a href="/nightmess/item/${item._id}" class="food-card" style="background: white; border-radius: 20px; overflow: hidden; transition: all 0.3s ease; border: 1px solid #e5e7eb; cursor: pointer; text-decoration: none; display: block;">
                <div class="food-image" style="position: relative; height: 200px; overflow: hidden;">
                    <img src="${escapeHtml(item.images[0])}" alt="${escapeHtml(item.title)}" style="width: 100%; height: 100%; object-fit: cover; transition: transform 0.3s ease;">
                    <div class="food-badge" style="position: absolute; top: 12px; left: 12px; background: rgba(0,0,0,0.7); backdrop-filter: blur(8px); padding: 4px 10px; border-radius: 20px; font-size: 11px; color: white;">
                        <i class="fas fa-tag"></i> ${escapeHtml(item.category)}
                    </div>
                    <div class="food-block-badge" style="position: absolute; bottom: 12px; right: 12px; background: linear-gradient(135deg, #f97316, #ea580c); padding: 4px 10px; border-radius: 20px; font-size: 12px; font-weight: 600; color: white;">
                        Block ${escapeHtml(item.hostelBlock)}
                    </div>
                </div>
                <div class="food-info" style="padding: 16px;">
                    <div class="food-title" style="font-size: 16px; font-weight: 700; margin-bottom: 6px; color: #1f2937;">${escapeHtml(item.title)}</div>
                    <div class="food-price" style="font-size: 18px; font-weight: 700; color: #f97316; margin-bottom: 8px;">${escapeHtml(priceText)}</div>
                    <div class="food-meta" style="display: flex; justify-content: space-between; align-items: center;">
                        <span class="food-vendor" style="font-size: 12px; color: #6b7280; display: flex; align-items: center; gap: 4px;">
                            <i class="fas fa-user-circle"></i> ${escapeHtml(item.vendor?.username || 'Unknown')}
                        </span>
                        <span class="food-rating" style="display: flex; align-items: center; gap: 4px; font-size: 12px; color: #f59e0b;">
                            ${ratingHtml}
                        </span>
                    </div>
                </div>
            </a>
        `;
    });
    
    html += '</div>';
    container.innerHTML = html;
}

function escapeHtml(text) {
    if (!text) return '';
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
}

function filterNightMessByBlock(block) {
    currentBlockFilter = block;
    loadNightMessItems();
    
    // Update active button styles
    document.querySelectorAll('#nightmessTab .block-btn').forEach(btn => {
        if (btn.innerText === block || (block === '' && btn.innerText === 'All')) {
            btn.style.background = 'linear-gradient(135deg, #f97316, #ea580c)';
            btn.style.color = 'white';
            btn.style.borderColor = 'transparent';
        } else {
            btn.style.background = 'var(--gray-100)';
            btn.style.color = 'var(--gray-600)';
            btn.style.borderColor = 'var(--gray-200)';
        }
    });
}

function switchTab(tabName) {
    // Update active button styles
    const tabs = document.querySelectorAll('.tab-btn');
    tabs.forEach(tab => tab.classList.remove('active'));
    
    // Update content visibility
    const contents = document.querySelectorAll('.tab-content');
    contents.forEach(content => content.classList.remove('active'));
    
    if (tabName === 'products') {
        document.getElementById('productsTab').classList.add('active');
        document.querySelector('.tab-buttons button:first-child').classList.add('active');
    } else if (tabName === 'nightmess') {
        document.getElementById('nightmessTab').classList.add('active');
        document.querySelector('.tab-buttons button:last-child').classList.add('active');
        // Load night mess items when tab is clicked
        loadNightMessItems();
    }
}

function toggleWishlist(element, productId) {
    const icon = element.querySelector('i');
    if (icon.classList.contains('far')) {
        icon.classList.remove('far');
        icon.classList.add('fas');
        icon.style.color = '#ef4444';
        console.log('Added to wishlist:', productId);
    } else {
        icon.classList.remove('fas');
        icon.classList.add('far');
        icon.style.color = '';
        console.log('Removed from wishlist:', productId);
    }
}

function performSearch() {
    const searchQuery = document.getElementById('bannerSearchInput').value;
    if (searchQuery.trim()) {
        window.location.href = `/marketplace?search=${encodeURIComponent(searchQuery)}`;
    } else {
        window.location.href = '/marketplace';
    }
}

// Handle night mess search
document.addEventListener('DOMContentLoaded', function() {
    // Load night mess items on page load if nightmess tab is active
    if (document.getElementById('nightmessTab') && document.getElementById('nightmessTab').classList.contains('active')) {
        loadNightMessItems();
    }
    
    const searchInput = document.getElementById('nightmessSearchInput');
    const searchBtn = document.querySelector('#nightmessTab .btn[type="submit"]');
    
    if (searchBtn) {
        searchBtn.addEventListener('click', function(e) {
            e.preventDefault();
            currentSearchQuery = searchInput ? searchInput.value : '';
            loadNightMessItems();
        });
    }
    
    if (searchInput) {
        searchInput.addEventListener('keypress', function(e) {
            if (e.key === 'Enter') {
                e.preventDefault();
                currentSearchQuery = searchInput.value;
                loadNightMessItems();
            }
        });
    }
    
    document.getElementById('bannerSearchInput')?.addEventListener('keypress', function(e) {
        if (e.key === 'Enter') {
            performSearch();
        }
    });
});


</script>