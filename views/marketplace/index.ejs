    background: linear-gradient(135deg, var(--primary), var(--accent));
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 24px;
}

.empty-icon i {
    font-size: 48px;
    color: white;
}

.empty-title {
    font-size: 28px;
    font-weight: 700;
    margin-bottom: 12px;
    color: var(--gray-800);
}

.empty-text {
