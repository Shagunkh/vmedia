<%- include('../partials/header') %>

<style>
@import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap');

/* ========== TOKENS ========== */
:root {
    --primary:       #008cff;
    --primary-dark:  #0070d6;
    --primary-light: #00d8ff;
    --accent:        #f97316;
    --accent-dark:   #ea580c;
    --success:       #10b981;
    --warning:       #f59e0b;
    --danger:        #ef4444;
    --dark:          #0f172a;
    --gray-50:       #f9fafb;
    --gray-100:      #f3f4f6;
    --gray-200:      #e5e7eb;
    --gray-300:      #d1d5db;
    --gray-600:      #4b5563;
    --gray-700:      #374151;
    --gray-800:      #1f2937;
    --card-shadow:   0 4px 24px rgba(0,140,255,0.07);
    --card-shadow-h: 0 20px 56px rgba(0,140,255,0.18);
}

*, *::before, *::after { box-sizing: border-box; }
body { font-family: 'Inter', sans-serif; background: #f0f8ff; }

/* ========== PAGE ========== */
.products-page {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 20px 80px;
}

/* ========== HERO HEADER ========== */
.page-header {
    background: linear-gradient(135deg, #00d8ff 0%, #008cff 60%, #0070d6 100%);
    border-radius: 0 0 32px 32px;
    padding: 40px 48px 44px;
    margin-bottom: 40px;
    margin-left: -20px;
    margin-right: -20px;
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    flex-wrap: wrap;
    gap: 28px;
    position: relative;
    overflow: hidden;
}

.page-header::before {
    content: '';
    position: absolute;
    top: -80px; right: -80px;
    width: 300px; height: 300px;
    background: rgba(255,255,255,0.06);
    border-radius: 50%;
    pointer-events: none;
}

.page-header::after {
    content: '';
    position: absolute;
    bottom: -60px; left: 25%;
    width: 200px; height: 200px;
    background: rgba(255,255,255,0.04);
    border-radius: 50%;
    pointer-events: none;
}

.header-left { z-index: 1; }

.header-left h1 {
    font-size: 34px;
    font-weight: 900;
    color: white;
    margin: 0 0 6px;
    letter-spacing: -0.5px;
}

.header-left p {
    color: rgba(255,255,255,0.72);
    margin: 0;
    font-size: 15px;
}

/* ========== STAT BADGES ========== */
.header-stats {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
    z-index: 1;
    background: transparent;
    padding: 0;
    border-radius: 0;
}

.stat-badge {
    background: rgba(255,255,255,0.13);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255,255,255,0.22);
    border-radius: 16px;
    padding: 14px 20px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    min-width: 88px;
}

.stat-badge i {
    font-size: 15px;
    color: rgba(255,255,255,0.8);
    margin-bottom: 2px;
}

.stat-badge span:first-of-type {
    font-size: 10px;
    font-weight: 700;
    color: rgba(255,255,255,0.65);
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

.stat-badge span:last-of-type {
    font-size: 22px;
    font-weight: 900;
    color: white;
    line-height: 1;
}

/* ========== BACK BUTTON ========== */
.back-nav {
    margin-bottom: 20px;
    display: flex;
    align-items: center;
}

.btn-back-market {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 16px;
    background: rgba(255, 255, 255, 0.15);
    backdrop-filter: blur(8px);
    border: 1px solid rgba(255, 255, 255, 0.3);
    border-radius: 50px;
    color: white;
    text-decoration: none;
    font-size: 13px;
    font-weight: 600;
    transition: all 0.3s ease;
}

.btn-back-market:hover {
    background: rgba(255, 255, 255, 0.25);
    color: white;
    transform: translateX(-4px);
    box-shadow: 0 4px 15px rgba(0,0,0,0.1);
}

/* ========== HEADER ACTION BUTTONS ========== */
.track-purchase-btn {
    background: rgba(255,255,255,0.15);
    backdrop-filter: blur(8px);
    border: 1.5px solid rgba(255,255,255,0.35);
    color: white;
    padding: 11px 22px;
    border-radius: 40px;
    font-weight: 700;
    font-size: 14px;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    transition: all 0.22s;
    cursor: pointer;
}

.track-purchase-btn:hover {
    background: rgba(255,255,255,0.28);
    transform: translateY(-2px);
    box-shadow: 0 8px 20px rgba(0,0,0,0.15);
}

.add-product-btn {
    background: white;
    color: #008cff;
    padding: 11px 22px;
    border-radius: 40px;
    text-decoration: none;
    font-weight: 700;
    font-size: 14px;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    transition: all 0.22s;
    box-shadow: 0 4px 16px rgba(0,0,0,0.12);
}

.add-product-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 28px rgba(0,0,0,0.18);
    color: #0070d6;
}

.add-nightmess-btn {
    background: linear-gradient(135deg, #f97316, #ea580c);
    color: white;
    padding: 11px 22px;
    border-radius: 40px;
    text-decoration: none;
    font-weight: 700;
    font-size: 14px;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    transition: all 0.22s;
    box-shadow: 0 4px 16px rgba(249,115,22,0.3);
}

.add-nightmess-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 28px rgba(249,115,22,0.4);
    color: white;
}

/* ========== EARNINGS MODAL ========== */
.earnings-modal {
    position: fixed;
    inset: 0;
    background: rgba(15,23,42,0.6);
    backdrop-filter: blur(8px);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2000;
    animation: fadeIn 0.25s ease;
}

.earnings-modal-content {
    background: white;
    border-radius: 28px;
    max-width: 500px;
    width: 90%;
    overflow: hidden;
    animation: slideUp 0.3s cubic-bezier(0.34,1.56,0.64,1);
    box-shadow: 0 32px 80px rgba(0,0,0,0.22);
}

.earnings-modal-header {
    background: linear-gradient(135deg, #10b981, #059669);
    padding: 28px 32px;
    text-align: center;
}

.earnings-modal-header h2 {
    color: white;
    margin: 0;
    font-size: 22px;
    font-weight: 800;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
}

.earnings-modal-body { padding: 32px; }

.earnings-total {
    text-align: center;
    margin-bottom: 28px;
    padding-bottom: 24px;
    border-bottom: 1px solid var(--gray-200);
}

.earnings-amount {
    font-size: 52px;
    font-weight: 900;
    color: #10b981;
    margin-bottom: 4px;
    letter-spacing: -2px;
}

.earnings-label { font-size: 13px; color: var(--gray-600); font-weight: 500; }

.earnings-breakdown { margin-bottom: 20px; }

.breakdown-item {
    display: flex;
    justify-content: space-between;
    padding: 11px 0;
    border-bottom: 1px solid var(--gray-100);
}

.breakdown-label { font-weight: 500; color: var(--gray-700); font-size: 14px; }
.breakdown-value { font-weight: 700; color: var(--gray-800); font-size: 14px; }

.earnings-note {
    background: #fef3c7;
    border-radius: 12px;
    padding: 12px 16px;
    font-size: 12px;
    color: #92400e;
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 20px;
    border-left: 3px solid #f59e0b;
}

.close-modal-btn {
    width: 100%;
    background: var(--gray-100);
    border: none;
    padding: 13px;
    border-radius: 40px;
    font-weight: 700;
    font-size: 14px;
    cursor: pointer;
    transition: all 0.2s;
    color: var(--gray-700);
}

.close-modal-btn:hover { background: var(--gray-200); }

/* ========== TABS ========== */
.tab-container {
    margin-bottom: 32px;
    border-bottom: 2px solid var(--gray-200);
}

.tab-buttons { display: flex; gap: 4px; flex-wrap: wrap; }

.tab-btn {
    padding: 13px 30px;
    font-size: 15px;
    font-weight: 700;
    background: transparent;
    border: none;
    color: var(--gray-600);
    cursor: pointer;
    transition: all 0.25s;
    border-radius: 12px 12px 0 0;
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 8px;
}

.tab-btn:hover { color: #008cff; background: rgba(0,140,255,0.06); }
.tab-btn.active { color: #008cff; background: rgba(0,140,255,0.07); }

.tab-btn.active::after {
    content: '';
    position: absolute;
    bottom: -2px; left: 0; right: 0;
    height: 2.5px;
    background: linear-gradient(90deg, #00d8ff, #008cff);
    border-radius: 2px 2px 0 0;
}

.tab-content { display: none; animation: fadeIn 0.3s ease; }
.tab-content.active { display: block; }

/* ========== EMPTY STATE ========== */
.empty-state {
    text-align: center;
    padding: 80px 40px;
    background: white;
    border-radius: 28px;
    border: 1px solid var(--gray-200);
    box-shadow: var(--card-shadow);
}

.empty-icon {
    width: 100px; height: 100px;
    background: linear-gradient(135deg, #00d8ff, #008cff);
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 24px;
    box-shadow: 0 16px 40px rgba(0,140,255,0.28);
}

.empty-icon i { font-size: 44px; color: white; }
.empty-title { font-size: 22px; font-weight: 800; margin-bottom: 10px; color: var(--gray-800); }
.empty-text  { color: var(--gray-600); margin-bottom: 28px; font-size: 15px; }

.empty-btn {
    background: linear-gradient(135deg, #00d8ff, #008cff);
    color: white;
    padding: 13px 32px;
    border-radius: 40px;
    text-decoration: none;
    font-weight: 700;
    font-size: 15px;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    transition: all 0.25s;
    box-shadow: 0 8px 24px rgba(0,140,255,0.3);
}

.empty-btn:hover {
    transform: translateY(-3px);
    box-shadow: 0 14px 36px rgba(0,140,255,0.4);
    color: white;
}

/* ========== PRODUCT GRID ========== */
.products-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 24px;
}

/* ========== PRODUCT CARD ========== */
.product-card-modern {
    background: white;
    border-radius: 22px;
    overflow: hidden;
    transition: all 0.38s cubic-bezier(0.4,0,0.2,1);
    border: 1px solid var(--gray-200);
    position: relative;
    animation: fadeInUp 0.5s ease-out both;
    box-shadow: var(--card-shadow);
}

.product-card-modern:hover {
    transform: translateY(-10px);
    box-shadow: 0 20px 56px rgba(0,140,255,0.18);
    border-color: #00d8ff;
}

.card-image {
    position: relative;
    height: 220px;
    overflow: hidden;
    background: var(--gray-100);
}

.card-image img {
    width: 100%; height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
}

.product-card-modern:hover .card-image img { transform: scale(1.07); }

/* ─── Overlay badges ─── */
.status-badge {
    position: absolute;
    top: 14px; right: 14px;
    padding: 5px 13px;
    border-radius: 100px;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.4px;
    text-transform: uppercase;
    backdrop-filter: blur(8px);
    z-index: 2;
    display: inline-flex;
    align-items: center;
    gap: 5px;
}

.status-available { background: rgba(16,185,129,0.92); color: white; }
.status-sold      { background: rgba(239,68,68,0.92);  color: white; }
.status-reserved  { background: rgba(245,158,11,0.92); color: white; }
.status-hidden    { background: rgba(107,114,128,0.9); color: white; }

/* Visibility toggle pill */
.visibility-toggle {
    position: absolute;
    top: 14px; left: 14px;
    z-index: 2;
    background: rgba(0,0,0,0.55);
    backdrop-filter: blur(6px);
    border-radius: 30px;
    padding: 5px 12px;
    display: flex;
    align-items: center;
    gap: 8px;
}

.toggle-switch {
    position: relative;
    display: inline-block;
    width: 36px; height: 18px;
    flex-shrink: 0;
}

.toggle-switch input { opacity:0; width:0; height:0; }

.toggle-slider {
    position: absolute;
    cursor: pointer;
    inset: 0;
    background: #6b7280;
    border-radius: 18px;
    transition: 0.3s;
}

.toggle-slider:before {
    content: '';
    position: absolute;
    width: 12px; height: 12px;
    left: 3px; bottom: 3px;
    background: white;
    border-radius: 50%;
    transition: 0.3s;
}

input:checked + .toggle-slider { background: #10b981; }
input:checked + .toggle-slider:before { transform: translateX(18px); }

.toggle-label { font-size: 10px; color: white; font-weight: 700; }

/* Category badge */
.category-badge {
    position: absolute;
    bottom: 14px; left: 14px;
    background: rgba(0,0,0,0.65);
    backdrop-filter: blur(8px);
    padding: 4px 12px;
    border-radius: 100px;
    font-size: 11px;
    font-weight: 600;
    color: white;
    z-index: 2;
    display: inline-flex;
    align-items: center;
    gap: 5px;
}

/* Night mess badge */
.nightmess-badge {
    background: linear-gradient(135deg, #f97316, #ea580c);
    position: absolute;
    top: 16px; left: 80px;
    padding: 4px 10px;
    border-radius: 20px;
    font-size: 10px;
    font-weight: 700;
    color: white;
    z-index: 2;
}

/* ─── Card body ─── */
.card-content { padding: 20px 22px 18px; }

.product-title {
    font-size: 17px;
    font-weight: 800;
    color: var(--gray-800);
    margin-bottom: 6px;
    line-height: 1.35;
}

.product-description {
    font-size: 13px;
    color: var(--gray-600);
    margin-bottom: 14px;
    line-height: 1.55;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
}

.menu-preview {
    font-size: 13px; color: #6b7280; margin-bottom: 12px;
    display: flex; align-items: center; gap: 6px; flex-wrap: wrap;
}

.menu-preview-item {
    background: #fff3e8; color: #ea580c; border: 1px solid #fed7aa;
    padding: 2px 9px; border-radius: 100px; font-size: 11px; font-weight: 600;
}

.menu-count {
    font-size: 12px; color: #f97316; font-weight: 600; margin-bottom: 8px;
    display: flex; align-items: center; gap: 5px;
}

.price-section {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 14px;
    padding-bottom: 14px;
    border-bottom: 1px solid var(--gray-200);
}

.product-price {
    font-size: 26px; font-weight: 900; color: var(--primary); letter-spacing: -0.5px;
}

.condition-tag {
    font-size: 11px; padding: 4px 11px; border-radius: 100px; font-weight: 700;
}

.condition-new      { background: #d1fae5; color: #065f46; }
.condition-like-new { background: #d9f99d; color: #3f6212; }
.condition-good     { background: #fed7aa; color: #92400e; }
.condition-fair     { background: #fef3c7; color: #78350f; }

.product-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 18px;
    flex-wrap: wrap;
    gap: 6px;
}

.meta-item {
    display: flex; align-items: center; gap: 5px;
    font-size: 11px; color: var(--gray-600); font-weight: 500;
}

.meta-item i { font-size: 10px; color: var(--primary); }

.action-buttons { display: flex; gap: 8px; }

.btn-action {
    flex: 1; padding: 10px 6px; border-radius: 11px;
    font-size: 12px; font-weight: 700; text-align: center; text-decoration: none;
    transition: all 0.2s; cursor: pointer; border: none;
    display: inline-flex; align-items: center; justify-content: center; gap: 5px;
}

.btn-action:hover { transform: translateY(-2px); }
.btn-view    { background: var(--gray-100); color: var(--gray-700); }
.btn-view:hover  { background: var(--gray-200); }
.btn-edit    { background: #fef3c7; color: #92400e; }
.btn-edit:hover  { background: #fde68a; }
.btn-delete  { background: #fee2e2; color: #991b1b; }
.btn-delete:hover { background: #fecaca; }

/* ========== TOAST ========== */
.delete-toast {
    position: fixed;
    bottom: 30px; right: 30px;
    background: white;
    border-radius: 16px;
    padding: 16px 24px;
    box-shadow: 0 20px 48px rgba(0,0,0,0.15);
    display: flex;
    align-items: center;
    gap: 14px;
    z-index: 10000;
    animation: slideInRight 0.3s ease;
    border-left: 4px solid var(--success);
    min-width: 240px;
    font-weight: 600;
    font-size: 14px;
    color: var(--gray-800);
}

/* ========== ANIMATIONS ========== */
@keyframes fadeInUp {
    from { opacity:0; transform:translateY(28px); }
    to   { opacity:1; transform:translateY(0); }
}

@keyframes fadeIn {
    from { opacity:0; }
    to   { opacity:1; }
}

@keyframes slideInRight {
    from { opacity:0; transform:translateX(80px); }
    to   { opacity:1; transform:translateX(0); }
}

@keyframes slideOutRight {
    from { opacity:1; transform:translateX(0); }
    to   { opacity:0; transform:translateX(80px); }
}

@keyframes slideUp {
    from { opacity:0; transform:translateY(40px) scale(0.97); }
    to   { opacity:1; transform:translateY(0) scale(1); }
}

/* ====== NIGHT MESS STALL CARDS (matching /nightmess/my-items) ====== */
.stall-card {
    background: white;
    border-radius: 22px;
    overflow: hidden;
    border: 1px solid var(--gray-200);
    transition: all 0.35s cubic-bezier(0.4,0,0.2,1);
    animation: fadeInUp 0.4s ease both;
    position: relative;
}

.stall-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 20px 50px rgba(249,115,22,0.18);
    border-color: #f97316;
}

.stall-image {
    height: 220px;
    overflow: hidden;
    position: relative;
    background: var(--gray-100);
}

.stall-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
}

.stall-card:hover .stall-image img {
    transform: scale(1.07);
}

.stall-overlay { position: absolute; inset: 0; pointer-events: none; }

.badge-topleft {
    position: absolute;
    top: 14px; left: 14px;
    display: flex; align-items: center; gap: 8px;
    pointer-events: all;
}

.badge-topright { position: absolute; top: 14px; right: 14px; }
.badge-bottomleft { position: absolute; bottom: 14px; left: 14px; }

.vis-pill {
    background: rgba(0,0,0,0.6);
    backdrop-filter: blur(6px);
    border-radius: 30px;
    padding: 6px 12px;
    display: flex; align-items: center; gap: 8px;
}

.status-pill {
    padding: 5px 12px;
    border-radius: 100px;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    display: inline-flex; align-items: center; gap: 5px;
    backdrop-filter: blur(8px);
}

.status-pill.nm-open   { background: rgba(16,185,129,0.9); color: white; }
.status-pill.nm-closed { background: rgba(239,68,68,0.9);  color: white; }
.status-pill.nm-hidden { background: rgba(107,114,128,0.85); color: white; }

.hostel-pill {
    background: rgba(0,0,0,0.65);
    backdrop-filter: blur(6px);
    color: white;
    padding: 4px 12px;
    border-radius: 100px;
    font-size: 10px;
    font-weight: 600;
    display: inline-flex; align-items: center; gap: 5px;
}

.hostel-pill.men   { border-left: 3px solid #38bdf8; }
.hostel-pill.women { border-left: 3px solid #f472b6; }

.stall-body { padding: 22px 22px 18px; }

.stall-name {
    font-size: 18px;
    font-weight: 800;
    color: var(--gray-800);
    margin-bottom: 4px;
    display: flex; align-items: center; gap: 8px;
}

.stall-name a { color: inherit; text-decoration: none; }
.stall-name a:hover { color: #f97316; }

.stall-location {
    font-size: 12px;
    color: var(--gray-600);
    margin-bottom: 12px;
    display: flex; align-items: center; gap: 6px;
}

.stall-location i { color: #f97316; }

.menu-chips {
    display: flex; flex-wrap: wrap; gap: 6px;
    margin-bottom: 14px;
}

.menu-chip {
    background: #fff3e8;
    color: #ea580c;
    border: 1px solid #fed7aa;
    padding: 3px 10px;
    border-radius: 100px;
    font-size: 11px;
    font-weight: 600;
}

.menu-chip.more {
    background: var(--gray-100);
    color: var(--gray-600);
    border-color: var(--gray-200);
}

.stall-tags {
    display: flex; gap: 8px; flex-wrap: wrap;
    margin-bottom: 16px;
}

.tag { padding: 4px 12px; border-radius: 100px; font-size: 11px; font-weight: 600; }
.tag-cat   { background: #eff6ff; color: #1d4ed8; }
.tag-block { background: #f5f3ff; color: #6d28d9; }

.stall-divider { border: none; border-top: 1px solid var(--gray-200); margin: 14px 0; }

.stall-actions { display: flex; gap: 8px; }

.btn-act {
    flex: 1;
    padding: 9px 6px;
    border-radius: 10px;
    font-size: 12px;
    font-weight: 600;
    text-align: center;
    text-decoration: none;
    cursor: pointer;
    border: none;
    display: inline-flex; align-items: center; justify-content: center; gap: 5px;
    transition: all 0.2s;
}

.btn-act:hover { transform: translateY(-2px); }
.btn-view-act  { background: var(--gray-100); color: var(--gray-700); }
.btn-view-act:hover { background: var(--gray-200); color: var(--gray-700); }
.btn-edit-act  { background: #fef3c7; color: #92400e; }
.btn-edit-act:hover { background: #fde68a; color: #78350f; }
.btn-del-act   { background: #fee2e2; color: #991b1b; }
.btn-del-act:hover { background: #fecaca; color: #7f1d1d; }

/* Responsive */
@media (max-width: 768px) {
    .products-page { padding: 0 12px 60px; }
    .page-header { 
        padding: 24px 20px 28px; 
        border-radius: 0 0 24px 24px; 
        flex-direction: column; 
        align-items: stretch; 
        gap: 20px; 
    }
    .header-left h1 { font-size: 26px; text-align: center; }
    .header-left p { text-align: center; font-size: 13px; }
    .header-stats { justify-content: center; gap: 8px; }
    .stat-badge { padding: 10px 8px; min-width: 0; flex: 1; }
    .stat-badge span:first-of-type { font-size: 9px; letter-spacing: 0; }
    .stat-badge span:last-of-type { font-size: 18px; }
    .page-header > div:last-child { flex-direction: column; }
    .track-purchase-btn, .add-product-btn, .add-nightmess-btn {
        width: 100%;
        justify-content: center;
        padding: 13px;
        font-size: 15px;
    }
    .products-grid { grid-template-columns: 1fr; gap: 18px; }
    .tab-buttons { display: flex; flex-wrap: nowrap; overflow-x: auto; padding-bottom: 4px; gap: 4px; }
    .tab-btn { padding: 12px 18px; font-size: 14px; white-space: nowrap; flex: 1; justify-content: center; border-radius: 12px; }
    .action-buttons { flex-wrap: wrap; }
    .btn-action { flex: auto; min-width: calc(33.33% - 7px); }
    .card-image { height: 180px; }
}
</style>

<div class="products-page">
    <!-- Header -->
    <div class="page-header">
        <div class="back-nav">
            <a href="/marketplace" class="btn-back-market">
                <i class="fas fa-arrow-left"></i> Back to Marketplace
            </a>
        </div>
        <div class="header-left">
            <h1>My Items</h1>
            <p>Manage your marketplace products and night mess food items</p>
        </div>
        
        <div class="header-stats">
            <div class="stat-badge">
                <i class="fas fa-box"></i>
                <span>Products:</span>
                <span><%= products.length %></span>
            </div>
            <div class="stat-badge">
                <i class="fas fa-utensils"></i>
                <span>Food Items:</span>
                <span><%= nightmessItems.length %></span>
            </div>
            <div class="stat-badge">
                <i class="fas fa-eye-slash"></i>
                <span>Hidden:</span>
                <span><%= hiddenCount %></span>
            </div>
            <div class="stat-badge">
                <i class="fas fa-rupee-sign"></i>
                <span>Total Sales:</span>
                <span>₹<%= totalEarnings %></span>
            </div>
        </div>
        
        <div style="display: flex; gap: 12px; flex-wrap: wrap;">
            <button class="track-purchase-btn" onclick="showEarningsModal()">
                <i class="fas fa-chart-line"></i> Track Purchase
            </button>
            <a href="/marketplace/add-product" class="add-product-btn">
                <i class="fas fa-plus-circle"></i> Add Product
            </a>
            <a href="/nightmess/add-item" class="add-nightmess-btn">
                <i class="fas fa-plus-circle"></i> Add Food Stall
            </a>
        </div>
    </div>
    
    <!-- Earnings Modal -->
    <div id="earningsModal" class="earnings-modal" style="display: none;">
        <div class="earnings-modal-content">
            <div class="earnings-modal-header">
                <h2><i class="fas fa-chart-line"></i> Sales Tracker</h2>
            </div>
            <div class="earnings-modal-body">
                <div class="earnings-total">
                    <div class="earnings-amount">₹<%= totalEarnings %></div>
                    <div class="earnings-label">Total Earnings</div>
                </div>
                
                <div class="earnings-breakdown">
                    <div class="breakdown-item">
                        <span class="breakdown-label">Products Sold:</span>
                        <span class="breakdown-value"><%= soldProductsCount %> items</span>
                    </div>
                    <div class="breakdown-item">
                        <span class="breakdown-label">Food Items Sold:</span>
                        <span class="breakdown-value"><%= soldFoodItemsCount %> items</span>
                    </div>
                    <div class="breakdown-item">
                        <span class="breakdown-label">Total Items Sold:</span>
                        <span class="breakdown-value"><%= soldProductsCount + soldFoodItemsCount %> items</span>
                    </div>
                    <div class="breakdown-item">
                        <span class="breakdown-label">Average Order Value:</span>
                        <span class="breakdown-value">₹<%= avgOrderValue %></span>
                    </div>
                </div>
                
                <div class="earnings-note">
                    <i class="fas fa-info-circle"></i>
                    <span>This includes all completed sales from your products and food items.</span>
                </div>
                
                <button class="close-modal-btn" onclick="closeEarningsModal()">Close</button>
            </div>
        </div>
    </div>
    
    <!-- Tabs -->
    <div class="tab-container">
        <div class="tab-buttons">
            <button class="tab-btn active" onclick="switchTab('products')">
                <i class="fas fa-box"></i> Products
            </button>
            <button class="tab-btn" onclick="switchTab('nightmess')">
                <i class="fas fa-utensils"></i> Night Mess Food
            </button>
        </div>
    </div>
    
    <!-- Products Tab -->
    <div id="productsTab" class="tab-content active">
        <% if (products.length === 0) { %>
            <div class="empty-state">
                <div class="empty-icon">
                    <i class="fas fa-store"></i>
                </div>
                <h3 class="empty-title">No products listed yet</h3>
                <p class="empty-text">Start selling your items and reach thousands of students on campus!</p>
                <a href="/marketplace/add-product" class="empty-btn">
                    <i class="fas fa-plus-circle"></i> Sell Your First Product
                </a>
            </div>
        <% } else { %>
            <div class="products-grid">
                <% products.forEach(product => { 
                    const statusClass = product.status === 'available' ? 'status-available' : 
                                       (product.status === 'sold' ? 'status-sold' : 'status-reserved');
                    const conditionClass = product.condition === 'New' ? 'condition-new' :
                                          (product.condition === 'Like New' ? 'condition-like-new' :
                                          (product.condition === 'Good' ? 'condition-good' : 'condition-fair'));
                %>
                    <div class="product-card-modern" data-product-id="<%= product._id %>" data-type="product">
                        <div class="card-image">
                            <img src="<%= (product.images && product.images.length > 0) ? (product.images[0].url || product.images[0]) : '/images/placeholder.png' %>" alt="<%= product.title %>">
                            <div class="visibility-toggle">
                                <label class="toggle-switch">
                                    <input type="checkbox" class="visibility-checkbox" 
                                           data-id="<%= product._id %>" 
                                           data-type="product"
                                           <%= product.status !== 'hidden' ? 'checked' : '' %>
                                           onchange="toggleVisibility('<%= product._id %>', 'product', this.checked)">
                                    <span class="toggle-slider"></span>
                                </label>
                                <span class="toggle-label">Visible</span>
                            </div>
                            <div class="status-badge <%= product.status === 'available' ? 'status-available' : (product.status === 'sold' ? 'status-sold' : (product.status === 'hidden' ? 'status-hidden' : 'status-reserved')) %>">
                                <i class="fas <%= product.status === 'available' ? 'fa-check-circle' : (product.status === 'sold' ? 'fa-shopping-cart' : (product.status === 'hidden' ? 'fa-eye-slash' : 'fa-clock')) %>"></i>
                                <%= product.status === 'hidden' ? 'HIDDEN' : product.status.toUpperCase() %>
                            </div>
                            <div class="category-badge">
                                <i class="fas fa-tag"></i> <%= product.category %>
                            </div>
                        </div>
                        
                        <div class="card-content">
                            <h3 class="product-title"><%= product.title %></h3>
                            <p class="product-description"><%= product.description ? product.description.substring(0, 80) : '' %><%= product.description && product.description.length > 80 ? '...' : '' %></p>
                            
                            <div class="price-section">
                                <span class="product-price">₹<%= product.price %></span>
                                <span class="condition-tag <%= conditionClass %>"><%= product.condition %></span>
                            </div>
                            
                            <div class="product-meta">
                                <div class="meta-item">
                                    <i class="fas fa-calendar-alt"></i>
                                    <span>Listed: <%= new Date(product.createdAt).toLocaleDateString() %></span>
                                </div>
                                <div class="meta-item">
                                    <i class="fas fa-eye"></i>
                                    <span><%= product.views %> views</span>
                                </div>
                                <div class="meta-item">
                                    <i class="fas fa-heart"></i>
                                    <span><%= product.interestedBuyers ? product.interestedBuyers.length : 0 %> interested</span>
                                </div>
                            </div>
                            
                            <div class="action-buttons">
                                <a href="/marketplace/product/<%= product._id %>" class="btn-action btn-view">
                                    <i class="fas fa-eye"></i> View
                                </a>
                                <a href="/marketplace/edit-product/<%= product._id %>" class="btn-action btn-edit">
                                    <i class="fas fa-edit"></i> Edit
                                </a>
                                <button onclick="deleteItem('<%= product._id %>', 'product', '<%= product.title %>')" class="btn-action btn-delete">
                                    <i class="fas fa-trash-alt"></i> Delete
                                </button>
                            </div>
                        </div>
                    </div>
                <% }) %>
            </div>
        <% } %>
    </div>
    
    <!-- Night Mess Tab -->
    <div id="nightmessTab" class="tab-content">
        <% if (nightmessItems.length === 0) { %>
            <div class="empty-state">
                <div class="empty-icon">
                    <i class="fas fa-utensils"></i>
                </div>
                <h3 class="empty-title">No food stalls added yet</h3>
                <p class="empty-text">Start selling your delicious food items to hungry students!</p>
                <a href="/nightmess/add-item" class="add-nightmess-btn" style="margin-top:8px;">
                    <i class="fas fa-plus-circle"></i> Add Your First Food Stall
                </a>
            </div>
        <% } else { %>
            <div class="products-grid">
                <% nightmessItems.forEach((item, idx) => {
                    const menuCount = item.menuItems ? item.menuItems.length : 0;
                    const previewItems = item.menuItems ? item.menuItems.slice(0, 3) : [];
                    const safeVendorName = (item.vendorName || "Food Stall").replace(/'/g, "\\'");
                %>
                    <div class="stall-card" data-item-id="<%= item._id %>" data-type="nightmess" style="animation-delay: <%= idx * 0.06 %>s">

                        <!-- Image with overlay badges -->
                        <div class="stall-image">
                            <img src="<%= item.images && item.images.length > 0 ? item.images[0] : '/images/placeholder.png' %>" alt="<%= item.vendorName %>">

                            <div class="stall-overlay">
                                <!-- Visibility Toggle -->
                                <div class="badge-topleft">
                                    <div class="vis-pill">
                                        <label class="toggle-switch">
                                            <input type="checkbox" class="visibility-checkbox"
                                                   data-id="<%= item._id %>"
                                                   data-type="nightmess"
                                                   <%= item.status !== 'hidden' ? 'checked' : '' %>
                                                   onchange="toggleVisibility('<%= item._id %>', 'nightmess', this.checked)">
                                            <span class="toggle-slider"></span>
                                        </label>
                                        <span class="toggle-label">Visible</span>
                                    </div>
                                </div>

                                <!-- Status Badge -->
                                <div class="badge-topright">
                                    <% if (item.status === 'available') { %>
                                        <span class="status-pill nm-open"><i class="fas fa-circle" style="font-size:7px;"></i> Open</span>
                                    <% } else if (item.status === 'sold_out') { %>
                                        <span class="status-pill nm-closed"><i class="fas fa-times-circle"></i> Closed</span>
                                    <% } else { %>
                                        <span class="status-pill nm-hidden"><i class="fas fa-eye-slash"></i> Hidden</span>
                                    <% } %>
                                </div>

                                <!-- Hostel Type + Block -->
                                <div class="badge-bottomleft">
                                    <span class="hostel-pill <%= item.hostelType %>">
                                        <% if (item.hostelType === 'men') { %>
                                            <i class="fas fa-mars"></i> Men's
                                        <% } else { %>
                                            <i class="fas fa-venus"></i> Women's
                                        <% } %>
                                        · Block <%= item.hostelBlock %>
                                    </span>
                                </div>
                            </div>
                        </div>

                        <!-- Card Body -->
                        <div class="stall-body">
                            <div class="stall-name">
                                <i class="fas fa-store" style="color:#f97316;font-size:16px;"></i>
                                <a href="/nightmess/item/<%= item._id %>"><%= item.vendorName %></a>
                            </div>

                            <div class="stall-location">
                                <i class="fas fa-utensils"></i>
                                <%= menuCount %> menu item<%= menuCount !== 1 ? 's' : '' %>
                                &nbsp;·&nbsp;
                                <i class="fas fa-eye"></i>
                                <%= item.views || 0 %> views
                                &nbsp;·&nbsp;
                                <i class="fas fa-heart"></i>
                                <%= item.interestedBuyers ? item.interestedBuyers.length : 0 %> interested
                            </div>

                            <% if (previewItems.length > 0) { %>
                                <div class="menu-chips">
                                    <% previewItems.forEach(mi => { %>
                                        <span class="menu-chip"><%= mi.itemName.substring(0,18) %><%= mi.itemName.length > 18 ? '…' : '' %> · ₹<%= mi.price %></span>
                                    <% }) %>
                                    <% if (menuCount > 3) { %>
                                        <span class="menu-chip more">+<%= menuCount - 3 %> more</span>
                                    <% } %>
                                </div>
                            <% } %>

                            <div class="stall-tags">
                                <span class="tag tag-cat"><i class="fas fa-layer-group"></i> <%= item.category %></span>
                                <span class="tag tag-block"><i class="fas fa-building"></i> Block <%= item.hostelBlock %></span>
                                <% if (item.vendorPhone) { %>
                                    <span class="tag" style="background:#f0fdf4;color:#166534;"><i class="fas fa-phone"></i> <%= item.vendorPhone %></span>
                                <% } %>
                            </div>

                            <hr class="stall-divider">

                            <div class="stall-actions">
                                <a href="/nightmess/item/<%= item._id %>" class="btn-act btn-view-act">
                                    <i class="fas fa-eye"></i> View
                                </a>
                                <a href="/nightmess/edit-item/<%= item._id %>" class="btn-act btn-edit-act">
                                    <i class="fas fa-pen"></i> Edit
                                </a>
                                <button onclick="deleteItem('<%= item._id %>', 'nightmess', '<%= safeVendorName %>')" class="btn-act btn-del-act">
                                    <i class="fas fa-trash"></i> Delete
                                </button>
                            </div>
                        </div>
                    </div>
                <% }) %>
            </div>
        <% } %>
    </div>
</div>

<script>
function showEarningsModal() {
    document.getElementById('earningsModal').style.display = 'flex';
    document.body.style.overflow = 'hidden';
}

function closeEarningsModal() {
    document.getElementById('earningsModal').style.display = 'none';
    document.body.style.overflow = 'auto';
}

window.onclick = function(event) {
    const modal = document.getElementById('earningsModal');
    if (event.target === modal) {
        closeEarningsModal();
    }
}

function switchTab(tabName) {
    const tabs = document.querySelectorAll('.tab-btn');
    const contents = document.querySelectorAll('.tab-content');
    
    tabs.forEach(tab => tab.classList.remove('active'));
    contents.forEach(content => content.classList.remove('active'));
    
    if (tabName === 'products') {
        document.getElementById('productsTab').classList.add('active');
        document.querySelector('.tab-buttons button:first-child').classList.add('active');
    } else if (tabName === 'nightmess') {
        document.getElementById('nightmessTab').classList.add('active');
        document.querySelector('.tab-buttons button:last-child').classList.add('active');
    }
}

function toggleVisibility(id, type, isVisible) {
    const status = isVisible ? 'available' : 'hidden';
    let url;
    
    if (type === 'product') {
        url = `/marketplace/product/${id}/visibility`;
    } else {
        url = `/nightmess/item/${id}/visibility`;
    }
    
    fetch(url, {
        method: 'PUT',
        headers: {
            'Content-Type': 'application/json'
        },
        body: JSON.stringify({ status: status })
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            showToast(`Item is now ${isVisible ? 'visible' : 'hidden'}!`, 'success');
            setTimeout(() => window.location.reload(), 1000);
        } else {
            showToast('Failed to update visibility', 'error');
            const checkbox = document.querySelector(`.visibility-checkbox[data-id="${id}"][data-type="${type}"]`);
            if (checkbox) checkbox.checked = !isVisible;
        }
    })
    .catch(err => {
        showToast('Error updating visibility', 'error');
        const checkbox = document.querySelector(`.visibility-checkbox[data-id="${id}"][data-type="${type}"]`);
        if (checkbox) checkbox.checked = !isVisible;
    });
}

function deleteItem(id, type, title) {
    vmConfirm({
        title: 'Delete Item',
        message: `Are you sure you want to delete <strong>"${title}"</strong>? This action cannot be undone.`,
        confirmText: 'Yes, Delete',
        cancelText: 'Keep It',
        variant: 'danger',
        onConfirm() {
            const url = type === 'product' ? '/marketplace/product/' : '/nightmess/item/';
            fetch(`${url}${id}`, {
                method: 'DELETE',
                headers: { 'Content-Type': 'application/json' }
            })
            .then(r => r.json())
            .then(data => {
                showToast('Item deleted successfully!', 'success');
                setTimeout(() => window.location.reload(), 1000);
            })
            .catch(() => showToast('Error deleting item', 'error'));
        }
    });
}

function showToast(message, type) {
    const toast = document.createElement('div');
    toast.className = 'delete-toast';
    
    const icon = type === 'success' ? 'fa-check-circle' : 'fa-exclamation-circle';
    const color = type === 'success' ? '#10b981' : '#ef4444';
    
    toast.innerHTML = `
        <i class="fas ${icon}" style="color: ${color};"></i>
        <span>${message}</span>
    `;
    
    document.body.appendChild(toast);
    
    setTimeout(() => {
        toast.style.animation = 'slideOutRight 0.3s ease forwards';
        setTimeout(() => toast.remove(), 300);
    }, 3000);
}

const style = document.createElement('style');
style.textContent = `
    @keyframes slideOutRight {
        from { opacity: 1; transform: translateX(0); }
        to { opacity: 0; transform: translateX(100px); }
    }
`;
document.head.appendChild(style);
</script>

<%- include('../partials/vall-promo-banner') %>