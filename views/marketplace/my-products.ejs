<%- include('../partials/header') %>

<style>
/* ========== PREMIUM VARIABLES ========== */
:root {
    --primary: #2563eb;
    --primary-dark: #1e40af;
    --primary-light: #3b82f6;
    --secondary: #7c3aed;
    --accent: #f97316;
    --success: #10b981;
    --warning: #f59e0b;
    --danger: #ef4444;
    --dark: #0f172a;
    --gray-50: #f9fafb;
    --gray-100: #f3f4f6;
    --gray-200: #e5e7eb;
    --gray-300: #d1d5db;
    --gray-600: #4b5563;
    --gray-700: #374151;
    --gray-800: #1f2937;
    --shadow-sm: 0 1px 2px 0 rgb(0 0 0 / 0.05);
    --shadow-md: 0 4px 6px -1px rgb(0 0 0 / 0.1);
    --shadow-lg: 0 10px 15px -3px rgb(0 0 0 / 0.1);
    --shadow-xl: 0 20px 25px -5px rgb(0 0 0 / 0.1);
}

/* ========== PAGE CONTAINER ========== */
.products-page {
    max-width: 1400px;
    margin: 0 auto;
    padding: 40px 20px;
}

/* ========== HEADER SECTION ========== */
.page-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 40px;
    flex-wrap: wrap;
    gap: 20px;
}

.header-left h1 {
    font-size: 32px;
    font-weight: 800;
    color: var(--dark);
    margin: 0 0 8px 0;
}

.header-left p {
    color: var(--gray-600);
    margin: 0;
}

.header-stats {
    display: flex;
    gap: 24px;
    background: var(--gray-50);
    padding: 12px 24px;
    border-radius: 60px;
    flex-wrap: wrap;
}

.stat-badge {
    display: flex;
    align-items: center;
    gap: 8px;
}

.stat-badge i {
    color: var(--primary);
}

.stat-badge span:first-child {
    font-weight: 600;
    color: var(--gray-700);
}

.stat-badge span:last-child {
    font-weight: 800;
    color: var(--primary);
}

/* Track Purchase Button */
.track-purchase-btn {
    background: linear-gradient(135deg, #10b981, #059669);
    color: white;
    padding: 12px 28px;
    border-radius: 60px;
    text-decoration: none;
    font-weight: 600;
    display: inline-flex;
    align-items: center;
    gap: 10px;
    transition: all 0.3s ease;
    box-shadow: var(--shadow-md);
    cursor: pointer;
    border: none;
}

.track-purchase-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 25px rgba(16, 185, 129, 0.3);
}

/* Earnings Modal */
.earnings-modal {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(8px);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2000;
    animation: fadeIn 0.3s ease;
}

.earnings-modal-content {
    background: white;
    border-radius: 28px;
    max-width: 500px;
    width: 90%;
    overflow: hidden;
    animation: slideUp 0.3s ease;
}

.earnings-modal-header {
    background: linear-gradient(135deg, #10b981, #059669);
    padding: 24px;
    text-align: center;
}

.earnings-modal-header h2 {
    color: white;
    margin: 0;
    font-size: 24px;
    font-weight: 700;
}

.earnings-modal-body {
    padding: 32px;
}

.earnings-total {
    text-align: center;
    margin-bottom: 32px;
    padding-bottom: 24px;
    border-bottom: 2px solid var(--gray-200);
}

.earnings-amount {
    font-size: 48px;
    font-weight: 800;
    color: #10b981;
    margin-bottom: 8px;
}

.earnings-label {
    font-size: 14px;
    color: var(--gray-600);
}

.earnings-breakdown {
    margin-bottom: 24px;
}

.breakdown-item {
    display: flex;
    justify-content: space-between;
    padding: 12px 0;
    border-bottom: 1px solid var(--gray-100);
}

.breakdown-label {
    font-weight: 500;
    color: var(--gray-700);
}

.breakdown-value {
    font-weight: 600;
    color: var(--gray-800);
}

.earnings-note {
    background: #fef3c7;
    border-radius: 16px;
    padding: 12px 16px;
    font-size: 12px;
    color: #92400e;
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 24px;
}

.close-modal-btn {
    width: 100%;
    background: var(--gray-100);
    border: none;
    padding: 12px;
    border-radius: 40px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
}

.close-modal-btn:hover {
    background: var(--gray-200);
}

.add-product-btn {
    background: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%);
    color: white;
    padding: 12px 28px;
    border-radius: 60px;
    text-decoration: none;
    font-weight: 600;
    display: inline-flex;
    align-items: center;
    gap: 10px;
    transition: all 0.3s ease;
    box-shadow: var(--shadow-md);
}

.add-product-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 25px rgba(37, 99, 235, 0.3);
    color: white;
}

.add-nightmess-btn {
    background: linear-gradient(135deg, #f97316, #ea580c);
    color: white;
    padding: 12px 28px;
    border-radius: 60px;
    text-decoration: none;
    font-weight: 600;
    display: inline-flex;
    align-items: center;
    gap: 10px;
    transition: all 0.3s ease;
    box-shadow: var(--shadow-md);
}

.add-nightmess-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 25px rgba(249,115,22,0.3);
    color: white;
}

/* Tab Styles */
.tab-container {
    margin-bottom: 32px;
    border-bottom: 2px solid var(--gray-200);
}

.tab-buttons {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
}

.tab-btn {
    padding: 12px 28px;
    font-size: 16px;
    font-weight: 600;
    background: transparent;
    border: none;
    color: var(--gray-600);
    cursor: pointer;
    transition: all 0.3s ease;
    border-radius: 40px;
    position: relative;
}

.tab-btn:hover {
    color: var(--primary);
    background: rgba(37, 99, 235, 0.05);
}

.tab-btn.active {
    color: var(--primary);
    background: linear-gradient(135deg, rgba(37, 99, 235, 0.1), rgba(249, 115, 22, 0.05));
}

.tab-btn.active::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--primary), var(--accent));
    border-radius: 2px;
}

.tab-content {
    display: none;
    animation: fadeIn 0.3s ease;
}

.tab-content.active {
    display: block;
}

/* Empty State */
.empty-state {
    text-align: center;
    padding: 80px 40px;
    background: var(--gray-50);
    border-radius: 32px;
    animation: fadeIn 0.5s ease;
}

.empty-icon {
    width: 100px;
    height: 100px;
    background: linear-gradient(135deg, var(--primary-light) 0%, var(--secondary) 100%);
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 24px;
}

.empty-icon i {
    font-size: 48px;
    color: white;
}

.empty-title {
    font-size: 24px;
    font-weight: 700;
    margin-bottom: 12px;
    color: var(--gray-800);
}

.empty-text {
    color: var(--gray-600);
    margin-bottom: 32px;
}

/* Product Grid */
.products-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 28px;
}

/* Product Card */
.product-card-modern {
    background: white;
    border-radius: 24px;
    overflow: hidden;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    border: 1px solid var(--gray-200);
    position: relative;
    animation: fadeInUp 0.5s ease-out backwards;
}

.product-card-modern:hover {
    transform: translateY(-8px);
    box-shadow: var(--shadow-xl);
    border-color: transparent;
}

.card-image {
    position: relative;
    height: 240px;
    overflow: hidden;
    background: var(--gray-100);
}

.card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
}

.product-card-modern:hover .card-image img {
    transform: scale(1.08);
}

/* Status Badge */
.status-badge {
    position: absolute;
    top: 16px;
    right: 16px;
    padding: 6px 14px;
    border-radius: 100px;
    font-size: 12px;
    font-weight: 600;
    backdrop-filter: blur(8px);
    z-index: 2;
}

.status-available {
    background: rgba(16, 185, 129, 0.9);
    color: white;
}

.status-sold {
    background: rgba(239, 68, 68, 0.9);
    color: white;
}

.status-reserved {
    background: rgba(245, 158, 11, 0.9);
    color: white;
}

.status-hidden {
    background: rgba(107, 114, 128, 0.9);
    color: white;
}

/* Visibility Toggle */
.visibility-toggle {
    position: absolute;
    top: 16px;
    left: 16px;
    z-index: 2;
}

.toggle-switch {
    position: relative;
    display: inline-block;
    width: 50px;
    height: 24px;
}

.toggle-switch input {
    opacity: 0;
    width: 0;
    height: 0;
}

.toggle-slider {
    position: absolute;
    cursor: pointer;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-color: #ccc;
    transition: 0.4s;
    border-radius: 34px;
}

.toggle-slider:before {
    position: absolute;
    content: "";
    height: 18px;
    width: 18px;
    left: 3px;
    bottom: 3px;
    background-color: white;
    transition: 0.4s;
    border-radius: 50%;
}

input:checked + .toggle-slider {
    background-color: #10b981;
}

input:checked + .toggle-slider:before {
    transform: translateX(26px);
}

.toggle-label {
    font-size: 10px;
    margin-left: 8px;
    color: white;
    font-weight: 600;
}

/* Category Badge */
.category-badge {
    position: absolute;
    bottom: 16px;
    left: 16px;
    background: rgba(0, 0, 0, 0.7);
    backdrop-filter: blur(8px);
    padding: 4px 12px;
    border-radius: 100px;
    font-size: 11px;
    font-weight: 500;
    color: white;
    z-index: 2;
}

/* Card Content */
.card-content {
    padding: 20px;
}

.product-title {
    font-size: 18px;
    font-weight: 700;
    color: var(--gray-800);
    margin-bottom: 8px;
    line-height: 1.4;
}

.product-description {
    font-size: 14px;
    color: var(--gray-600);
    margin-bottom: 16px;
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
}

.price-section {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 16px;
    padding-bottom: 16px;
    border-bottom: 1px solid var(--gray-200);
}

.product-price {
    font-size: 24px;
    font-weight: 800;
    color: var(--primary);
}

.condition-tag {
    font-size: 12px;
    padding: 4px 10px;
    border-radius: 100px;
    font-weight: 600;
}

.condition-new { background: #d1fae5; color: #065f46; }
.condition-like-new { background: #d9f99d; color: #3f6212; }
.condition-good { background: #fed7aa; color: #9b2c1d; }
.condition-fair { background: #fef3c7; color: #92400e; }

/* Product Meta */
.product-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 20px;
    flex-wrap: wrap;
    gap: 8px;
}

.meta-item {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 12px;
    color: var(--gray-600);
}

.meta-item i {
    font-size: 12px;
    color: var(--primary);
}

/* Action Buttons */
.action-buttons {
    display: flex;
    gap: 10px;
}

.btn-action {
    flex: 1;
    padding: 10px;
    border-radius: 12px;
    font-size: 13px;
    font-weight: 500;
    text-align: center;
    text-decoration: none;
    transition: all 0.2s ease;
    cursor: pointer;
    border: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
}

.btn-view {
    background: var(--gray-100);
    color: var(--gray-700);
}

.btn-view:hover {
    background: var(--gray-200);
    transform: translateY(-2px);
}

.btn-edit {
    background: var(--warning);
    color: white;
}

.btn-edit:hover {
    background: #d97706;
    transform: translateY(-2px);
}

.btn-delete {
    background: var(--danger);
    color: white;
}

.btn-delete:hover {
    background: #dc2626;
    transform: translateY(-2px);
}

/* Night Mess Badge */
.nightmess-badge {
    background: linear-gradient(135deg, #f97316, #ea580c);
    position: absolute;
    top: 16px;
    left: 80px;
    padding: 4px 10px;
    border-radius: 20px;
    font-size: 10px;
    font-weight: 600;
    color: white;
    z-index: 2;
}

/* Toast */
.delete-toast {
    position: fixed;
    bottom: 30px;
    right: 30px;
    background: white;
    border-radius: 16px;
    padding: 16px 24px;
    box-shadow: var(--shadow-xl);
    display: flex;
    align-items: center;
    gap: 16px;
    z-index: 1000;
    animation: slideInRight 0.3s ease;
    border-left: 4px solid var(--danger);
}

.delete-toast i {
    font-size: 20px;
    color: var(--danger);
}

/* Animations */
@keyframes fadeInUp {
    from {
        opacity: 0;
        transform: translateY(30px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

@keyframes fadeIn {
    from {
        opacity: 0;
    }
    to {
        opacity: 1;
    }
}

@keyframes slideInRight {
    from {
        opacity: 0;
        transform: translateX(100px);
    }
    to {
        opacity: 1;
        transform: translateX(0);
    }
}

@keyframes slideOutRight {
    from {
        opacity: 1;
        transform: translateX(0);
    }
    to {
        opacity: 0;
        transform: translateX(100px);
    }
}

@keyframes slideUp {
    from {
        opacity: 0;
        transform: translateY(50px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

/* Responsive */
@media (max-width: 768px) {
    .products-page {
        padding: 20px;
    }
    
    .page-header {
        flex-direction: column;
        align-items: stretch;
    }
    
    .header-stats {
        justify-content: center;
    }
    
    .products-grid {
        grid-template-columns: 1fr;
        gap: 20px;
    }
    
    .action-buttons {
        flex-wrap: wrap;
    }
    
    .btn-action {
        flex: auto;
        min-width: calc(33.33% - 7px);
    }
    
    .tab-btn {
        padding: 8px 20px;
        font-size: 14px;
    }
}
</style>

<div class="products-page">
    <!-- Header -->
    <div class="page-header">
        <div class="header-left">
            <h1>My Items</h1>
            <p>Manage your marketplace products and night mess food items</p>
        </div>
        
        <div class="header-stats">
            <div class="stat-badge">
                <i class="fas fa-box"></i>
                <span>Products:</span>
                <span><%= products.length %></span>
            </div>
            <div class="stat-badge">
                <i class="fas fa-utensils"></i>
                <span>Food Items:</span>
                <span><%= nightmessItems.length %></span>
            </div>
            <div class="stat-badge">
                <i class="fas fa-eye-slash"></i>
                <span>Hidden:</span>
                <span><%= hiddenCount %></span>
            </div>
            <div class="stat-badge">
                <i class="fas fa-rupee-sign"></i>
                <span>Total Sales:</span>
                <span>₹<%= totalEarnings %></span>
            </div>
        </div>
        
        <div style="display: flex; gap: 12px; flex-wrap: wrap;">
            <button class="track-purchase-btn" onclick="showEarningsModal()">
                <i class="fas fa-chart-line"></i> Track Purchase
            </button>
            <a href="/marketplace/add-product" class="add-product-btn">
                <i class="fas fa-plus-circle"></i> Add Product
            </a>
            <a href="/nightmess/add-item" class="add-nightmess-btn">
                <i class="fas fa-plus-circle"></i> Add Food Item
            </a>
        </div>
    </div>
    
    <!-- Earnings Modal -->
    <div id="earningsModal" class="earnings-modal" style="display: none;">
        <div class="earnings-modal-content">
            <div class="earnings-modal-header">
                <h2><i class="fas fa-chart-line"></i> Sales Tracker</h2>
            </div>
            <div class="earnings-modal-body">
                <div class="earnings-total">
                    <div class="earnings-amount">₹<%= totalEarnings %></div>
                    <div class="earnings-label">Total Earnings</div>
                </div>
                
                <div class="earnings-breakdown">
                    <div class="breakdown-item">
                        <span class="breakdown-label">Products Sold:</span>
                        <span class="breakdown-value"><%= soldProductsCount %> items</span>
                    </div>
                    <div class="breakdown-item">
                        <span class="breakdown-label">Food Items Sold:</span>
                        <span class="breakdown-value"><%= soldFoodItemsCount %> items</span>
                    </div>
                    <div class="breakdown-item">
                        <span class="breakdown-label">Total Items Sold:</span>
                        <span class="breakdown-value"><%= soldProductsCount + soldFoodItemsCount %> items</span>
                    </div>
                    <div class="breakdown-item">
                        <span class="breakdown-label">Average Order Value:</span>
                        <span class="breakdown-value">₹<%= avgOrderValue %></span>
                    </div>
                </div>
                
                <div class="earnings-note">
                    <i class="fas fa-info-circle"></i>
                    <span>This includes all completed sales from your products and food items.</span>
                </div>
                
                <button class="close-modal-btn" onclick="closeEarningsModal()">Close</button>
            </div>
        </div>
    </div>
    
    <!-- Tabs -->
    <div class="tab-container">
        <div class="tab-buttons">
            <button class="tab-btn active" onclick="switchTab('products')">
                <i class="fas fa-box"></i> Products
            </button>
            <button class="tab-btn" onclick="switchTab('nightmess')">
                <i class="fas fa-utensils"></i> Night Mess Food
            </button>
        </div>
    </div>
    
    <!-- Products Tab -->
    <div id="productsTab" class="tab-content active">
        <% if (products.length === 0) { %>
            <div class="empty-state">
                <div class="empty-icon">
                    <i class="fas fa-store"></i>
                </div>
                <h3 class="empty-title">No products listed yet</h3>
                <p class="empty-text">Start selling your items and reach thousands of students on campus!</p>
                <a href="/marketplace/add-product" class="empty-btn">
                    <i class="fas fa-plus-circle"></i> Sell Your First Product
                </a>
            </div>
        <% } else { %>
            <div class="products-grid">
                <% products.forEach(product => { 
                    const statusClass = product.status === 'available' ? 'status-available' : 
                                       (product.status === 'sold' ? 'status-sold' : 'status-reserved');
                    const conditionClass = product.condition === 'New' ? 'condition-new' :
                                          (product.condition === 'Like New' ? 'condition-like-new' :
                                          (product.condition === 'Good' ? 'condition-good' : 'condition-fair'));
                %>
                    <div class="product-card-modern" data-product-id="<%= product._id %>" data-type="product">
                        <div class="card-image">
                            <img src="<%= product.images[0] %>" alt="<%= product.title %>">
                            <div class="visibility-toggle">
                                <label class="toggle-switch">
                                    <input type="checkbox" class="visibility-checkbox" 
                                           data-id="<%= product._id %>" 
                                           data-type="product"
                                           <%= product.status !== 'hidden' ? 'checked' : '' %>
                                           onchange="toggleVisibility('<%= product._id %>', 'product', this.checked)">
                                    <span class="toggle-slider"></span>
                                </label>
                                <span class="toggle-label">Visible</span>
                            </div>
                            <div class="status-badge <%= product.status === 'available' ? 'status-available' : (product.status === 'sold' ? 'status-sold' : (product.status === 'hidden' ? 'status-hidden' : 'status-reserved')) %>">
                                <i class="fas <%= product.status === 'available' ? 'fa-check-circle' : (product.status === 'sold' ? 'fa-shopping-cart' : (product.status === 'hidden' ? 'fa-eye-slash' : 'fa-clock')) %>"></i>
                                <%= product.status === 'hidden' ? 'HIDDEN' : product.status.toUpperCase() %>
                            </div>
                            <div class="category-badge">
                                <i class="fas fa-tag"></i> <%= product.category %>
                            </div>
                        </div>
                        
                        <div class="card-content">
                            <h3 class="product-title"><%= product.title %></h3>
                            <p class="product-description"><%= product.description.substring(0, 80) %><%= product.description.length > 80 ? '...' : '' %></p>
                            
                            <div class="price-section">
                                <span class="product-price">₹<%= product.price %></span>
                                <span class="condition-tag <%= conditionClass %>"><%= product.condition %></span>
                            </div>
                            
                            <div class="product-meta">
                                <div class="meta-item">
                                    <i class="fas fa-calendar-alt"></i>
                                    <span>Listed: <%= new Date(product.createdAt).toLocaleDateString() %></span>
                                </div>
                                <div class="meta-item">
                                    <i class="fas fa-eye"></i>
                                    <span><%= product.views %> views</span>
                                </div>
                                <div class="meta-item">
                                    <i class="fas fa-heart"></i>
                                    <span><%= product.interestedBuyers ? product.interestedBuyers.length : 0 %> interested</span>
                                </div>
                            </div>
                            
                            <div class="action-buttons">
                                <a href="/marketplace/product/<%= product._id %>" class="btn-action btn-view">
                                    <i class="fas fa-eye"></i> View
                                </a>
                                <a href="/marketplace/edit-product/<%= product._id %>" class="btn-action btn-edit">
                                    <i class="fas fa-edit"></i> Edit
                                </a>
                                <button onclick="deleteItem('<%= product._id %>', 'product', '<%= product.title %>')" class="btn-action btn-delete">
                                    <i class="fas fa-trash-alt"></i> Delete
                                </button>
                            </div>
                        </div>
                    </div>
                <% }) %>
            </div>
        <% } %>
    </div>
    
    <!-- Night Mess Tab -->
    <div id="nightmessTab" class="tab-content">
        <% if (nightmessItems.length === 0) { %>
            <div class="empty-state">
                <div class="empty-icon">
                    <i class="fas fa-utensils"></i>
                </div>
                <h3 class="empty-title">No food items added yet</h3>
                <p class="empty-text">Start selling your delicious food items to hungry students!</p>
                <a href="/nightmess/add-item" class="empty-btn" style="background: linear-gradient(135deg, #f97316, #ea580c);">
                    <i class="fas fa-plus-circle"></i> Add Your First Food Item
                </a>
            </div>
        <% } else { %>
            <div class="products-grid">
                <% nightmessItems.forEach(item => { 
                    const statusClass = item.status === 'available' ? 'status-available' : 
                                       (item.status === 'sold_out' ? 'status-sold' : 'status-hidden');
                %>
                    <div class="product-card-modern" data-item-id="<%= item._id %>" data-type="nightmess">
                        <div class="card-image">
                            <img src="<%= item.images[0] %>" alt="<%= item.title %>">
                            <div class="visibility-toggle">
                                <label class="toggle-switch">
                                    <input type="checkbox" class="visibility-checkbox" 
                                           data-id="<%= item._id %>" 
                                           data-type="nightmess"
                                           <%= item.status !== 'hidden' ? 'checked' : '' %>
                                           onchange="toggleVisibility('<%= item._id %>', 'nightmess', this.checked)">
                                    <span class="toggle-slider"></span>
                                </label>
                                <span class="toggle-label">Visible</span>
                            </div>
                            <div class="status-badge <%= statusClass %>">
                                <i class="fas <%= item.status === 'available' ? 'fa-check-circle' : (item.status === 'sold_out' ? 'fa-shopping-cart' : 'fa-eye-slash') %>"></i>
                                <%= item.status.toUpperCase() %>
                            </div>
                            <div class="category-badge">
                                <i class="fas fa-tag"></i> <%= item.category %>
                            </div>
                            <div class="nightmess-badge">
                                <i class="fas fa-utensils"></i> Night Mess
                            </div>
                        </div>
                        
                        <div class="card-content">
                            <h3 class="product-title"><%= item.title %></h3>
                            <p class="product-description"><%= item.description.substring(0, 80) %><%= item.description.length > 80 ? '...' : '' %></p>
                            
                            <div class="price-section">
                                <span class="product-price"><%= item.price > 0 ? '₹' + item.price : 'Price Varies' %></span>
                                <span class="condition-tag condition-good">Block <%= item.hostelBlock %></span>
                            </div>
                            
                            <div class="product-meta">
                                <div class="meta-item">
                                    <i class="fas fa-calendar-alt"></i>
                                    <span>Listed: <%= new Date(item.createdAt).toLocaleDateString() %></span>
                                </div>
                                <div class="meta-item">
                                    <i class="fas fa-eye"></i>
                                    <span><%= item.views %> views</span>
                                </div>
                                <div class="meta-item">
                                    <i class="fas fa-heart"></i>
                                    <span><%= item.interestedBuyers ? item.interestedBuyers.length : 0 %> interested</span>
                                </div>
                            </div>
                            
                            <div class="action-buttons">
                                <a href="/nightmess/item/<%= item._id %>" class="btn-action btn-view">
                                    <i class="fas fa-eye"></i> View
                                </a>
                                <a href="/nightmess/edit-item/<%= item._id %>" class="btn-action btn-edit">
                                    <i class="fas fa-edit"></i> Edit
                                </a>
                                <button onclick="deleteItem('<%= item._id %>', 'nightmess', '<%= item.title %>')" class="btn-action btn-delete">
                                    <i class="fas fa-trash-alt"></i> Delete
                                </button>
                            </div>
                        </div>
                    </div>
                <% }) %>
            </div>
        <% } %>
    </div>
</div>

<script>
function showEarningsModal() {
    document.getElementById('earningsModal').style.display = 'flex';
    document.body.style.overflow = 'hidden';
}

function closeEarningsModal() {
    document.getElementById('earningsModal').style.display = 'none';
    document.body.style.overflow = 'auto';
}

window.onclick = function(event) {
    const modal = document.getElementById('earningsModal');
    if (event.target === modal) {
        closeEarningsModal();
    }
}

function switchTab(tabName) {
    const tabs = document.querySelectorAll('.tab-btn');
    const contents = document.querySelectorAll('.tab-content');
    
    tabs.forEach(tab => tab.classList.remove('active'));
    contents.forEach(content => content.classList.remove('active'));
    
    if (tabName === 'products') {
        document.getElementById('productsTab').classList.add('active');
        document.querySelector('.tab-buttons button:first-child').classList.add('active');
    } else if (tabName === 'nightmess') {
        document.getElementById('nightmessTab').classList.add('active');
        document.querySelector('.tab-buttons button:last-child').classList.add('active');
    }
}

function toggleVisibility(id, type, isVisible) {
    const status = isVisible ? 'available' : 'hidden';
    let url;
    
    if (type === 'product') {
        url = `/marketplace/product/${id}/visibility`;
    } else {
        url = `/nightmess/item/${id}/visibility`;
    }
    
    fetch(url, {
        method: 'PUT',
        headers: {
            'Content-Type': 'application/json'
        },
        body: JSON.stringify({ status: status })
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            showToast(`Item is now ${isVisible ? 'visible' : 'hidden'}!`, 'success');
            setTimeout(() => window.location.reload(), 1000);
        } else {
            showToast('Failed to update visibility', 'error');
            const checkbox = document.querySelector(`.visibility-checkbox[data-id="${id}"][data-type="${type}"]`);
            if (checkbox) checkbox.checked = !isVisible;
        }
    })
    .catch(err => {
        showToast('Error updating visibility', 'error');
        const checkbox = document.querySelector(`.visibility-checkbox[data-id="${id}"][data-type="${type}"]`);
        if (checkbox) checkbox.checked = !isVisible;
    });
}

function deleteItem(id, type, title) {
    if (confirm(`Are you sure you want to delete "${title}"? This action cannot be undone.`)) {
        const url = type === 'product' ? '/marketplace/product/' : '/nightmess/item/';
        
        fetch(`${url}${id}`, {
            method: 'DELETE',
            headers: {
                'Content-Type': 'application/json'
            }
        })
        .then(response => response.json())
        .then(data => {
            if (data.success || response.ok) {
                showToast('Item deleted successfully!', 'success');
                setTimeout(() => window.location.reload(), 1000);
            } else {
                showToast('Error deleting item', 'error');
            }
        })
        .catch(error => {
            showToast('Error deleting item', 'error');
        });
    }
}

function showToast(message, type) {
    const toast = document.createElement('div');
    toast.className = 'delete-toast';
    
    const icon = type === 'success' ? 'fa-check-circle' : 'fa-exclamation-circle';
    const color = type === 'success' ? '#10b981' : '#ef4444';
    
    toast.innerHTML = `
        <i class="fas ${icon}" style="color: ${color};"></i>
        <span>${message}</span>
    `;
    
    document.body.appendChild(toast);
    
    setTimeout(() => {
        toast.style.animation = 'slideOutRight 0.3s ease forwards';
        setTimeout(() => toast.remove(), 300);
    }, 3000);
}

const style = document.createElement('style');
style.textContent = `
    @keyframes slideOutRight {
        from { opacity: 1; transform: translateX(0); }
        to { opacity: 0; transform: translateX(100px); }
    }
`;
document.head.appendChild(style);
</script>

<%- include('../partials/vall-promo-banner') %>