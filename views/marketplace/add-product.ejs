<%- include('../partials/header') %>

<style>
/* ========== VALL THEME VARIABLES ========== */
:root {
    --primary: #00d8ff;
    --primary-dark: #00b8e6;
    --primary-light: #33e0ff;
    --secondary: #7c3aed;
    --accent: #f97316;
    --success: #10b981;
    --dark: #dcdcdc;
    --gray-50: #f9fafb;
    --gray-100: #f3f4f6;
    --gray-200: #e5e7eb;
    --gray-300: #d1d5db;
    --gray-600: #ffffff;
    --gray-700: #ffffff;
    --gray-800: #ffffff;
    --shadow-sm: 0 1px 2px 0 rgb(0 0 0 / 0.05);
    --shadow-md: 0 4px 6px -1px rgb(0 0 0 / 0.1);
    --shadow-lg: 0 10px 15px -3px rgb(0 0 0 / 0.1);
    --shadow-xl: 0 20px 25px -5px rgb(0 0 0 / 0.1);
}

/* ========== MAIN CONTAINER ========== */
.sell-container {
    max-width: 900px;
    margin: 40px auto;
    padding: 0 20px;
}

/* ========== FORM CARD ========== */
.form-card {
    background: rgba(249, 249, 249, 0.8);
   
    border-radius: 32px;
   
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    border: 1px solid rgba(0, 216, 255, 0.1);
}

.form-card:hover {
    box-shadow: 0 25px 50px -12px rgba(0, 216, 255, 0.2);
    border-color: rgba(0, 216, 255, 0.3);
}

/* ========== HEADER SECTION ========== */
.form-header {
    background: linear-gradient(135deg, #00d8ff 0%, #7c3aed 100%);
    padding: 40px 40px 60px 40px;
    text-align: center;
    position: relative;
    overflow: hidden;
}

.form-header::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -20%;
    width: 200px;
    height: 200px;
    background: rgba(255, 255, 255, 0.1);
    border-radius: 50%;
    pointer-events: none;
}

.form-header::after {
    content: '';
    position: absolute;
    bottom: -30%;
    left: -10%;
    width: 300px;
    height: 300px;
    background: rgba(255, 255, 255, 0.05);
    border-radius: 50%;
    pointer-events: none;
}

.header-icon {
    width: 80px;
    height: 80px;
    background: rgba(255, 255, 255, 0.2);
    backdrop-filter: blur(10px);
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 24px;
    animation: float 3s ease-in-out infinite;
}

.header-icon i {
    font-size: 36px;
    color: white;
}

.header-title {
    font-size: 36px;
    font-weight: 800;
    color: white;
    margin-bottom: 12px;
    text-shadow: 0 0 20px rgba(0, 216, 255, 0.5);
}

.header-subtitle {
    font-size: 16px;
    color: rgba(255, 255, 255, 0.9);
    max-width: 400px;
    margin: 0 auto;
}

/* ========== FORM BODY ========== */
.form-body {
    padding: 40px;
    background: rgba(255, 255, 255, 0.6);
}

/* ========== FORM GROUPS ========== */
.form-group {
    margin-bottom: 28px;
    position: relative;
}

.form-label {
    display: block;
    font-size: 14px;
    font-weight: 600;
    color: black;
    margin-bottom: 8px;
}

.form-label i {
    color: black;
    margin-right: 8px;
}

.form-input,
.form-textarea,
.form-select {
    width: 100%;
    padding: 14px 16px;
    border: 1px solid rgba(0, 216, 255, 0.2);
    border-radius: 16px;
    font-size: 15px;
    transition: all 0.3s ease;
    background: rgba(243, 243, 243, 0.8);
    color: black;
    font-family: inherit;
}

.form-input:focus,
.form-textarea:focus,
.form-select:focus {
    outline: none;
    border-color: var(--primary);
    box-shadow: 0 0 0 4px rgba(0, 216, 255, 0.1);
    background: rgb(246, 246, 246);
}

.form-input::placeholder,
.form-textarea::placeholder {
    color: rgba(0, 0, 0, 0.87);
}

.form-textarea {
    resize: vertical;
    min-height: 120px;
}

.form-select option {
    background: #0f172a;
    color: var(--gray-200);
}

/* ========== ROW LAYOUT ========== */
.form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin-bottom: 28px;
}

@media (max-width: 640px) {
    .form-row {
        grid-template-columns: 1fr;
        gap: 28px;
    }
}

/* ========== CONTACT INFO SECTION ========== */
.contact-info-section {
    background: linear-gradient(135deg, rgba(0, 216, 255, 0.05) 0%, rgba(124, 58, 237, 0.05) 100%);
    border-radius: 20px;
    padding: 20px;
    margin-bottom: 28px;
    border: 1px solid rgba(0, 216, 255, 0.2);
}

.contact-info-section .form-label i {
    color: black;
}

.helper-text-small {
    font-size: 11px;
    color: black;
    margin-top: 4px;
}

/* ========== IMAGE UPLOAD ========== */
.image-upload-area {
    border: 2px dashed rgba(0, 216, 255, 0.3);
    border-radius: 20px;
    padding: 40px;
    text-align: center;
    transition: all 0.3s ease;
    cursor: pointer;
    background: rgba(232, 232, 233, 0.871);
    color: black;
}

.image-upload-area:hover {
    border-color: var(--primary);
    background: rgba(68, 68, 68, 0.05);
    transform: translateY(-2px);
}

.upload-icon {
    width: 64px;
    height: 64px;
    background: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%);
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 16px;
    box-shadow: 0 0 20px rgba(0, 216, 255, 0.3);
}

.upload-icon i {
    font-size: 24px;
    color: white;
}

.upload-title {
    font-size: 16px;
    font-weight: 600;
    color: black;
    margin-bottom: 8px;
}

.upload-hint {
    font-size: 13px;
    color: black;
}

.preview-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(100px, 1fr));
    gap: 16px;
    margin-top: 20px;
}

.preview-item {
    position: relative;
    aspect-ratio: 1;
    border-radius: 12px;
    overflow: hidden;
    background: rgba(10, 10, 26, 0.8);
    border: 1px solid rgba(0, 216, 255, 0.2);
    animation: fadeIn 0.3s ease;
}

.preview-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
}

.remove-image {
    position: absolute;
    top: 4px;
    right: 4px;
    width: 24px;
    height: 24px;
    background: rgba(0, 0, 0, 0.7);
    backdrop-filter: blur(4px);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.2s ease;
    color: white;
    font-size: 12px;
}

.remove-image:hover {
    background: #ef4444;
    transform: scale(1.1);
}

/* ========== BUTTONS ========== */
.btn-update {
    width: 100%;
    background: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%);
    border: none;
    padding: 16px;
    border-radius: 60px;
    color: rgb(252, 248, 248);
    font-size: 16px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    margin-bottom: 12px;
    position: relative;
    overflow: hidden;
}

.btn-update::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
    transition: left 0.5s ease;
}

.btn-update:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 25px rgba(0, 216, 255, 0.3);
}

.btn-update:hover::before {
    left: 100%;
}

.btn-cancel {
    width: 100%;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgb(0, 0, 0);
    padding: 14px;
    border-radius: 60px;
    color: black;
    font-size: 16px;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.3s ease;
    text-align: center;
    text-decoration: none;
    display: inline-block;
}

.btn-cancel:hover {
    background: rgba(0, 216, 255, 0.1);
    border-color: var(--primary);
    transform: translateY(-2px);
    color: white;
}

/* ========== HELPER TEXT ========== */
.helper-text {
    font-size: 12px;
    color: var(--gray-600);
    margin-top: 6px;
}

.required-star {
    color: var(--accent);
    margin-left: 4px;
}

/* ========== ANIMATIONS ========== */
@keyframes float {
    0%, 100% { transform: translateY(0px); }
    50% { transform: translateY(-8px); }
}

@keyframes fadeIn {
    from {
        opacity: 0;
        transform: scale(0.9);
    }
    to {
        opacity: 1;
        transform: scale(1);
    }
}

@keyframes slideUp {
    from {
        opacity: 0;
        transform: translateY(30px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

.form-card {
    animation: slideUp 0.5s ease-out;
}

/* ========== LOADING STATE ========== */
.btn-update.loading {
    opacity: 0.7;
    cursor: not-allowed;
}

.btn-update.loading i {
    animation: spin 1s linear infinite;
}

@keyframes spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
}
</style>

<div class="sell-container">
    <div class="form-card">
        <div class="form-header">
            <div class="header-icon">
                <i class="fas fa-store"></i>
            </div>
            <h1 class="header-title">Sell Your Item</h1>
            <p class="header-subtitle">List your item and reach thousands of students on campus</p>
        </div>
        
        <div class="form-body">
            <form action="/marketplace/add-product" method="POST" enctype="multipart/form-data" id="productForm">
                <!-- Title -->
                <div class="form-group">
                    <label class="form-label">
                        <i class="fas fa-tag"></i> Product Title <span class="required-star">*</span>
                    </label>
                    <input type="text" name="title" class="form-input" placeholder="e.g., Engineering Mathematics Textbook" required>
                </div>
                
                <!-- Description -->
                <div class="form-group">
                    <label class="form-label">
                        <i class="fas fa-align-left"></i> Description <span class="required-star">*</span>
                    </label>
                    <textarea name="description" rows="5" class="form-textarea" placeholder="Describe your item in detail... (condition, features, reason for selling, etc.)" required></textarea>
                </div>
                
                <!-- Price & Category Row -->
                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">
                            <i class="fas fa-rupee-sign"></i> Price <span class="required-star">*</span>
                        </label>
                        <input type="number" name="price" class="form-input" placeholder="Enter price" step="0.01" required>
                    </div>
                    
                    <div class="form-group">
                        <label class="form-label">
                            <i class="fas fa-folder"></i> Category <span class="required-star">*</span>
                        </label>
                        <select name="category" class="form-select" required>
                            <option value="" disabled selected>Select category</option>
                            <option value="Books">📚 Books & Textbooks</option>
                            <option value="Electronics">💻 Electronics & Gadgets</option>
                            <option value="Furniture">🪑 Furniture</option>
                            <option value="Clothing">👕 Clothing & Accessories</option>
                            <option value="Stationery">✏️ Stationery & Supplies</option>
                            <option value="Sports">⚽ Sports Equipment</option>
                            <option value="Others">🎁 Others</option>
                        </select>
                    </div>
                </div>
                
                <!-- Condition & Tags Row -->
                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">
                            <i class="fas fa-clipboard-check"></i> Condition <span class="required-star">*</span>
                        </label>
                        <select name="condition" class="form-select" required>
                            <option value="" disabled selected>Select condition</option>
                            <option value="New">✨ Brand New</option>
                            <option value="Like New">🌟 Like New (Unused)</option>
                            <option value="Good">👍 Good (Lightly used)</option>
                            <option value="Fair">🔄 Fair (Some wear)</option>
                            <option value="Poor">⚠️ Poor (Needs repair)</option>
                        </select>
                    </div>
                    
                    <div class="form-group">
                        <label class="form-label">
                            <i class="fas fa-hashtag"></i> Tags
                        </label>
                        <input type="text" name="tags" class="form-input" placeholder="textbook, calculator, bag">
                        <div class="helper-text">Separate tags with commas</div>
                    </div>
                </div>
                
                <!-- Contact Information Section -->
                <div class="contact-info-section">
                    <div class="form-group">
                        <label class="form-label">
                            <i class="fas fa-phone-alt"></i> Mobile Number <span class="required-star">*</span>
                        </label>
                        <input type="tel" name="sellerPhone" class="form-input" placeholder="Enter your mobile number (e.g., 9876543210)" required pattern="[0-9]{10}" title="Please enter a valid 10-digit mobile number">
                        <div class="helper-text-small">Buyers will see this number after showing interest</div>
                    </div>
                    <div class="form-group">
                        <label class="form-label">
                            <i class="fas fa-envelope"></i> Email Address <span class="required-star">*</span>
                        </label>
                        <input type="email" name="sellerEmail" class="form-input" value="<%= currUser ? currUser.email : '' %>" placeholder="Enter your email address" required>
                        <div class="helper-text-small">Buyers will contact you via email</div>
                    </div>
                </div>
                
                <!-- Image Upload -->
                <div class="form-group">
                    <label class="form-label">
                        <i class="fas fa-images"></i> Product Images <span class="required-star">*</span>
                    </label>
                    <div class="image-upload-area" onclick="document.getElementById('images').click()">
                        <div class="upload-icon mx-auto">
                            <i class="fas fa-cloud-upload-alt"></i>
                        </div>
                        <div class="upload-title">Click to upload images</div>
                        <div class="upload-hint">PNG, JPG up to 5MB each (Max 5 images)</div>
                        <input type="file" name="images" id="images" class="d-none" multiple accept="image/*" required onchange="previewImages(this)">
                    </div>
                    <div id="imagePreview" class="preview-grid"></div>
                </div>
                
                <!-- Submit Buttons -->
                <div style="margin-top: 32px;">
                    <button type="submit" class="btn-update" id="submitBtn">
                        <i class="fas fa-rocket"></i> List Item for Sale
                    </button>
                    <a href="/marketplace" class="btn-cancel">
                        <i class="fas fa-arrow-left"></i> Cancel
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
let selectedFiles = [];

function previewImages(input) {
    const preview = document.getElementById('imagePreview');
    
    if (input.files) {
        selectedFiles = Array.from(input.files);
        preview.innerHTML = '';
        
        selectedFiles.forEach((file, index) => {
            const reader = new FileReader();
            reader.onload = function(e) {
                const div = document.createElement('div');
                div.className = 'preview-item';
                div.innerHTML = `
                    <img src="${e.target.result}" alt="Preview">
                    <div class="remove-image" onclick="removeImage(${index})">
                        <i class="fas fa-times"></i>
                    </div>
                `;
                preview.appendChild(div);
            }
            reader.readAsDataURL(file);
        });
    }
}

function removeImage(indexToRemove) {
    selectedFiles = selectedFiles.filter((_, index) => index !== indexToRemove);
    
    const dataTransfer = new DataTransfer();
    selectedFiles.forEach(file => dataTransfer.items.add(file));
    document.getElementById('images').files = dataTransfer.files;
    
    if (selectedFiles.length === 0) {
        document.getElementById('imagePreview').innerHTML = '';
    } else {
        previewImages({ files: selectedFiles });
    }
}

document.getElementById('productForm').addEventListener('submit', function(e) {
    const submitBtn = document.getElementById('submitBtn');
    submitBtn.classList.add('loading');
    submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Listing Item...';
    submitBtn.disabled = true;
});
</script>

