<% layout("layouts/boilerplate") %>

<div class="container my-5">
    <div class="row">
        <div class="col-12">
            <h2>My Orders</h2>
            
            <% if (transactions.length === 0) { %>
                <div class="alert alert-info text-center">
                    <h4>No orders yet</h4>
                    <p>When you buy something, it will appear here!</p>
                </div>
            <% } else { %>
                <div class="row">
                    <% transactions.forEach(transaction => { %>
                        <div class="col-md-6 mb-4">
                            <div class="card shadow-sm">
                                <div class="card-body">
                                    <div class="row">
                                        <div class="col-md-4">
                                            <img src="<%= transaction.product.images[0] %>" class="img-fluid rounded" alt="<%= transaction.product.title %>">
                                        </div>
                                        <div class="col-md-8">
                                            <h5><%= transaction.product.title %></h5>
                                            <p class="text-muted">Seller: <%= transaction.seller.username %></p>
                                            <h5 class="text-primary">₹<%= transaction.product.price %></h5>
                                            <p class="small">Purchased on: <%= transaction.completedAt.toLocaleDateString() %></p>
                                            
                                            <% if (!transaction.rating || !transaction.rating.score) { %>
                                                <button class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#rateModal<%= transaction._id %>">
                                                    Rate & Review
                                                </button>
                                            <% } else { %>
                                                <div class="mt-2">
                                                    <strong>Your Rating:</strong>
                                                    <div class="text-warning">
                                                        <% for(let i=1; i<=5; i++) { %>
                                                            <% if (i <= transaction.rating.score) { %>
                                                                <i class="fas fa-star"></i>
                                                            <% } else { %>
                                                                <i class="far fa-star"></i>
                                                            <% } %>
                                                        <% } %>
                                                    </div>
                                                    <p class="small"><%= transaction.rating.review %></p>
                                                </div>
                                            <% } %>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        
                        <!-- Rating Modal -->
                        <div class="modal fade" id="rateModal<%= transaction._id %>" tabindex="-1">
                            <div class="modal-dialog">
                                <div class="modal-content">
                                    <form action="/marketplace/product/<%= transaction.product._id %>/rate" method="POST">
                                        <div class="modal-header">
                                            <h5 class="modal-title">Rate Product</h5>
                                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                        </div>
                                        <div class="modal-body">
                                            <div class="mb-3">
                                                <label class="form-label">Rating</label>
                                                <select name="rating" class="form-select" required>
                                                    <option value="">Select rating</option>
                                                    <option value="5">5 - Excellent</option>
                                                    <option value="4">4 - Good</option>
                                                    <option value="3">3 - Average</option>
                                                    <option value="2">2 - Poor</option>
                                                    <option value="1">1 - Terrible</option>
                                                </select>
                                            </div>
                                            <div class="mb-3">
                                                <label class="form-label">Review</label>
                                                <textarea name="review" rows="3" class="form-control" required></textarea>
                                            </div>
                                        </div>
                                        <div class="modal-footer">
                                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                                            <button type="submit" class="btn btn-primary">Submit Review</button>
                                        </div>
                                    </form>
                                </div>
                            </div>
                        </div>
                    <% }) %>
                </div>
            <% } %>
        </div>
    </div>
</div>

<%- include('../partials/vall-promo-banner') %>