<%- include('../partials/header') %>

<style>
@import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap');

:root {
    --primary: #008cff;
    --primary-dark: #0070d6;
    --success: #10b981;
    --warning: #f59e0b;
    --danger: #ef4444;
    --bg: #f0f8ff;
    --card-bg: #ffffff;
    --text-dark: #0f172a;
    --text-mid: #374151;
    --text-muted: #6b7280;
    --border: #e5e7eb;
    --shadow: 0 4px 24px rgba(0,140,255,0.08);
    --shadow-hover: 0 16px 48px rgba(0,140,255,0.18);
}

/* ========== BACK BUTTON ========== */
.back-nav {
    width: 100%;
    margin-bottom: 20px;
    display: flex;
    align-items: center;
    z-index: 2;
}

.btn-back-market {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 16px;
    background: rgba(255, 255, 255, 0.15);
    backdrop-filter: blur(8px);
    border: 1px solid rgba(255, 255, 255, 0.3);
    border-radius: 50px;
    color: white !important;
    text-decoration: none !important;
    font-size: 13px;
    font-weight: 600;
    transition: all 0.3s ease;
}

.btn-back-market:hover {
    background: rgba(255, 255, 255, 0.25);
    transform: translateX(-4px);
    box-shadow: 0 4px 15px rgba(0,0,0,0.1);
}

* { box-sizing: border-box; }

body { font-family: 'Inter', sans-serif; background: var(--bg); }

/* PAGE LAYOUT */
.orders-page {
    max-width: 1100px;
    margin: 0 auto;
    padding: 48px 20px 80px;
}

/* HERO HEADER */
.orders-hero {
    background: linear-gradient(135deg, #00d8ff 0%, #008cff 60%, #0070d6 100%);
    border-radius: 28px;
    padding: 40px 48px;
    margin-bottom: 40px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 24px;
    position: relative;
    overflow: hidden;
}

.orders-hero::before {
    content: '';
    position: absolute;
    top: -60px; right: -60px;
    width: 240px; height: 240px;
    background: rgba(255,255,255,0.08);
    border-radius: 50%;
}

.orders-hero::after {
    content: '';
    position: absolute;
    bottom: -40px; left: 30%;
    width: 160px; height: 160px;
    background: rgba(255,255,255,0.05);
    border-radius: 50%;
}

.hero-text h1 {
    font-size: 32px;
    font-weight: 800;
    color: white;
    margin: 0 0 8px;
}

.hero-text p {
    color: rgba(255,255,255,0.75);
    margin: 0;
    font-size: 15px;
}

.hero-stats {
    display: flex;
    gap: 32px;
    flex-wrap: wrap;
    z-index: 1;
}

.hero-stat {
    text-align: center;
    background: rgba(255,255,255,0.15);
    backdrop-filter: blur(8px);
    border-radius: 16px;
    padding: 16px 24px;
    border: 1px solid rgba(255,255,255,0.2);
}

.hero-stat-number {
    font-size: 28px;
    font-weight: 800;
    color: white;
    display: block;
    line-height: 1;
    margin-bottom: 4px;
}

.hero-stat-label {
    font-size: 12px;
    color: rgba(255,255,255,0.75);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

/* SECTION LABEL */
.section-label {
    font-size: 13px;
    font-weight: 700;
    color: var(--primary);
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 20px;
    display: flex;
    align-items: center;
    gap: 10px;
}

.section-label::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--border);
}

/* ORDER CARD */
.order-card {
    background: var(--card-bg);
    border-radius: 20px;
    border: 1px solid var(--border);
    margin-bottom: 20px;
    overflow: hidden;
    transition: all 0.35s cubic-bezier(0.4,0,0.2,1);
    animation: fadeUp 0.4s ease both;
}

.order-card:hover {
    box-shadow: var(--shadow-hover);
    border-color: var(--primary);
    transform: translateY(-4px);
}

.order-card-inner {
    display: flex;
    align-items: stretch;
    min-height: 160px;
}

/* IMAGE */
.order-image-wrap {
    width: 200px;
    flex-shrink: 0;
    position: relative;
    overflow: hidden;
    background: #f3f4f6;
}

.order-image-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
}

.order-card:hover .order-image-wrap img {
    transform: scale(1.06);
}

.order-image-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 8px;
    color: #9ca3af;
    min-height: 160px;
}

/* CONTENT */
.order-content {
    flex: 1;
    padding: 24px 28px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
}

.order-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 16px;
    flex-wrap: wrap;
    margin-bottom: 12px;
}

.order-title {
    font-size: 18px;
    font-weight: 700;
    color: var(--text-dark);
    margin: 0 0 4px;
    line-height: 1.3;
}

.order-seller {
    font-size: 13px;
    color: var(--text-muted);
    display: flex;
    align-items: center;
    gap: 6px;
}

.order-price {
    font-size: 26px;
    font-weight: 800;
    color: var(--primary);
    white-space: nowrap;
}

/* STATUS BADGE */
.order-status-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 5px 14px;
    border-radius: 100px;
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

.status-completed { background: #d1fae5; color: #065f46; }
.status-pending   { background: #fef3c7; color: #92400e; }

/* META ROW */
.order-meta {
    display: flex;
    align-items: center;
    gap: 20px;
    flex-wrap: wrap;
    margin-top: 12px;
    padding-top: 14px;
    border-top: 1px solid var(--border);
}

.meta-chip {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 12px;
    color: var(--text-muted);
    font-weight: 500;
}

.meta-chip i { color: var(--primary); font-size: 11px; }

/* STAR RATING */
.star-row {
    display: flex;
    align-items: center;
    gap: 3px;
}

.star-row i {
    font-size: 13px;
    color: #f59e0b;
}

/* RATE BUTTON */
.btn-rate {
    margin-left: auto;
    background: linear-gradient(135deg, var(--primary), #00d8ff);
    color: white;
    border: none;
    padding: 8px 20px;
    border-radius: 40px;
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    transition: all 0.25s;
    text-decoration: none;
}

.btn-rate:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 20px rgba(0,140,255,0.35);
    color: white;
}

/* REVIEW TEXT */
.review-text {
    font-size: 13px;
    color: var(--text-mid);
    font-style: italic;
    background: #f9fafb;
    border-radius: 10px;
    padding: 8px 14px;
    margin-top: 6px;
    border-left: 3px solid var(--primary);
}

/* EMPTY STATE */
.empty-state {
    text-align: center;
    padding: 80px 40px;
    background: white;
    border-radius: 28px;
    border: 1px solid var(--border);
}

.empty-icon-circle {
    width: 100px;
    height: 100px;
    border-radius: 50%;
    background: linear-gradient(135deg, #e0f8ff, #bae6fd);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 24px;
}

.empty-icon-circle i {
    font-size: 42px;
    color: var(--primary);
}

.empty-title {
    font-size: 24px;
    font-weight: 700;
    color: var(--text-dark);
    margin-bottom: 10px;
}

.empty-subtitle {
    color: var(--text-muted);
    margin-bottom: 28px;
    font-size: 15px;
}

.btn-shop {
    background: linear-gradient(135deg, #00d8ff, var(--primary));
    color: white;
    padding: 13px 32px;
    border-radius: 40px;
    text-decoration: none;
    font-weight: 700;
    display: inline-flex;
    align-items: center;
    gap: 10px;
    transition: all 0.25s;
    font-size: 15px;
}

.btn-shop:hover {
    transform: translateY(-3px);
    box-shadow: 0 12px 32px rgba(0,140,255,0.35);
    color: white;
}

/* MODAL */
.rate-modal { font-family: 'Inter', sans-serif; }
.modal-content { border-radius: 20px; border: none; box-shadow: 0 24px 80px rgba(0,0,0,0.18); }
.modal-header { border-bottom: 1px solid #f0f0f0; padding: 20px 24px; }
.modal-body { padding: 24px; }
.modal-footer { padding: 16px 24px; border-top: 1px solid #f0f0f0; }
.modal-title { font-weight: 700; font-size: 18px; }
.form-label { font-weight: 600; font-size: 14px; color: var(--text-mid); }
.form-select, .form-control { border-radius: 10px; border: 1px solid #e5e7eb; padding: 10px 14px; font-size: 14px; }
.form-select:focus, .form-control:focus { border-color: var(--primary); box-shadow: 0 0 0 3px rgba(0,140,255,0.12); }

/* ANIMATION */
@keyframes fadeUp {
    from { opacity: 0; transform: translateY(24px); }
    to   { opacity: 1; transform: translateY(0); }
}

/* RESPONSIVE */
@media (max-width: 700px) {
    .orders-hero { padding: 28px 24px; }
    .hero-text h1 { font-size: 24px; }
    .order-card-inner { flex-direction: column; }
    .order-image-wrap { width: 100%; height: 200px; }
    .order-content { padding: 18px; }
    .hero-stats { gap: 16px; }
}
</style>

<div class="orders-page">

    <!-- Hero Header -->
    <div class="orders-hero">
        <div class="back-nav">
            <a href="/marketplace" class="btn-back-market">
                <i class="fas fa-arrow-left"></i> Back to Marketplace
            </a>
        </div>
        <div class="hero-text" style="z-index:1;">
            <h1><i class="fas fa-shopping-bag" style="margin-right:10px;opacity:0.9;"></i>My Orders</h1>
            <p>Track everything you've purchased on the marketplace</p>
        </div>
        <div class="hero-stats">
            <div class="hero-stat">
                <span class="hero-stat-number"><%= transactions.length %></span>
                <span class="hero-stat-label">Total Orders</span>
            </div>
            <div class="hero-stat">
                <span class="hero-stat-number">₹<%= transactions.reduce((sum, t) => sum + (t.product ? t.product.price : 0), 0).toLocaleString('en-IN') %></span>
                <span class="hero-stat-label">Total Spent</span>
            </div>
        </div>
    </div>

    <% if (transactions.length === 0) { %>
        <!-- Empty State -->
        <div class="empty-state">
            <div class="empty-icon-circle">
                <i class="fas fa-box-open"></i>
            </div>
            <div class="empty-title">No orders yet</div>
            <div class="empty-subtitle">When you buy something from the marketplace, it will appear here.</div>
            <a href="/marketplace" class="btn-shop">
                <i class="fas fa-store"></i> Browse Marketplace
            </a>
        </div>
    <% } else { %>

        <div class="section-label">
            <i class="fas fa-receipt"></i> Order History
        </div>

        <% transactions.forEach((transaction, idx) => { %>
            <div class="order-card" style="animation-delay: <%= idx * 0.07 %>s">
                <div class="order-card-inner">

                    <!-- Product Image -->
                    <div class="order-image-wrap">
                        <% if (!transaction.product) { %>
                            <div class="order-image-placeholder">
                                <i class="fas fa-box-open fa-2x"></i>
                                <span style="font-size:12px;">Removed</span>
                            </div>
                        <% } else { %>
                            <img src="<%= (transaction.product.images && transaction.product.images.length > 0) ? (transaction.product.images[0].url || transaction.product.images[0]) : '/images/placeholder.png' %>"
                                 alt="<%= transaction.product.title %>">
                        <% } %>
                    </div>

                    <!-- Order Content -->
                    <div class="order-content">
                        <div>
                            <div class="order-top">
                                <div>
                                    <div class="order-title">
                                        <% if (transaction.product) { %>
                                            <a href="/marketplace/product/<%= transaction.product._id %>" style="color:inherit;text-decoration:none;">
                                                <%= transaction.product.title %>
                                            </a>
                                        <% } else { %>
                                            Product no longer available
                                        <% } %>
                                    </div>
                                    <div class="order-seller">
                                        <i class="fas fa-user-circle"></i>
                                        Sold by <strong style="color:#374151;margin-left:3px;"><%= transaction.seller ? transaction.seller.username : 'Unknown Seller' %></strong>
                                    </div>
                                </div>
                                <div style="text-align:right;">
                                    <div class="order-price">₹<%= transaction.product ? transaction.product.price.toLocaleString('en-IN') : '—' %></div>
                                    <span class="order-status-badge status-completed" style="margin-top:6px;display:inline-flex;">
                                        <i class="fas fa-check-circle"></i> Completed
                                    </span>
                                </div>
                            </div>

                            <!-- Rating Section -->
                            <% if (transaction.rating && transaction.rating.score) { %>
                                <div style="margin-top:8px;">
                                    <div class="star-row">
                                        <% for(let i=1; i<=5; i++) { %>
                                            <i class="fas fa-star<%= i <= transaction.rating.score ? '' : '' %>" style="color:<%= i <= transaction.rating.score ? '#f59e0b' : '#e5e7eb' %>"></i>
                                        <% } %>
                                        <span style="font-size:13px;color:#6b7280;margin-left:6px;">Your rating</span>
                                    </div>
                                    <% if (transaction.rating.review) { %>
                                        <div class="review-text">"<%= transaction.rating.review %>"</div>
                                    <% } %>
                                </div>
                            <% } %>
                        </div>

                        <!-- Meta Footer -->
                        <div class="order-meta">
                            <div class="meta-chip">
                                <i class="fas fa-calendar-alt"></i>
                                <%= transaction.completedAt ? transaction.completedAt.toLocaleDateString('en-IN', { day:'numeric', month:'short', year:'numeric' }) : 'N/A' %>
                            </div>
                            <% if (transaction.product && transaction.product.condition) { %>
                                <div class="meta-chip">
                                    <i class="fas fa-tag"></i> <%= transaction.product.condition %>
                                </div>
                            <% } %>
                            <% if (transaction.product && transaction.product.category) { %>
                                <div class="meta-chip">
                                    <i class="fas fa-layer-group"></i> <%= transaction.product.category %>
                                </div>
                            <% } %>

                            <!-- Rate Button -->
                            <% if (transaction.product && (!transaction.rating || !transaction.rating.score)) { %>
                                <button class="btn-rate" data-bs-toggle="modal" data-bs-target="#rateModal<%= transaction._id %>">
                                    <i class="fas fa-star"></i> Rate & Review
                                </button>
                            <% } %>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Rating Modal -->
            <% if (transaction.product) { %>
            <div class="modal fade rate-modal" id="rateModal<%= transaction._id %>" tabindex="-1">
                <div class="modal-dialog modal-dialog-centered">
                    <div class="modal-content">
                        <form action="/marketplace/product/<%= transaction.product._id %>/rate" method="POST">
                            <div class="modal-header">
                                <h5 class="modal-title">
                                    <i class="fas fa-star" style="color:#f59e0b;margin-right:8px;"></i>
                                    Rate: <%= transaction.product.title %>
                                </h5>
                                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                            </div>
                            <div class="modal-body">
                                <div class="mb-4">
                                    <label class="form-label">Overall Rating</label>
                                    <select name="rating" class="form-select" required>
                                        <option value="">Select a rating...</option>
                                        <option value="5">⭐⭐⭐⭐⭐ — Excellent (5/5)</option>
                                        <option value="4">⭐⭐⭐⭐ — Good (4/5)</option>
                                        <option value="3">⭐⭐⭐ — Average (3/5)</option>
                                        <option value="2">⭐⭐ — Poor (2/5)</option>
                                        <option value="1">⭐ — Terrible (1/5)</option>
                                    </select>
                                </div>
                                <div class="mb-2">
                                    <label class="form-label">Your Review</label>
                                    <textarea name="review" rows="4" class="form-control" placeholder="Share your experience with this product and seller..." required></textarea>
                                </div>
                            </div>
                            <div class="modal-footer">
                                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal" style="border-radius:40px;padding:8px 20px;">Cancel</button>
                                <button type="submit" class="btn-rate">
                                    <i class="fas fa-paper-plane"></i> Submit Review
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
            <% } %>

        <% }) %>

    <% } %>
</div>

<%- include('../partials/vall-promo-banner') %>