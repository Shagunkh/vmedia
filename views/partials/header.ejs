<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>VMALL - Campus Marketplace</title>
    
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    
    <style>
        /* ========== DARK NAVY GRADIENT NAVBAR - MATCHING BANNER ========== */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        :root {
            --dark-bg-start: #0f172a;
            --dark-bg-mid: #1e293b;
            --dark-bg-end: #0f172a;
            --accent-blue: #3b82f6;
            --accent-orange: #f97316;
            --text-light: #e2e8f0;
            --text-muted: #94a3b8;
        }
        
        .navbar-vmall {
            background: linear-gradient(135deg, #0f172a 0%, #1e293b 50%, #0f172a 100%);
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
            position: sticky;
            top: 0;
            z-index: 1000;
            border-bottom: 1px solid rgba(59, 130, 246, 0.2);
        }
        
        .navbar-container {
            max-width: 1400px;
            margin: 0 auto;
            padding: 0 24px;
            display: flex;
            align-items: center;
            height: 56px;
            gap: 20px;
        }
        
        /* Left Section - Logo */
        .navbar-left {
            flex-shrink: 0;
        }
        
        .navbar-logo {
            display: flex;
            align-items: center;
            gap: 10px;
            text-decoration: none;
        }
        
        .logo-icon {
            width: 34px;
            height: 34px;
            background: linear-gradient(135deg, #3b82f6, #000000);
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.3s ease;
        }
        
        .logo-icon i {
            font-size: 18px;
            color: white;
        }
        
        .logo-icon:hover {
            transform: scale(1.05);
            box-shadow: 0 0 15px rgba(59, 130, 246, 0.4);
        }
        
        .logo-text {
            font-size: 22px;
            font-weight: 800;
            background: linear-gradient(135deg, #60a5fa, #ffffff);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            letter-spacing: 0.5px;
        }
        
        /* Center - Search */
        .navbar-center {
            flex: 1;
            max-width: 450px;
        }
        
        .search-form {
            display: flex;
            gap: 8px;
            width: 100%;
        }
        
        .search-input {
            flex: 1;
            padding: 8px 18px;
            border: 1px solid rgba(59, 130, 246, 0.3);
            border-radius: 40px;
            font-size: 14px;
            background: rgba(15, 23, 42, 0.8);
            color: #e2e8f0;
            transition: all 0.3s ease;
        }
        
        .search-input::placeholder {
            color: #64748b;
        }
        
        .search-input:focus {
            outline: none;
            border-color: #3b82f6;
            background: rgba(15, 23, 42, 0.95);
            box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.2);
        }
        
        .search-btn {
            background: linear-gradient(135deg, #3b82f6, #2563eb);
            border: none;
            padding: 0 24px;
            border-radius: 40px;
            color: white;
            font-size: 13px;
            font-weight: 600;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 6px;
            white-space: nowrap;
            transition: all 0.3s ease;
        }
        
        .search-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(59, 130, 246, 0.4);
        }
        
        .search-btn i {
            font-size: 12px;
        }
        
        /* Right - Navigation Links */
        .navbar-right {
            display: flex;
            align-items: center;
            gap: 8px;
            flex-shrink: 0;
        }
        
        /* Desktop Navigation Links */
        .nav-link {
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 7px 14px;
            color: #cbd5e1;
            text-decoration: none;
            font-size: 13px;
            font-weight: 500;
            border-radius: 40px;
            transition: all 0.3s ease;
            white-space: nowrap;
        }
        
        .nav-link i {
            font-size: 13px;
        }
        
        .nav-link:hover {
            background: rgba(59, 130, 246, 0.15);
            color: #60a5fa;
            transform: translateY(-2px);
        }
        
        .nav-link.active {
            background: linear-gradient(135deg, rgba(59, 130, 246, 0.2), rgba(249, 115, 22, 0.1));
            color: #60a5fa;
            border: 1px solid rgba(59, 130, 246, 0.3);
        }
        
        /* User Menu */
        .user-menu {
            position: relative;
        }
        
        .user-avatar {
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 5px 12px 5px 8px;
            background: rgba(59, 130, 246, 0.1);
            border-radius: 40px;
            cursor: pointer;
            transition: all 0.3s ease;
            border: 1px solid rgba(59, 130, 246, 0.2);
        }
        
        .user-avatar:hover {
            background: rgba(59, 130, 246, 0.2);
            transform: translateY(-2px);
        }
        
        .avatar-icon {
            width: 28px;
            height: 28px;
            background: linear-gradient(135deg, #3b82f6, #f97316);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-weight: 600;
            font-size: 12px;
        }
        
        .user-name {
            font-weight: 500;
            font-size: 13px;
            color: #e2e8f0;
        }
        
        .dropdown-menu {
            position: absolute;
            top: 100%;
            right: 0;
            margin-top: 12px;
            background: linear-gradient(135deg, #0f172a, #1e293b);
            border-radius: 16px;
            box-shadow: 0 15px 35px rgba(0, 0, 0, 0.3);
            min-width: 200px;
            overflow: hidden;
            display: none;
            z-index: 1000;
            border: 1px solid rgba(59, 130, 246, 0.2);
        }
        
        .dropdown-menu.show {
            display: block;
            animation: fadeInDown 0.2s ease;
        }
        
        .dropdown-item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 10px 18px;
            color: #cbd5e1;
            text-decoration: none;
            font-size: 13px;
            transition: all 0.2s ease;
        }
        
        .dropdown-item i {
            font-size: 14px;
            width: 20px;
            color: #3b82f6;
        }
        
        .dropdown-item:hover {
            background: rgba(59, 130, 246, 0.15);
            color: #60a5fa;
            padding-left: 24px;
        }
        
        .dropdown-divider {
            height: 1px;
            background: rgba(59, 130, 246, 0.2);
            margin: 8px 0;
        }
        
        .logout-item {
            color: #f87171;
        }
        
        .logout-item i {
            color: #f87171;
        }
        
        .logout-item:hover {
            background: rgba(248, 113, 113, 0.15);
            color: #f87171;
        }
        
        /* Notification Badge */
        .notification-badge {
            position: relative;
        }
        
        .badge-count {
            position: absolute;
            top: -5px;
            right: -5px;
            background: #ef4444;
            color: white;
            font-size: 9px;
            font-weight: 600;
            padding: 2px 6px;
            border-radius: 50%;
            min-width: 18px;
            text-align: center;
            box-shadow: 0 0 8px rgba(239, 68, 68, 0.5);
        }
        
        @keyframes fadeInDown {
            from {
                opacity: 0;
                transform: translateY(-10px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
        
        /* ========== MOBILE NAVBAR ========== */
        @media (max-width: 992px) {
            .navbar-container {
                padding: 0 16px;
                gap: 12px;
            }
            
            .navbar-center {
                max-width: 280px;
            }
            
            .search-input {
                padding: 7px 12px;
                font-size: 12px;
            }
            
            .search-btn span {
                display: none;
            }
            
            .search-btn {
                padding: 0 16px;
            }
            
            /* Hide all nav links on mobile */
            .nav-link {
                display: none;
            }
            
            .user-menu {
                display: block;
            }
            
            .user-avatar {
                padding: 4px 10px 4px 6px;
            }
            
            .user-name {
                display: none;
            }
            
            .avatar-icon {
                width: 26px;
                height: 26px;
                font-size: 11px;
            }
        }
        
        @media (max-width: 768px) {
            .navbar-container {
                padding: 0 12px;
                height: 52px;
                gap: 8px;
            }
            
            .logo-icon {
                width: 30px;
                height: 30px;
            }
            
            .logo-icon i {
                font-size: 15px;
            }
            
            .logo-text {
                font-size: 18px;
                display: none;
            }
            
            .navbar-center {
                max-width: 200px;
            }
            
            .search-input {
                padding: 6px 10px;
                font-size: 11px;
            }
            
            .search-btn {
                padding: 0 12px;
            }
            
            .search-btn i {
                font-size: 11px;
            }
            
            .user-avatar {
                padding: 4px 8px;
            }
            
            .avatar-icon {
                width: 24px;
                height: 24px;
                font-size: 10px;
            }
        }
        
        @media (max-width: 480px) {
            .navbar-center {
                max-width: 160px;
            }
            
            .search-input {
                padding: 5px 8px;
                font-size: 10px;
            }
            
            .search-btn {
                padding: 0 10px;
            }
        }
        
        /* Flash Messages - Matching Theme */
        .alert {
            padding: 12px 20px;
            margin: 12px 20px;
            border-radius: 12px;
            font-size: 13px;
            background: linear-gradient(135deg, #0f172a, #1e293b);
            border: 1px solid rgba(59, 130, 246, 0.2);
            color: #e2e8f0;
        }
        
        .alert-success {
            border-left: 4px solid #10b981;
        }
        
        .alert-danger {
            border-left: 4px solid #ef4444;
        }
        
        .alert-info {
            border-left: 4px solid #3b82f6;
        }
        
        .btn-close-white {
            filter: invert(1) grayscale(100%) brightness(200%);
        }
    </style>
</head>
<body>

<nav class="navbar-vmall">
    <div class="navbar-container">
        <!-- Left: Logo -->
        <div class="navbar-left">
            <a href="/" class="navbar-logo">
                <div class="logo-icon">
                    <i class="fas fa-store"></i>
                </div>
                <span class="logo-text">VMALL</span>
            </a>
        </div>
        
        <!-- Center: Search -->
        <div class="navbar-center">
            <form class="search-form" action="/marketplace/search" method="GET">
                <input type="text" name="q" class="search-input" placeholder="Search products..." value="<%= typeof searchQuery !== 'undefined' ? searchQuery : '' %>">
                <button class="search-btn" type="submit">
                    <i class="fas fa-search"></i> <span>Search</span>
                </button>
            </form>
        </div>
        
        <!-- Right: Navigation -->
        <div class="navbar-right">
            <% if (currUser) { %>
                <!-- Desktop Navigation Links -->
                <a href="/marketplace" class="nav-link">
                    <i class="fas fa-store"></i> <span>Marketplace</span>
                </a>
                <a href="/marketplace/my-products" class="nav-link">
                    <i class="fas fa-box"></i> <span>My Products</span>
                </a>
                <a href="/marketplace/orders" class="nav-link">
                    <i class="fas fa-shopping-cart"></i> <span>My Orders</span>
                </a>
                <a href="/notifications" class="nav-link notification-badge">
                    <i class="fas fa-bell"></i> <span>Notifications</span>
                    <% if (notifications && notifications.length > 0) { %>
                        <span class="badge-count"><%= notifications.length %></span>
                    <% } %>
                </a>
                
                <!-- User Menu -->
                <div class="user-menu">
                    <div class="user-avatar" onclick="toggleDropdown()">
                        <div class="avatar-icon">
                            <%= currUser.username.charAt(0).toUpperCase() %>
                        </div>
                        <span class="user-name"><%= currUser.username %></span>
                        <i class="fas fa-chevron-down" style="font-size: 10px;"></i>
                    </div>
                    <div class="dropdown-menu" id="userDropdown">
                        <a href="/profile" class="dropdown-item">
                            <i class="fas fa-user-circle"></i> My Profile
                        </a>
                        <a href="/marketplace/my-products" class="dropdown-item">
                            <i class="fas fa-box"></i> My Products
                        </a>
                        <a href="/marketplace/orders" class="dropdown-item">
                            <i class="fas fa-shopping-cart"></i> My Orders
                        </a>
                        <a href="/marketplace/add-product" class="dropdown-item">
                            <i class="fas fa-plus-circle"></i> Sell an Item
                        </a>
                        <div class="dropdown-divider"></div>
                        <a href="/users/logout" class="dropdown-item logout-item">
                            <i class="fas fa-sign-out-alt"></i> Logout
                        </a>
                    </div>
                </div>
            <% } else { %>
                <a href="/users/login" class="nav-link active" id="loginLink">
                    <i class="fas fa-sign-in-alt"></i> Login
                </a>
                <a href="/users/register" class="nav-link" id="registerLink">
                    <i class="fas fa-user-plus"></i> Register
                </a>
            <% } %>
        </div>
    </div>
</nav>

<!-- Flash Messages -->
<% if (typeof success !== 'undefined' && success && success.length > 0) { %>
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="fas fa-check-circle me-2"></i> <%= success %>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert"></button>
    </div>
<% } %>

<% if (typeof error !== 'undefined' && error && error.length > 0) { %>
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="fas fa-exclamation-circle me-2"></i> <%= error %>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert"></button>
    </div>
<% } %>

<% if (typeof info !== 'undefined' && info && info.length > 0) { %>
    <div class="alert alert-info alert-dismissible fade show" role="alert">
        <i class="fas fa-info-circle me-2"></i> <%= info %>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert"></button>
    </div>
<% } %>

<!-- Chat Popup Styles and Scripts -->
<link rel="stylesheet" href="/css/chat-popup.css">
<script src="/socket.io/socket.io.js"></script>

<script>
    window.currentUser = {
        _id: '<%= currUser ? currUser._id : "" %>',
        username: '<%= currUser ? currUser.username : "" %>',
        profilePhoto: '<%= currUser ? currUser.profilePhoto : "" %>'
    };
    
    function toggleDropdown() {
        const dropdown = document.getElementById('userDropdown');
        dropdown.classList.toggle('show');
    }
    
    document.addEventListener('click', function(event) {
        const userMenu = document.querySelector('.user-menu');
        const dropdown = document.getElementById('userDropdown');
        if (userMenu && !userMenu.contains(event.target)) {
            if (dropdown) dropdown.classList.remove('show');
        }
    });
    
    setTimeout(function() {
        document.querySelectorAll('.alert').forEach(alert => {
            alert.style.transition = 'opacity 0.5s';
            alert.style.opacity = '0';
            setTimeout(() => alert.remove(), 500);
        });
    }, 5000);
    
    // Set return URL for login and register links
    const currentPageUrl = encodeURIComponent(window.location.pathname + window.location.search);
    
    document.addEventListener('DOMContentLoaded', function() {
        const loginLink = document.getElementById('loginLink');
        const registerLink = document.getElementById('registerLink');
        
        if (loginLink) {
            loginLink.href = `/users/login?returnTo=${currentPageUrl}`;
        }
        if (registerLink) {
            registerLink.href = `/users/register?returnTo=${currentPageUrl}`;
        }
    });
</script>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/chat-popup.js"></script>