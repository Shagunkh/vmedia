<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>VMALL - Campus Marketplace</title>
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    
    <style>
        /* ========== LIGHT THEME - WHITE BACKGROUND ========== */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        :root {
            --primary-cyan: #00d8ff;
            --primary-cyan-dark: #00b8e6;
            --primary-cyan-light: #33e0ff;
            --accent-blue: #008cff;
            --accent-purple: #7c3aed;
            --light-bg: #ffffff;
            --light-bg-2: #f8f9fa;
            --card-bg: #ffffff;
            --text-dark: #1f2937;
            --text-muted-light: #6c757d;
            --border-light: #e5e7eb;
            --shadow-light: 0 2px 10px rgba(0, 0, 0, 0.05);
            --neon-glow: 0 0 10px rgba(0, 216, 255, 0.3);
        }
        
        /* Slide-down animation on page load */
        .navbar-vmall {
            background: var(--light-bg);
            box-shadow: var(--shadow-light);
            position: sticky;
            top: 0;
            z-index: 1000;
            border-bottom: 1px solid var(--border-light);
            animation: slideDownNav 0.8s cubic-bezier(0.165, 0.84, 0.44, 1) forwards;
        }

        @keyframes slideDownNav {
            0% { transform: translateY(-100%); opacity: 0; }
            100% { transform: translateY(0); opacity: 1; }
        }
        
        .navbar-container {
            max-width: 1400px;
            margin: 0 auto;
            padding: 0 24px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            height: 70px;
            gap: 20px;
        }
        
        /* Left Section - Logo */
        .navbar-left {
            flex-shrink: 0;
        }
        
        .navbar-logo {
            display: flex;
            align-items: center;
            text-decoration: none;
        }
        
        /* Logo styling */
        .custom-logo {
            height: 60px;
            width: auto;
            object-fit: contain;
            transition: transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275), filter 0.3s ease;
        }

        .navbar-logo:hover .custom-logo {
            transform: scale(1.05) rotate(-1deg);
            filter: drop-shadow(0 0 10px rgba(0, 216, 255, 0.3));
        }
        
        /* Center - Search */
        .navbar-center {
            flex: 1;
            max-width: 500px;
        }
        
        .search-form {
            display: flex;
            gap: 8px;
            width: 100%;
        }
        
        .search-input {
            flex: 1;
            padding: 10px 20px;
            border: 1px solid var(--border-light);
            border-radius: 40px;
            font-size: 14px;
            background: var(--light-bg-2);
            color: var(--text-dark);
            transition: all 0.3s ease;
        }
        
        .search-input::placeholder {
            color: var(--text-muted-light);
        }
        
        .search-input:focus {
            outline: none;
            border-color: var(--primary-cyan);
            background: var(--light-bg);
            box-shadow: 0 0 0 3px rgba(0, 216, 255, 0.1);
        }
        
        .search-btn {
            background: linear-gradient(135deg, var(--primary-cyan), var(--accent-blue));
            border: none;
            padding: 0 28px;
            border-radius: 40px;
            color: white;
            font-size: 14px;
            font-weight: 600;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 8px;
            white-space: nowrap;
            transition: all 0.3s ease;
        }
        
        .search-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(0, 216, 255, 0.3);
        }

        .search-btn:hover i {
            animation: popIcon 0.4s ease forwards;
        }

        @keyframes popIcon {
            50% { transform: scale(1.2); }
            100% { transform: scale(1); }
        }
        
        .search-btn i {
            font-size: 14px;
        }
        
        /* Right - Navigation Links */
        .navbar-right {
            display: flex;
            align-items: center;
            gap: 12px;
            flex-shrink: 0;
        }
        
        /* Desktop Navigation Links */
        .nav-link {
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 8px 16px;
            color: var(--text-muted-light);
            text-decoration: none;
            font-size: 14px;
            font-weight: 500;
            border-radius: 40px;
            transition: all 0.3s ease;
            white-space: nowrap;
        }
        
        .nav-link i {
            font-size: 14px;
        }
        
        .nav-link:hover {
            background: rgba(0, 216, 255, 0.08);
            color: var(--primary-cyan);
            transform: translateY(-1px);
        }
        
        .nav-link.active {
            background: rgba(0, 216, 255, 0.1);
            color: var(--primary-cyan);
            border: 1px solid rgba(0, 216, 255, 0.2);
        }
        
        /* User Menu */
        .user-menu {
            position: relative;
        }
        
        .user-avatar {
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 6px 12px 6px 8px;
            background: var(--light-bg-2);
            border-radius: 40px;
            cursor: pointer;
            transition: all 0.3s ease;
            border: 1px solid var(--border-light);
        }
        
        .user-avatar:hover {
            background: rgba(0, 216, 255, 0.05);
            transform: translateY(-1px);
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
        }
        
        .avatar-icon {
            width: 32px;
            height: 32px;
            background: linear-gradient(135deg, var(--primary-cyan), var(--accent-blue));
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-weight: 600;
            font-size: 14px;
            box-shadow: 0 2px 8px rgba(0, 216, 255, 0.2);
        }
        
        .user-name {
            font-weight: 500;
            font-size: 14px;
            color: var(--text-dark);
        }
        
        .dropdown-menu {
            position: absolute;
            top: 100%;
            right: 0;
            margin-top: 12px;
            background: var(--light-bg);
            border-radius: 16px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
            min-width: 220px;
            overflow: hidden;
            display: none;
            z-index: 1000;
            border: 1px solid var(--border-light);
            transform-origin: top right;
        }
        
        .dropdown-menu.show {
            display: block;
            animation: popIn 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards;
        }

        @keyframes popIn {
            0% { opacity: 0; transform: scale(0.95) translateY(-10px); }
            100% { opacity: 1; transform: scale(1) translateY(0); }
        }
        
        .dropdown-item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 20px;
            color: var(--text-dark);
            text-decoration: none;
            font-size: 14px;
            transition: all 0.2s ease;
        }
        
        .dropdown-item i {
            font-size: 16px;
            width: 20px;
            color: var(--primary-cyan);
            transition: transform 0.2s ease;
        }
        
        .dropdown-item:hover {
            background: rgba(0, 216, 255, 0.05);
            color: var(--primary-cyan);
            padding-left: 28px;
        }

        .dropdown-item:hover i {
            transform: scale(1.1);
        }
        
        .dropdown-divider {
            height: 1px;
            background: var(--border-light);
            margin: 8px 0;
        }
        
        .logout-item {
            color: #dc2626;
        }
        
        .logout-item i {
            color: #dc2626;
        }
        
        .logout-item:hover {
            background: rgba(220, 38, 38, 0.05);
            color: #dc2626;
        }
        
        /* Notification Badge */
        .notification-badge {
            position: relative;
        }
        
        .badge-count {
            position: absolute;
            top: -5px;
            right: -5px;
            background: #ef4444;
            color: white;
            font-size: 10px;
            font-weight: 600;
            padding: 2px 6px;
            border-radius: 50%;
            min-width: 18px;
            text-align: center;
            box-shadow: 0 0 8px rgba(239, 68, 68, 0.5);
        }
        
        /* ========== MOBILE NAVBAR ========== */
        @media (max-width: 992px) {
            .navbar-container {
                padding: 0 16px;
                gap: 12px;
                justify-content: space-between;
                height: 60px;
            }
            .navbar-center { display: none; }
            .nav-link { display: none; }
            .user-menu { display: block; }
            
            .user-avatar { padding: 4px 10px 4px 6px; }
            .user-name { display: none; }
            
            .avatar-icon {
                width: 28px;
                height: 28px;
                font-size: 12px;
            }
            
            .custom-logo {
                height: 38px;
            }
        }
        
        @media (max-width: 768px) {
            .navbar-container {
                padding: 0 12px;
                height: 56px;
            }
            .custom-logo { 
                height: 34px;
            }
            
            .user-avatar { padding: 4px 8px; }
            .avatar-icon {
                width: 26px;
                height: 26px;
                font-size: 11px;
            }
        }
        
        @media (max-width: 480px) {
            .navbar-container { padding: 0 10px; }
            .custom-logo { 
                height: 30px;
            }
        }
        
        /* Flash Messages - Light Theme */
        .alert {
            padding: 12px 20px;
            margin: 12px 20px;
            border-radius: 12px;
            font-size: 13px;
            background: var(--light-bg);
            border: 1px solid var(--border-light);
            color: var(--text-dark);
            box-shadow: var(--shadow-light);
        }
        .alert-success { border-left: 4px solid #10b981; }
        .alert-danger { border-left: 4px solid #ef4444; }
        .alert-info { border-left: 4px solid var(--primary-cyan); }
        .btn-close { filter: none; }
        
        /* Body background */
        body {
            background: #f5f7fa;
        }
    </style>
</head>
<body>

<nav class="navbar-vmall">
    <div class="navbar-container">
        <div class="navbar-left">
            <a href="/" class="navbar-logo">
                <img src="/images/file_00000000ca2871fd90232408f4554b20.png" alt="VMALL Logo" class="custom-logo">
            </a>
        </div>
        
        <div class="navbar-center">
            <form class="search-form" action="/marketplace/search" method="GET">
                <input type="text" name="q" class="search-input" placeholder="Search products..." value="<%= typeof searchQuery !== 'undefined' ? searchQuery : '' %>">
                <button class="search-btn" type="submit">
                    <i class="fas fa-search"></i> <span>Search</span>
                </button>
            </form>
        </div>
        
        <div class="navbar-right">
            <% if (typeof currUser !== 'undefined' && currUser) { %>
                <a href="/marketplace" class="nav-link">
                    <i class="fas fa-store"></i> <span>Marketplace</span>
                </a>
                <a href="/marketplace/my-products" class="nav-link">
                    <i class="fas fa-box"></i> <span>My Products</span>
                </a>
                <a href="/marketplace/orders" class="nav-link">
                    <i class="fas fa-shopping-cart"></i> <span>My Orders</span>
                </a>
                
                <div class="user-menu">
                    <div class="user-avatar" onclick="toggleDropdown()">
                        <div class="avatar-icon">
                            <%= currUser.username.charAt(0).toUpperCase() %>
                        </div>
                        <span class="user-name"><%= currUser.username %></span>
                        <i class="fas fa-chevron-down" style="font-size: 10px; color: var(--text-muted-light);"></i>
                    </div>
                    <div class="dropdown-menu" id="userDropdown">
                        <a href="/marketplace" class="dropdown-item">
                            <i class="fas fa-store"></i> Marketplace
                        </a>
                        <a href="/profile" class="dropdown-item">
                            <i class="fas fa-user-circle"></i> My Profile
                        </a>
                        <a href="/marketplace/my-products" class="dropdown-item">
                            <i class="fas fa-box"></i> My Products
                        </a>
                        <a href="/marketplace/orders" class="dropdown-item">
                            <i class="fas fa-shopping-cart"></i> My Orders
                        </a>
                        <a href="/marketplace/add-product" class="dropdown-item">
                            <i class="fas fa-plus-circle"></i> Sell an Item
                        </a>
                        <div class="dropdown-divider"></div>
                        <a href="/users/logout" class="dropdown-item logout-item">
                            <i class="fas fa-sign-out-alt"></i> Logout
                        </a>
                    </div>
                </div>
            <% } else { %>
                <a href="/users/login" class="nav-link active" id="loginLink">
                    <i class="fas fa-sign-in-alt"></i> Login
                </a>
                <a href="/users/register" class="nav-link" id="registerLink">
                    <i class="fas fa-user-plus"></i> Register
                </a>
            <% } %>
        </div>
    </div>
</nav>

<% if (typeof success !== 'undefined' && success && success.length > 0) { %>
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="fas fa-check-circle me-2"></i> <%= success %>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
<% } %>

<% if (typeof error !== 'undefined' && error && error.length > 0) { %>
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="fas fa-exclamation-circle me-2"></i> <%= error %>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
<% } %>

<% if (typeof info !== 'undefined' && info && info.length > 0) { %>
    <div class="alert alert-info alert-dismissible fade show" role="alert">
        <i class="fas fa-info-circle me-2"></i> <%= info %>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
<% } %>

<link rel="stylesheet" href="/css/chat-popup.css">
<script src="/socket.io/socket.io.js"></script>

<script>
    window.currentUser = {
        _id: '<%= typeof currUser !== "undefined" && currUser ? currUser._id : "" %>',
        username: '<%= typeof currUser !== "undefined" && currUser ? currUser.username : "" %>',
        profilePhoto: '<%= typeof currUser !== "undefined" && currUser ? currUser.profilePhoto : "" %>'
    };
    
    function toggleDropdown() {
        const dropdown = document.getElementById('userDropdown');
        dropdown.classList.toggle('show');
    }
    
    document.addEventListener('click', function(event) {
        const userMenu = document.querySelector('.user-menu');
        const dropdown = document.getElementById('userDropdown');
        if (userMenu && !userMenu.contains(event.target)) {
            if (dropdown) dropdown.classList.remove('show');
        }
    });
    
    setTimeout(function() {
        document.querySelectorAll('.alert').forEach(alert => {
            alert.style.transition = 'opacity 0.5s';
            alert.style.opacity = '0';
            setTimeout(() => alert.remove(), 500);
        });
    }, 5000);
    
    const currentPageUrl = encodeURIComponent(window.location.pathname + window.location.search);
    
    document.addEventListener('DOMContentLoaded', function() {
        const loginLink = document.getElementById('loginLink');
        const registerLink = document.getElementById('registerLink');
        
        if (loginLink) {
            loginLink.href = `/users/login?returnTo=${currentPageUrl}`;
        }
        if (registerLink) {
            registerLink.href = `/users/register?returnTo=${currentPageUrl}`;
        }
    });
</script>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/vmall-confirm.js"></script>
<script src="/js/chat-popup.js"></script>
</body>
</html>