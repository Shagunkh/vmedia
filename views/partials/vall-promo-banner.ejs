<!-- VALL PROMO BANNER - Futuristic Design for The VITian Ecosystem -->
<style>
    /* ========== VALL PROMO BANNER ========== */
    .vall-promo {
        position: relative;
        background: linear-gradient(135deg, #0a0a1a 0%, #000000 100%);
        margin: 60px 20px;
        border-radius: 48px;
        overflow: hidden;
        cursor: pointer;
        transition: all 0.6s cubic-bezier(0.165, 0.84, 0.44, 1);
        border: 1px solid rgba(0, 216, 255, 0.2);
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3);
    }
    
    .vall-promo:hover {
        transform: translateY(-10px);
        box-shadow: 0 30px 60px rgba(0, 140, 255, 0.2);
        border-color: rgba(0, 216, 255, 0.5);
    }
    
    /* Animated Background */
    .promo-bg {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        overflow: hidden;
        z-index: 0;
    }
    
    .promo-bg::before {
        content: '';
        position: absolute;
        width: 200%;
        height: 200%;
        top: -50%;
        left: -50%;
        background: radial-gradient(circle, rgba(0, 216, 255, 0.08) 0%, transparent 70%);
        animation: rotateBg 25s linear infinite;
    }
    
    @keyframes rotateBg {
        from { transform: rotate(0deg); }
        to { transform: rotate(360deg); }
    }
    
    /* Floating Particles */
    .promo-particles {
        position: absolute;
        width: 100%;
        height: 100%;
        pointer-events: none;
    }
    
    .particle {
        position: absolute;
        width: 2px;
        height: 2px;
        background: #00d8ff;
        border-radius: 50%;
        opacity: 0;
        animation: floatParticle 10s ease-in-out infinite;
    }
    
    @keyframes floatParticle {
        0% {
            opacity: 0;
            transform: translateY(0) translateX(0);
        }
        10% {
            opacity: 0.6;
        }
        90% {
            opacity: 0.4;
        }
        100% {
            opacity: 0;
            transform: translateY(-150px) translateX(80px);
        }
    }
    
    /* Content Container */
    .promo-content {
        position: relative;
        z-index: 2;
        padding: 60px 50px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 40px;
    }
    
    /* Left Section */
    .promo-left {
        flex: 1;
        min-width: 280px;
    }
    
    .promo-badge {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: rgba(0, 216, 255, 0.1);
        backdrop-filter: blur(10px);
        padding: 8px 20px;
        border-radius: 100px;
        margin-bottom: 24px;
        border: 1px solid rgba(0, 216, 255, 0.3);
        animation: pulseGlow 2s infinite;
    }
    
    .promo-badge i {
        color: #00d8ff;
        font-size: 14px;
    }
    
    .promo-badge span {
        color: #00d8ff;
        font-size: 13px;
        font-weight: 500;
        letter-spacing: 1px;
    }
    
    @keyframes pulseGlow {
        0%, 100% {
            box-shadow: 0 0 0 0 rgba(0, 216, 255, 0.3);
        }
        50% {
            box-shadow: 0 0 0 15px rgba(0, 216, 255, 0);
        }
    }
    
    .promo-title {
        font-size: 52px;
        font-weight: 800;
        line-height: 1.2;
        margin-bottom: 20px;
        color: white;
    }
    
    .promo-title span {
        background: linear-gradient(135deg, #00d8ff, #008cff);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        position: relative;
        display: inline-block;
        animation: titleGlow 3s ease-in-out infinite alternate;
    }
    
    @keyframes titleGlow {
        from {
            text-shadow: 0 0 10px rgba(0, 216, 255, 0.3);
        }
        to {
            text-shadow: 0 0 20px rgba(0, 216, 255, 0.6), 0 0 30px rgba(0, 140, 255, 0.4);
        }
    }
    
    .promo-description {
        font-size: 17px;
        color: #a1a1a6;
        margin-bottom: 32px;
        line-height: 1.6;
        max-width: 500px;
    }
    
    /* Features Grid */
    .promo-features {
        display: flex;
        flex-wrap: wrap;
        gap: 16px;
        margin-bottom: 32px;
    }
    
    .feature-item {
        display: flex;
        align-items: center;
        gap: 8px;
        background: rgba(255, 255, 255, 0.03);
        padding: 10px 18px;
        border-radius: 40px;
        border: 1px solid rgba(255, 255, 255, 0.05);
        transition: all 0.3s ease;
    }
    
    .feature-item:hover {
        background: rgba(0, 216, 255, 0.1);
        border-color: rgba(0, 216, 255, 0.3);
        transform: translateX(5px);
    }
    
    .feature-item i {
        color: #00d8ff;
        font-size: 14px;
    }
    
    .feature-item span {
        color: #e0e0e0;
        font-size: 13px;
        font-weight: 500;
    }
    
    /* CTA Button */
    .promo-cta {
        display: inline-flex;
        align-items: center;
        gap: 12px;
        background: linear-gradient(135deg, #00d8ff, #008cff);
        color: white;
        padding: 14px 36px;
        border-radius: 50px;
        text-decoration: none;
        font-weight: 600;
        font-size: 16px;
        transition: all 0.4s ease;
        position: relative;
        overflow: hidden;
        box-shadow: 0 5px 20px rgba(0, 140, 255, 0.3);
    }
    
    .promo-cta::before {
        content: '';
        position: absolute;
        top: 0;
        left: -100%;
        width: 100%;
        height: 100%;
        background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.3), transparent);
        transition: left 0.6s ease;
    }
    
    .promo-cta:hover {
        transform: translateY(-3px);
        box-shadow: 0 15px 30px rgba(0, 140, 255, 0.5);
    }
    
    .promo-cta:hover::before {
        left: 100%;
    }
    
    .promo-cta i {
        transition: transform 0.3s ease;
    }
    
    .promo-cta:hover i {
        transform: translateX(5px);
    }
    
    /* Right Section - 3D Stats Card */
    .promo-right {
        flex: 0.8;
        min-width: 300px;
        background: rgba(10, 10, 26, 0.6);
        backdrop-filter: blur(20px);
        border-radius: 32px;
        padding: 32px;
        border: 1px solid rgba(0, 216, 255, 0.15);
        position: relative;
        overflow: hidden;
        transform-style: preserve-3d;
        transition: all 0.4s ease;
    }
    
    .vall-promo:hover .promo-right {
        transform: translateZ(20px);
    }
    
    .promo-right::before {
        content: '';
        position: absolute;
        top: -50%;
        left: -50%;
        width: 200%;
        height: 200%;
        background: radial-gradient(circle, rgba(0, 216, 255, 0.05) 0%, transparent 70%);
        animation: rotateSlow 20s linear infinite;
    }
    
    @keyframes rotateSlow {
        from { transform: rotate(0deg); }
        to { transform: rotate(360deg); }
    }
    
    .stats-3d {
        position: relative;
        z-index: 2;
    }
    
    .stat-3d-item {
        text-align: center;
        margin-bottom: 24px;
        padding: 20px;
        background: rgba(0, 0, 0, 0.4);
        border-radius: 20px;
        transition: all 0.3s ease;
        border: 1px solid rgba(0, 216, 255, 0.05);
    }
    
    .stat-3d-item:hover {
        transform: scale(1.02);
        background: rgba(0, 216, 255, 0.08);
        border-color: rgba(0, 216, 255, 0.2);
    }
    
    .stat-3d-number {
        font-size: 44px;
        font-weight: 800;
        background: linear-gradient(135deg, #00d8ff, #008cff);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        margin-bottom: 8px;
        display: block;
    }
    
    .stat-3d-label {
        font-size: 14px;
        color: #a1a1a6;
        letter-spacing: 1px;
    }
    
    .divider {
        height: 1px;
        background: linear-gradient(90deg, transparent, rgba(0, 216, 255, 0.3), transparent);
        margin: 24px 0;
    }
    
    /* Quote Section */
    .quote-section {
        text-align: center;
        margin-top: 20px;
        padding: 16px;
        background: rgba(0, 216, 255, 0.03);
        border-radius: 20px;
    }
    
    .quote-text {
        font-size: 14px;
        color: #c0c0c0;
        font-style: italic;
        line-height: 1.5;
        margin-bottom: 12px;
    }
    
    .quote-author {
        font-size: 12px;
        color: #00d8ff;
        font-weight: 500;
    }
    
    /* Responsive */
    @media (max-width: 992px) {
        .promo-content {
            flex-direction: column;
            text-align: center;
            padding: 40px 30px;
        }
        
        .promo-title {
            font-size: 40px;
        }
        
        .promo-description {
            margin-left: auto;
            margin-right: auto;
        }
        
        .promo-features {
            justify-content: center;
        }
        
        .promo-right {
            width: 100%;
        }
    }
    
    @media (max-width: 768px) {
        .vall-promo {
            margin: 40px 16px;
            border-radius: 32px;
        }
        
        .promo-title {
            font-size: 32px;
        }
        
        .promo-description {
            font-size: 14px;
        }
        
        .feature-item {
            padding: 6px 12px;
        }
        
        .feature-item span {
            font-size: 11px;
        }
        
        .stat-3d-number {
            font-size: 36px;
        }
    }
    
    @media (max-width: 480px) {
        .promo-title {
            font-size: 28px;
        }
        
        .promo-features {
            gap: 10px;
        }
        
        .feature-item {
            padding: 5px 10px;
        }
        
        .promo-cta {
            padding: 12px 28px;
            font-size: 14px;
        }
    }
    @media (max-width: 768px) {
    .vall-promo {
        margin: 30px 12px;
        border-radius: 32px;
    }
    
    .promo-content {
        flex-direction: column;
        text-align: center;
        padding: 30px 24px;
        gap: 32px;
    }
    
    .promo-left {
        min-width: auto;
        width: 100%;
    }
    
    .promo-badge {
        padding: 6px 16px;
        margin-bottom: 20px;
    }
    
    .promo-badge i {
        font-size: 12px;
    }
    
    .promo-badge span {
        font-size: 11px;
    }
    
    .promo-title {
        font-size: 32px;
        line-height: 1.3;
        margin-bottom: 16px;
    }
    
    .promo-description {
        font-size: 14px;
        margin-bottom: 24px;
        margin-left: auto;
        margin-right: auto;
    }
    
    .promo-features {
        justify-content: center;
        gap: 10px;
        margin-bottom: 28px;
    }
    
    .feature-item {
        padding: 6px 12px;
    }
    
    .feature-item i {
        font-size: 11px;
    }
    
    .feature-item span {
        font-size: 10px;
    }
    
    .promo-cta {
        padding: 12px 28px;
        font-size: 14px;
    }
    
    .promo-right {
        width: 100%;
        min-width: auto;
        padding: 24px;
    }
    
    .stat-3d-item {
        margin-bottom: 20px;
        padding: 16px;
    }
    
    .stat-3d-number {
        font-size: 32px;
    }
    
    .stat-3d-label {
        font-size: 12px;
    }
    
    .divider {
        margin: 20px 0;
    }
    
    .quote-section {
        padding: 12px;
    }
    
    .quote-text {
        font-size: 12px;
    }
    
    .quote-author {
        font-size: 10px;
    }
}

